---
import '../assets/styles/global.css';
import CookieConsent from '@components/ui/banners/CookieConsent.astro';
import { SITE, getLocalizedSiteUrl, getSiteUrl } from '@/constants';

interface Props {
	lang?: string;
	title?: string;
}

const { lang = 'en', title = 'WinFlowz — Productivity Plugins & Windows Training' } = Astro.props;

const description = lang === 'fr'
	? 'Formation Windows en 8 modules, plugins Obsidian et outils Chrome pour construire un workflow plus fluide avec 200+ astuces testees.'
	: 'Windows training in 8 modules, Obsidian plugins, and Chrome tools for building a smoother workflow with 200+ tested tips.';

const ogImage = getSiteUrl(SITE.ogImage);
const siteUrl = getLocalizedSiteUrl(lang === 'fr' ? 'fr' : 'en');
---

<html lang={lang} class="scroll-pt-16">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<title>{title}</title>

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="600" />
		<meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />
		<meta property="og:site_name" content={SITE.name} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Alternate languages -->
		<link rel="alternate" hreflang="en" href={getLocalizedSiteUrl('en')} />
		<link rel="alternate" hreflang="fr" href={getLocalizedSiteUrl('fr')} />
		<link rel="canonical" href={siteUrl} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Audiowide&family=Manrope:wght@200..800&family=DM+Sans:opsz,wght@9..40,100..1000&family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet" />
		<link rel="icon" type="image/png" href="/images/WinFlowz.png" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<meta name="theme-color" content="#ff00c8" />
		<script is:inline>
			(() => {
				const storedTheme = localStorage.getItem('hs_theme')
				const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches
					? 'dark'
					: 'light'
				const theme = storedTheme || systemTheme
				const root = document.documentElement

				root.classList.remove('dark', 'light')
				root.classList.add(theme)
				root.setAttribute('data-theme', theme)
			})()
		</script>
	</head>
	<body id="top" class="landing-page bg-background text-foreground font-sans antialiased transition-colors duration-300">
		<div class="noise-overlay" aria-hidden="true"></div>
		<slot />
		<CookieConsent />
		{
			import.meta.env.PROD && (
				<script is:inline async src="https://cdn.onthe.io/io.js/YyAMWtaLLPUi" />
			)
		}
		<!-- CTA click tracking -->
		<script>
			document.addEventListener('click', (e) => {
				const target = (e.target as HTMLElement).closest('[data-track]') as HTMLElement | null;
				if (!target) return;
				const event = target.dataset.track;
				if (!event) return;
				// Fire via Vercel Analytics if available
				if (typeof (window as any).va === 'function') {
					(window as any).va('event', { name: event });
				}
			});
		</script>
		<script>
			import Lenis from 'lenis';

			const lenis = new Lenis({
				duration: 1.2,
				easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
				smoothWheel: true,
			});

			function raf(time: number) {
				lenis.raf(time);
				requestAnimationFrame(raf);
			}

			requestAnimationFrame(raf);

			// Intersection Observer for .reveal elements
			const observer = new IntersectionObserver((entries) => {
				entries.forEach(e => {
					if (e.isIntersecting) {
						e.target.classList.add('revealed');
						observer.unobserve(e.target);
					}
				});
			}, { rootMargin: '-80px' });
			document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
		</script>
</body>
</html>

<style is:global>
	@import '../assets/styles/landing.css';
</style>

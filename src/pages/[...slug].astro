---
import { getCollection } from 'astro:content';
import DocsLayout from '@/layouts/DocsLayout.astro';
import CoursePreviewGate from '@/components/overrides/CoursePreviewGate.astro';
import { buildDocTree, getDocLang, getDocPager } from '@/utils/docs';
import { isFormationSlug } from '@/utils/courseGating';

export const prerender = true;

export async function getStaticPaths() {
  const docs = await getCollection('docs', ({ data }) => !data.draft);
  return docs.map((entry) => ({
    params: {
      slug: entry.slug,
    },
  }));
}

const requestedSlug = Astro.params.slug?.replace(/\/$/, '');
const docs = await getCollection('docs');
const entry = docs.find((doc) => doc.slug.replace(/\/$/, '') === requestedSlug);

if (!entry || entry.data.draft) {
  return Astro.redirect('/404');
}

const { Content, headings } = await entry.render();
const lang = getDocLang(entry.slug);
const sidebar = buildDocTree(docs, lang);
const pager = getDocPager(docs, lang, entry.slug);
const isFormationPage = isFormationSlug(entry.slug);
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  lang={lang}
  sidebar={sidebar}
  headings={headings}
  currentPath={Astro.url.pathname}
  pager={pager}
>
  {
    isFormationPage ? (
      <CoursePreviewGate
        entry={{ slug: entry.slug, body: entry.body }}
        headings={headings}
        isAuthenticated={false}
        hasAccess={false}
      />
    ) : (
      <Content />
    )
  }
</DocsLayout>

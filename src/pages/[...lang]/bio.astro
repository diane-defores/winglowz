---
import type { Language } from '@/types'

export const prerender = true

export async function getStaticPaths() {
	return [
		{
			params: { lang: undefined },
			props: { lang: 'en' as Language },
		},
		{
			params: { lang: 'fr' },
			props: { lang: 'fr' as Language },
		},
	]
}

interface Props {
	lang: Language
}

const { lang } = Astro.props
const isEn = lang === 'en'

const title = isEn ? 'WinFlowz | Links' : 'WinFlowz | Liens'
const description = isEn
	? 'Chrome extensions, Obsidian plugins & Windows productivity guide with 200+ tested tips.'
	: 'Extensions Chrome, plugins Obsidian et guide de productivité Windows avec 200+ astuces testées.'
const siteUrl = 'https://winflowz.com'
const langPrefix = isEn ? '' : '/fr'
---

<!DOCTYPE html>
<html lang={lang} class="dark">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>{title}</title>
	<meta name="description" content={description} />
	<meta name="robots" content="index, follow" />
	<link rel="canonical" href={`${siteUrl}${langPrefix}/bio`} />

	<link rel="alternate" hreflang="en" href={`${siteUrl}/bio`} />
	<link rel="alternate" hreflang="fr" href={`${siteUrl}/fr/bio`} />
	<link rel="alternate" hreflang="x-default" href={`${siteUrl}/bio`} />

	<meta property="og:title" content={title} />
	<meta property="og:description" content={description} />
	<meta property="og:url" content={`${siteUrl}${langPrefix}/bio`} />
	<meta property="og:type" content="website" />
	<meta property="og:site_name" content="WinFlowz" />
	<meta property="og:locale" content={isEn ? 'en_US' : 'fr_FR'} />

	<meta name="twitter:card" content="summary" />
	<meta name="twitter:title" content={title} />
	<meta name="twitter:description" content={description} />

	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Audiowide&family=Manrope:wght@400;500;600;700&family=DM+Sans:opsz,wght@9..40,400;9..40,500&display=swap" rel="stylesheet" />

	<style>
		:root {
			--bg: #000;
			--card-bg: rgba(255, 255, 255, 0.03);
			--card-border: rgba(255, 255, 255, 0.08);
			--text: #fff;
			--text-muted: rgba(255, 255, 255, 0.6);
			--accent: #ff00c8;
			--accent-glow: rgba(255, 0, 200, 0.3);
		}

		* { margin: 0; padding: 0; box-sizing: border-box; }

		body {
			font-family: 'DM Sans', system-ui, sans-serif;
			background: var(--bg);
			color: var(--text);
			min-height: 100vh;
			display: flex;
			justify-content: center;
			padding: 2rem 1rem;
		}

		/* Noise overlay */
		body::before {
			content: '';
			position: fixed;
			inset: 0;
			background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
			pointer-events: none;
			z-index: 0;
		}

		.bio-container {
			width: 100%;
			max-width: 480px;
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 1.5rem;
			position: relative;
			z-index: 1;
		}

		.bio-avatar {
			width: 96px;
			height: 96px;
			border-radius: 50%;
			border: 2px solid var(--accent);
			display: flex;
			align-items: center;
			justify-content: center;
			background: var(--card-bg);
			box-shadow: 0 0 30px var(--accent-glow);
			overflow: hidden;
		}

		.bio-avatar img {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}

		.bio-name {
			font-family: 'Audiowide', cursive;
			font-size: 1.5rem;
			text-align: center;
			color: var(--text);
			letter-spacing: 0.05em;
		}

		.bio-tagline {
			font-family: 'DM Sans', sans-serif;
			font-size: 0.95rem;
			text-align: center;
			color: var(--text-muted);
			line-height: 1.5;
			max-width: 340px;
		}

		.bio-links {
			width: 100%;
			display: flex;
			flex-direction: column;
			gap: 0.75rem;
		}

		.bio-link {
			display: block;
			width: 100%;
			padding: 1rem 1.25rem;
			text-align: center;
			text-decoration: none;
			font-family: 'Manrope', sans-serif;
			font-weight: 600;
			font-size: 0.95rem;
			color: var(--text);
			background: var(--card-bg);
			border: 1px solid var(--card-border);
			border-radius: 0.5rem;
			transition: all 0.3s ease;
		}

		.bio-link:hover {
			border-color: var(--accent);
			box-shadow: 0 0 20px var(--accent-glow);
			transform: translateY(-2px);
		}

		.bio-link.cta {
			background: var(--accent);
			color: #fff;
			border: none;
			box-shadow: 0 0 30px var(--accent-glow);
		}

		.bio-link.cta:hover {
			box-shadow: 0 0 40px var(--accent-glow);
			transform: translateY(-2px);
		}

		.bio-socials {
			display: flex;
			gap: 1.25rem;
			margin-top: 0.5rem;
		}

		.bio-socials a {
			color: var(--text-muted);
			transition: color 0.2s ease;
		}

		.bio-socials a:hover {
			color: var(--accent);
		}

		.bio-socials svg {
			width: 26px;
			height: 26px;
		}

		.bio-footer {
			font-size: 0.8rem;
			color: var(--text-muted);
			opacity: 0.5;
			margin-top: 1rem;
		}

		*,
		*::before,
		*::after {
			-webkit-user-select: none;
			-moz-user-select: none;
			-ms-user-select: none;
			user-select: none;
		}

	</style>
</head>
<body>
	<script>
		(() => {
			const blockEvent = (event: Event) => event.preventDefault();
			document.addEventListener("copy", blockEvent);
			document.addEventListener("cut", blockEvent);
			document.addEventListener("contextmenu", blockEvent);
			document.addEventListener("selectstart", blockEvent);
			document.addEventListener("dragstart", blockEvent);
			document.addEventListener("keydown", (event) => {
				if (!(event.ctrlKey || event.metaKey)) return;
				const key = event.key.toLowerCase();
				if (["a", "c", "u", "x"].includes(key)) event.preventDefault();
			});
		})();
	</script>
	<div class="bio-container">
		<div class="bio-avatar">
			<img src="/images/WinFlowz.png" alt="WinFlowz" width="96" height="96" />
		</div>

		<h1 class="bio-name">WinFlowz</h1>

		<p class="bio-tagline">
			{isEn
				? 'Chrome extensions, Obsidian plugins & Windows productivity guide.'
				: 'Extensions Chrome, plugins Obsidian et guide productivité Windows.'
			}
		</p>

		<div class="bio-links">
			<a href={`${siteUrl}${langPrefix}/landing`} class="bio-link">
				{isEn ? 'Homepage' : 'Accueil'}
			</a>
			<a href={`${siteUrl}${langPrefix}/produits`} class="bio-link">
				{isEn ? 'Products' : 'Produits'}
			</a>
			<a href={`${siteUrl}${langPrefix}/blog`} class="bio-link">Blog</a>
			<a href={`${siteUrl}${langPrefix}/pricing`} class="bio-link">
				{isEn ? 'Pricing' : 'Tarifs'}
			</a>
			<a href={`${siteUrl}${langPrefix}/landing`} class="bio-link cta">
				{isEn ? 'Get Started Free' : 'Commencer Gratuitement'}
			</a>
			<a href={`${siteUrl}${langPrefix}/contact`} class="bio-link">Contact</a>
		</div>

		<div class="bio-socials">
			<!-- GitHub -->
			<a href="https://github.com/winflowz" aria-label="GitHub" rel="noopener noreferrer" target="_blank">
				<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
			</a>
			<!-- Twitter/X -->
			<a href="https://x.com/winflowz" aria-label="Twitter / X" rel="noopener noreferrer" target="_blank">
				<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
			</a>
			<!-- LinkedIn -->
			<a href="https://linkedin.com/company/winflowz" aria-label="LinkedIn" rel="noopener noreferrer" target="_blank">
				<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
			</a>
		</div>

		<p class="bio-footer">&copy; 2026 WinFlowz</p>
	</div>
</body>
</html>

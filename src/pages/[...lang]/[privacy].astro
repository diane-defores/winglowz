---
export const prerender = true
import MainLayout from '@/layouts/MainLayout.astro'
import { getLangFromUrl, useTranslations } from '@/utils/i18n'

export function getStaticPaths() {
	return [
		{ params: { lang: undefined, privacy: 'privacy' } },
		{ params: { lang: 'fr', privacy: 'confidentialite' } },
	]
}

const lang = getLangFromUrl(Astro.url)
const t = await useTranslations(lang, 'privacy')
const sections = (t.sections ?? {}) as Record<
	string,
	{ title?: string; intro?: string; content?: string; items?: string[] }
>
---

<MainLayout
	title={t.title}
	lang={lang}
	structuredData={{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		'@id': `https://winflowz.com/${lang === 'fr' ? 'fr/confidentialite' : 'privacy'}`,
		url: `https://winflowz.com/${lang === 'fr' ? 'fr/confidentialite' : 'privacy'}`,
		name: `${t.title} | WinFlowz`,
		description: t.intro,
		inLanguage: lang,
	}}
>
	<div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
		<h1 class="mb-8 text-3xl font-bold text-neutral-900 dark:text-white">
			{t.title}
		</h1>

		<p class="mb-4 text-sm text-neutral-500 dark:text-neutral-400">
			{t.lastUpdated}
		</p>

		<div class="space-y-6 text-neutral-600 dark:text-neutral-400">
			<p>{t.intro}</p>

			<!-- Section Collecte d'Informations -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.collection?.title}
			</h2>
			<p>{sections.collection?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.collection?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			<!-- Section Utilisation des Données -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.usage?.title}
			</h2>
			<p>{sections.usage?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.usage?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			<!-- Section Protection des Données -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.protection?.title}
			</h2>
			<p>{sections.protection?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.protection?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			<!-- Section Services Tiers -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.thirdParty?.title}
			</h2>
			<p>{sections.thirdParty?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.thirdParty?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			<!-- Section Vos Droits -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.rights?.title}
			</h2>
			<p>{sections.rights?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.rights?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			<!-- Section Cookies -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.cookies?.title}
			</h2>
			<p>{sections.cookies?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.cookies?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			<!-- Section Mises à Jour -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.updates?.title}
			</h2>
			<p>{sections.updates?.content}</p>

			<!-- Section Contact -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.contact?.title}
			</h2>
			<p>{sections.contact?.content}</p>

			<!-- Section Analytics Opt-out -->
			<h2 class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200">
				{lang === 'fr' ? 'Préférences analytics' : 'Analytics Preferences'}
			</h2>
			<p class="mb-4">
				{lang === 'fr'
					? 'Vous pouvez désactiver le suivi analytique à tout moment. Ce choix est sauvegardé dans votre navigateur.'
					: 'You can disable analytics tracking at any time. This choice is saved in your browser.'}
			</p>
			<div id="analytics-opt-out-section" style="margin: 1.5rem 0; padding: 1.5rem; border: 1px solid #e5e7eb; border-radius: 8px;">
				<p id="analytics-status" style="margin: 0 0 1rem;">
					{lang === 'fr' ? 'Chargement...' : 'Loading...'}
				</p>
				<button id="analytics-toggle" style="padding: 0.5rem 1rem; border-radius: 6px; cursor: pointer; font-size: 0.9rem; border: 1px solid currentColor;">
					{lang === 'fr' ? 'Chargement...' : 'Loading...'}
				</button>
			</div>
		</div>
	</div>
</MainLayout>

<script is:inline>
  var _lang = document.documentElement.lang || 'en';
  var _isFr = _lang === 'fr';

  function updateUI() {
    var status = document.getElementById('analytics-status');
    var btn = document.getElementById('analytics-toggle');
    if (!status || !btn) return;

    var optedOut = typeof posthog !== 'undefined' && posthog.has_opted_out_capturing();

    if (optedOut) {
      status.textContent = _isFr ? '🟢 Le suivi analytique est actuellement désactivé.' : '🟢 Analytics tracking is currently disabled.';
      btn.textContent = _isFr ? 'Réactiver les analytics' : 'Re-enable analytics';
    } else {
      status.textContent = _isFr ? '🔵 Le suivi analytique est actuellement activé.' : '🔵 Analytics tracking is currently enabled.';
      btn.textContent = _isFr ? 'Désactiver les analytics' : 'Disable analytics';
    }
  }

  function toggleAnalytics() {
    if (typeof posthog === 'undefined') return;
    if (posthog.has_opted_out_capturing()) {
      posthog.opt_in_capturing();
    } else {
      posthog.opt_out_capturing();
    }
    updateUI();
  }

  var btn = document.getElementById('analytics-toggle');
  if (btn) btn.addEventListener('click', toggleAnalytics);
  document.addEventListener('DOMContentLoaded', updateUI);
  setTimeout(updateUI, 500);
</script>

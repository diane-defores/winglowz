---
export const prerender = true
import MainLayout from '@/layouts/MainLayout.astro'
import { getLangFromUrl, useTranslations } from '@/utils/i18n'
import { SITE, getLocalizedSiteUrl } from '@/constants'

export function getStaticPaths() {
	return [
		{ params: { lang: undefined, privacy: 'privacy' } },
		{ params: { lang: 'fr', privacy: 'confidentialite' } },
	]
}

const lang = getLangFromUrl(Astro.url)
const t = await useTranslations(lang, 'privacy')
const sections = (t.sections ?? {}) as Record<
	string,
	{ title?: string; intro?: string; content?: string; items?: string[] }
>
---

<MainLayout
	title={t.title}
	lang={lang}
	structuredData={{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		'@id': getLocalizedSiteUrl(lang, lang === 'fr' ? '/confidentialite' : '/privacy'),
		url: getLocalizedSiteUrl(lang, lang === 'fr' ? '/confidentialite' : '/privacy'),
		name: `${t.title} | ${SITE.name}`,
		description: t.intro,
		inLanguage: lang,
	}}
>
	<div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
		<h1 class="mb-8 text-3xl font-bold text-neutral-900 dark:text-white">
			{t.title}
		</h1>

		<p class="mb-4 text-sm text-neutral-500 dark:text-neutral-400">
			{t.lastUpdated}
		</p>

		<div class="space-y-6 text-neutral-600 dark:text-neutral-400">
			<p>{t.intro}</p>

			<!-- Section Collecte d'Informations -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.collection?.title}
			</h2>
			<p>{sections.collection?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.collection?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			<!-- Section Utilisation des Données -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.usage?.title}
			</h2>
			<p>{sections.usage?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.usage?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			<!-- Section Protection des Données -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.protection?.title}
			</h2>
			<p>{sections.protection?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.protection?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			<!-- Section Services Tiers -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.thirdParty?.title}
			</h2>
			<p>{sections.thirdParty?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.thirdParty?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			<!-- Section Vos Droits -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.rights?.title}
			</h2>
			<p>{sections.rights?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.rights?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			<!-- Section Cookies -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.cookies?.title}
			</h2>
			<p>{sections.cookies?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.cookies?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			<!-- Section Mises à Jour -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.updates?.title}
			</h2>
			<p>{sections.updates?.content}</p>

			<!-- Section Contact -->
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.contact?.title}
			</h2>
			<p>{sections.contact?.content}</p>

		</div>
	</div>
</MainLayout>


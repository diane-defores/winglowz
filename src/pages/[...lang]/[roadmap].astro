---
import MainLayout from '@/layouts/MainLayout.astro'
import KanbanBoard from '../../components/roadmap/KanbanBoard.astro'
import ProjectNav from '../../components/roadmap/ProjectNav.astro'
import AddFeatureModal from '../../components/roadmap/AddFeatureModal.astro'
import { projects } from '../../types/roadmap'
import { getLangFromUrl, useTranslations } from '@/utils/i18n'
import type { Language } from '@/types'

export const prerender = true

export function getStaticPaths() {
	return [
		{
			params: {
				lang: undefined,
				roadmap: 'roadmap',
			},
		},
		...projects.map((project) => ({
			params: {
				lang: undefined,
				roadmap: `roadmap/${project.id}`,
			},
		})),
		{
			params: {
				lang: 'fr',
				roadmap: 'roadmap',
			},
		},
		...projects.map((project) => ({
			params: {
				lang: 'fr',
				roadmap: `roadmap/${project.id}`,
			},
		})),
	]
}

const lang = getLangFromUrl(Astro.url)
const t = await useTranslations(lang, 'roadmap')

const segments = Astro.url.pathname.split('/')
const projectId =
	segments[segments.length - 1] === 'roadmap'
		? null
		: segments[segments.length - 1]
const project = projectId ? projects.find((p) => p.id === projectId) : null

const defaultTranslations = {
	planned: 'Planned',
	inProgress: 'In Development',
	completed: 'Completed',
	considering: 'Ideas',
	rejected: 'Rejected',
	vote: 'Vote',
	votes: 'votes',
}

const translations = {
	planned: t?.status?.planned ?? defaultTranslations.planned,
	inProgress: t?.status?.inProgress ?? defaultTranslations.inProgress,
	completed: t?.status?.completed ?? defaultTranslations.completed,
	considering: t?.status?.considering ?? defaultTranslations.considering,
	rejected: t?.status?.rejected ?? defaultTranslations.rejected,
	vote: t?.feature?.vote ?? defaultTranslations.vote,
	votes: t?.feature?.votes ?? defaultTranslations.votes,
}

// Hardcoded features until Convex is fully wired
const features: any[] = [
	// TubeFlowz
	{ id: '1', title: 'YouTube Timestamp Bookmarks', description: 'Save and organize bookmarks at specific video timestamps with notes', status: 'completed', projectId: 'tubeflowz', votes: 42 },
	{ id: '2', title: 'Annotation Export to Obsidian', description: 'Export all video annotations directly into your Obsidian vault as structured notes', status: 'in-development', projectId: 'tubeflowz', votes: 38 },
	{ id: '3', title: 'Playlist Analytics Dashboard', description: 'Visual overview of your watch patterns, saved content, and learning progress', status: 'planned', projectId: 'tubeflowz', votes: 25 },
	{ id: '4', title: 'AI-Powered Video Summaries', description: 'Automatic chapter summaries using AI to capture key takeaways', status: 'considering', projectId: 'tubeflowz', votes: 67 },
	// MediaFlowz
	{ id: '5', title: 'RSS Feed Aggregation', description: 'Unified RSS reader inside Obsidian with customizable feeds and filters', status: 'completed', projectId: 'mediaflowz', votes: 31 },
	{ id: '6', title: 'Social Media Scheduler', description: 'Schedule and publish content across multiple social platforms from Obsidian', status: 'planned', projectId: 'mediaflowz', votes: 44 },
	{ id: '7', title: 'Content Curation Templates', description: 'Pre-built templates for curating and organizing content from various sources', status: 'in-development', projectId: 'mediaflowz', votes: 19 },
	{ id: '8', title: 'Newsletter Generator', description: 'Turn curated content into formatted newsletters ready to send', status: 'considering', projectId: 'mediaflowz', votes: 52 },
	// WinFlowz
	{ id: '9', title: 'Windows Mastery Guide v2', description: 'Updated guide with 200+ tips covering Windows 11 24H2 features and optimizations', status: 'in-development', projectId: 'winflowz', votes: 35 },
	{ id: '10', title: 'Plugin Manager for Obsidian', description: 'Search, compare, and manage Obsidian plugins with ratings and compatibility checks', status: 'completed', projectId: 'winflowz', votes: 28 },
	{ id: '11', title: 'Keyboard Shortcut Trainer', description: 'Interactive training mode to learn and practice Windows keyboard shortcuts', status: 'planned', projectId: 'winflowz', votes: 41 },
	{ id: '12', title: 'Workflow Automation Builder', description: 'Visual builder for creating custom Windows automation workflows', status: 'considering', projectId: 'winflowz', votes: 73 },
]

const featuresWithProjectNames =
	features?.map((feature: any) => ({
		...feature,
		projectName:
			projects.find((p) => p.id === feature.projectId)?.name ??
			feature.projectId,
	})) ?? []

const pageTitle: string = project
	? `${project.name} - ${t?.title || 'Roadmap'}`
	: t?.title || 'Roadmap'
---

<MainLayout title={pageTitle} lang={lang}>
	<div class="min-h-screen bg-white dark:bg-neutral-900">
		<ProjectNav currentProjectId={projectId} />
		<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
			<KanbanBoard
				features={featuresWithProjectNames}
				showProjectName={!project}
				translations={translations}
			/>
		</div>
	</div>

	<AddFeatureModal />
</MainLayout>

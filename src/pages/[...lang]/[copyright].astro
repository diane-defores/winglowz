---
export const prerender = true
import MainLayout from '@/layouts/MainLayout.astro'
import { getLangFromUrl, useTranslations } from '@/utils/i18n'

export function getStaticPaths() {
	return [
		{ params: { lang: undefined, copyright: 'copyright' } },
		{ params: { lang: 'fr', copyright: 'droits' } },
	]
}

const lang = getLangFromUrl(Astro.url)
const t = await useTranslations(lang, 'copyright')
const sections = (t.sections ?? {}) as Record<
	string,
	{ title?: string; content?: string; items?: string[] }
>
const copyrightDescription = sections.protection?.content ?? ''
---

<MainLayout
	title={t.title}
	lang={lang}
	structuredData={{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		'@id': `https://winflowz.com/${lang === 'fr' ? 'fr/droits' : 'copyright'}`,
		url: `https://winflowz.com/${lang === 'fr' ? 'fr/droits' : 'copyright'}`,
		name: `${t.title} | WinFlowz`,
		description: copyrightDescription,
		inLanguage: lang,
	}}
>
	<div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
		<h1 class="mb-8 text-3xl font-bold text-neutral-900 dark:text-white">
			{t.title}
		</h1>

		<p class="mb-4 text-sm text-neutral-500 dark:text-neutral-400">
			{t.lastUpdated}
		</p>

		<div class="space-y-6 text-neutral-600 dark:text-neutral-400">
			{/* Section Protection des Droits d'Auteur */}
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.protection?.title}
			</h2>
			<p>{sections.protection?.content}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.protection?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			{/* Section Restrictions de Licence */}
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.license?.title}
			</h2>
			<p>{sections.license?.content}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.license?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			{/* Section Utilisation Commerciale */}
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.commercial?.title}
			</h2>
			<p>{sections.commercial?.content}</p>

			{/* Section Application */}
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.enforcement?.title}
			</h2>
			<p>{sections.enforcement?.content}</p>
			<ul class="list-disc space-y-2 pl-6">
				{
					(sections.enforcement?.items ?? []).map((item: string) => (
						<li>{item}</li>
					))
				}
			</ul>

			{/* Section Usage Équitable */}
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.fairUse?.title}
			</h2>
			<p>{sections.fairUse?.content}</p>

			<p class="mt-8">
				{t.footer.notice}
			</p>
		</div>

		<p class="mt-8 text-sm text-neutral-500 dark:text-neutral-400">
			{t.footer.contact}
		</p>
	</div>
</MainLayout>

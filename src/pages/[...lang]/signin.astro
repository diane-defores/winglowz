---
import MainLayout from '@/layouts/MainLayout.astro'
import type { Language } from '@/types'
import { getSafeAuthRedirectPath } from '@/utils/courseGating'
import { SignIn } from '@clerk/astro/components'

export const prerender = false

export async function getStaticPaths() {
	return [
		{ params: { lang: undefined }, props: { lang: 'en' as Language } },
		{ params: { lang: 'fr' }, props: { lang: 'fr' as Language } },
	]
}

const { lang } = Astro.props
const title = lang === 'fr' ? 'Connexion' : 'Sign In'
const nextUrl = Astro.url.searchParams.get('next')
const safeNextUrl = getSafeAuthRedirectPath(nextUrl)
---

<MainLayout title={title} lang={lang}>
	<div class="flex min-h-[60vh] items-center justify-center py-12">
		<SignIn
			routing="hash"
			fallbackRedirectUrl={safeNextUrl}
		/>
	</div>
</MainLayout>

---
import MainLayout from '@/layouts/MainLayout.astro'

const auth = Astro.locals.auth()
if (!auth.userId) {
	return Astro.redirect('/signin')
}
---

<MainLayout title="Tasks - Dashboard">
	<div class="min-h-[60vh] py-12">
		<div class="mx-auto max-w-4xl">
			<div class="mb-8 flex items-center gap-4">
				<a href="/dashboard" class="text-sm text-neutral-500 hover:text-neutral-700 dark:text-neutral-400 dark:hover:text-neutral-200">
					&larr; Dashboard
				</a>
				<h1 class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
					Tasks
				</h1>
			</div>

			<div class="rounded-xl border border-neutral-200 bg-white p-8 dark:border-neutral-800 dark:bg-neutral-800">
				<div class="mb-6 flex items-center justify-between">
					<h2 class="text-lg font-semibold text-neutral-900 dark:text-white">My Tasks</h2>
				</div>

				<ul class="space-y-3" id="task-list">
					<li class="flex items-center gap-3 rounded-lg border border-neutral-200 p-4 dark:border-neutral-700">
						<input type="checkbox" class="h-5 w-5 rounded border-neutral-300 text-magenta focus:ring-magenta" />
						<span class="text-neutral-700 dark:text-neutral-300">Explore WinFlowz extensions</span>
					</li>
					<li class="flex items-center gap-3 rounded-lg border border-neutral-200 p-4 dark:border-neutral-700">
						<input type="checkbox" class="h-5 w-5 rounded border-neutral-300 text-magenta focus:ring-magenta" />
						<span class="text-neutral-700 dark:text-neutral-300">Complete Windows Mastery guide</span>
					</li>
					<li class="flex items-center gap-3 rounded-lg border border-neutral-200 p-4 dark:border-neutral-700">
						<input type="checkbox" class="h-5 w-5 rounded border-neutral-300 text-magenta focus:ring-magenta" />
						<span class="text-neutral-700 dark:text-neutral-300">Try ObsiFlowz plugin</span>
					</li>
				</ul>

				<p class="mt-6 text-center text-sm text-neutral-500 dark:text-neutral-400">
					Full task management coming soon with Convex sync.
				</p>
			</div>
		</div>
	</div>
</MainLayout>

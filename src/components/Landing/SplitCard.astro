---
interface Props {
	title?: string;
	icon?: string;
	href?: string;
}
---

<div class="card--fullwidth">
	<article class="card">
		<div class="split">
			<slot />
		</div>
	</article>
</div>

<style>
	.card--fullwidth {
		--card-bg: rgba(23, 25, 30, 0.8);
		grid-column: 1 / -1;
	}
	:global(:root[data-theme='light']) .card--fullwidth {
		--card-bg: rgba(255, 255, 255, 0.8);
	}

	.split {
		margin-top: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0 1rem;
		color: rgb(250 250 250);
	}

	.card--fullwidth .card {
		background:
			radial-gradient(var(--brand-cyan), transparent 70%) no-repeat 50% -25% / 120% 300%,
			var(--card-bg);
		position: relative;
		border: 1px solid rgb(255 255 255 / 0.12);
		border-radius: 1rem;
		padding: 1.25rem;
		backdrop-filter: blur(12px);
	}

	@media screen and (min-width: 78rem) {
		.split {
			flex-direction: row;
			gap: 2.5rem;
		}
		.split > :global(*) {
			margin-top: 0 !important;
			flex: 1;
		}
	}
</style>

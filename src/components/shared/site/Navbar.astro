---
import { MobileMenu } from '@components/react/landing/MobileMenu'
import ThemePicker from '@/components/ui/ThemePicker.astro'
import { getLangFromUrl, useTranslations } from '@/utils/i18n'

interface NavItem {
	label: string
	href: string
}

interface Props {
	navItems?: NavItem[]
	forceDark?: boolean
	showThemePicker?: boolean
}

const {
	navItems: propNavItems,
	forceDark = false,
	showThemePicker = true,
} = Astro.props

const lang = getLangFromUrl(Astro.url)
const t = await useTranslations(lang, 'navigation')
const homeUrl = lang === 'fr' ? '/fr' : '/'

const navItems: NavItem[] =
	propNavItems ||
	t.navBarLinks?.map((link: { name: string; url: string }) => ({
		label: link.name,
		href: link.url,
	})) ||
	[]

const altLang = lang === 'fr' ? 'en' : 'fr'
const altLangLabel = lang === 'fr' ? 'EN' : 'FR'

const routeMappings: Record<string, string> = {
	about: 'a-propos',
	terms: 'cgu',
	disclaimer: 'non-responsabilite',
	privacy: 'confidentialite',
	copyright: 'droits',
	legal: 'mentions-legales',
	products: 'produits',
	'products/obsidian': 'produits/obsidian',
	'products/chrome': 'produits/chrome',
	'products/windows': 'produits/windows',
	'products/pricing': 'produits/tarifs',
	services: 'services',
	blog: 'blog',
	contact: 'contact',
	roadmap: 'roadmap',
}

function getTranslatedPath(path: string, targetLang: string): string {
	if (path === '/' || path === '/fr' || path === '/fr/') {
		return targetLang === 'fr' ? '/fr' : '/'
	}

	const cleanPath = path.replace(/^\/fr\//, '/')

	if (targetLang === 'fr') {
		for (const [en, fr] of Object.entries(routeMappings)) {
			if (cleanPath === `/${en}` || cleanPath.startsWith(`/${en}/`)) {
				return `/fr/${fr}${cleanPath.substring(en.length + 1)}`
			}
		}
		return `/fr${cleanPath}`
	}

	for (const [en, fr] of Object.entries(routeMappings)) {
		if (cleanPath === `/${fr}` || cleanPath.startsWith(`/${fr}/`)) {
			return `/${en}${cleanPath.substring(fr.length + 1)}`
		}
	}

	return cleanPath
}

const altLangUrl = getTranslatedPath(Astro.url.pathname, altLang)

const signInLabel = lang === 'fr' ? 'Connexion' : 'Sign In'
const ctaLabel = lang === 'fr' ? 'Commencer' : 'Get Started'
const signInUrl = lang === 'fr' ? '/fr/connexion' : '/signin'
const ctaUrl = lang === 'fr' ? '/fr/produits' : '/products'

const navShellClass = forceDark
	? 'relative flex items-center justify-between rounded-full border border-zinc-800 bg-zinc-950/88 px-4 py-3 shadow-none backdrop-blur-md'
	: 'relative flex items-center justify-between rounded-full border border-neutral-200/60 bg-white/80 px-4 py-3 shadow-sm backdrop-blur-md dark:border-zinc-800 dark:bg-zinc-900/80 dark:shadow-none'

const navLinkClass = forceDark
	? 'nav-link no-hover-animation relative rounded-full px-3 py-2 text-sm text-zinc-400 transition-colors hover:text-white'
	: 'nav-link no-hover-animation relative rounded-full px-3 py-2 text-sm font-medium text-neutral-800 transition-colors hover:text-neutral-950 dark:text-zinc-400 dark:hover:text-white'

const langLinkClass = forceDark
	? 'no-hover-animation rounded-full px-2.5 py-1.5 text-xs font-semibold text-zinc-500 transition-colors hover:bg-zinc-800 hover:text-white'
	: 'no-hover-animation rounded-full px-2.5 py-1.5 text-xs font-semibold text-neutral-700 transition-colors hover:bg-neutral-100 hover:text-neutral-950 dark:text-zinc-500 dark:hover:bg-zinc-800 dark:hover:text-white'

const signInButtonClass = forceDark
	? 'rounded-full px-3 py-1.5 text-sm text-zinc-400 transition-colors hover:bg-zinc-800 hover:text-white'
	: 'rounded-full px-3 py-1.5 text-sm font-medium text-neutral-800 transition-colors hover:bg-neutral-100 hover:text-neutral-950 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-white'

const ctaButtonClass = forceDark
	? 'shimmer-btn rounded-full bg-white px-4 py-1.5 text-sm font-medium text-zinc-950 hover:bg-zinc-200'
	: 'shimmer-btn rounded-full bg-neutral-900 px-4 py-1.5 text-sm font-medium text-white hover:bg-neutral-700 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200'
---

<header class="navbar-header fixed left-0 right-0 top-4 z-50 mx-auto w-[calc(100%-2rem)] max-w-4xl">
	<nav class={navShellClass}>
		<a href={homeUrl} class="flex items-center gap-2 no-hover-animation">
			<div class="text-logo" style="font-size: 1.25rem;">
				<span class="text">WinFlowz</span>
				<div class="glow-effect"></div>
			</div>
		</a>

		<div class="hidden items-center gap-1 md:flex">
			{
				navItems.map((item) => (
					<a
						href={item.href}
						class={navLinkClass}
					>
						{item.label}
					</a>
				))
			}
		</div>

		<div class="hidden items-center gap-1 md:flex">
			<a
				href={altLangUrl}
				class={langLinkClass}
			>
				{altLangLabel}
			</a>
			{showThemePicker && !forceDark && <ThemePicker />}
			<a href={signInUrl} class="no-hover-animation">
				<button class={signInButtonClass}>
					{signInLabel}
				</button>
			</a>
			<a href={ctaUrl} class="no-hover-animation">
				<button class={ctaButtonClass}>
					{ctaLabel}
				</button>
			</a>
		</div>

		<MobileMenu
			client:only="react"
			items={navItems}
			signInLabel={signInLabel}
			ctaLabel={ctaLabel}
			signInUrl={signInUrl}
			ctaUrl={ctaUrl}
			altLangUrl={altLangUrl}
			altLangLabel={altLangLabel}
			forceDark={forceDark}
			showThemeToggle={showThemePicker && !forceDark}
		/>
	</nav>
</header>

<style>
	.navbar-header {
		animation: navbar-slide-down 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
	}

	.nav-link:hover {
		background-color: rgb(229 229 229);
	}

	:global(.dark) .nav-link:hover {
		background-color: rgb(39 39 42);
	}

	.nav-link {
		transition: background-color 0.2s ease, color 0.2s ease;
	}
</style>

---
import type { Props } from "@astrojs/starlight/props";

const main = "/";
const locale = Astro.props.locale ? Astro.props.locale + "/" : "";
const docs = "/" + locale + "welcome-to-docs/";
---

<span class="site-title flex">
  <a class="main-logo text-logo-link" href={main} aria-label="WinFlowz">
    <span class="text-logo">
      <span class="text">WinFlowz</span>
      <span class="glow-effect"></span>
    </span>
  </a>
</span>

<!-- text-logo styles from global.css @layer components -->
<style>
  .site-title {
    gap: 1rem;
    margin-right: 1rem;
  }
  .site-title a {
    display: flex;
    text-decoration: none;
  }
  .flex {
    display: flex;
    align-items: center;
  }
  .site-title a:focus-visible {
    outline: 0;
  }
  .text-logo-link {
    text-decoration: none;
  }
  /* Size override for Starlight header */
  .text-logo {
    font-size: 1.5rem;
  }
</style>

---
interface Props {
  productName: string;
  apiKey: string;
  price: string;
}

const { productName, apiKey, price } = Astro.props;
---

<div class="rounded-lg border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
  <div class="sm:flex sm:items-start">
    <div class="mx-auto flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-green/10 dark:bg-green/10 sm:mx-0">
      <svg class="h-6 w-6 text-green" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>
    <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-left">
      <h3 class="text-lg font-medium leading-6 text-neutral-900 dark:text-neutral-100">
        Achat réussi !
      </h3>
      <div class="mt-2">
        <p class="text-sm text-neutral-500 dark:text-neutral-400">
          Merci pour votre achat de {productName} pour {price}.
        </p>
      </div>
    </div>
  </div>

  <div class="mt-6">
    <div class="rounded-md bg-yellow/10 p-4 dark:bg-yellow/10">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-yellow" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-neutral-800 dark:text-neutral-200">
            Votre clé API
          </h3>
          <div class="mt-2">
            <p class="text-sm text-neutral-700 dark:text-neutral-300">
              Copiez votre clé API maintenant. Pour des raisons de sécurité, elle ne sera plus jamais affichée.
            </p>
          </div>
          <div class="mt-4">
            <div class="flex items-center space-x-2">
              <input
                type="text"
                value={apiKey}
                readonly
                class="block w-full rounded-md border-neutral-300 bg-neutral-50 font-mono text-sm shadow-sm dark:border-neutral-700 dark:bg-neutral-800"
              />
              <button
                type="button"
                class="inline-flex items-center rounded-md bg-yellow/10 px-3 py-2 text-sm font-semibold text-neutral-800 shadow-sm ring-1 ring-inset ring-yellow/20 hover:bg-yellow/20 dark:bg-yellow/10 dark:text-neutral-200 dark:ring-yellow/30 dark:hover:bg-yellow/20"
                data-copy-key={apiKey}
              >
                <svg class="-ml-0.5 mr-1.5 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2" />
                </svg>
                Copier
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-6">
    <div class="rounded-md bg-neutral-50 p-4 dark:bg-neutral-800">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-cyan" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-cyan dark:text-cyan">
            Prochaines étapes
          </h3>
          <div class="mt-2 text-sm text-cyan dark:text-cyan">
            <ul class="list-disc space-y-1 pl-5">
              <li>Consultez la documentation pour intégrer votre clé API</li>
              <li>Gérez vos clés API dans votre tableau de bord</li>
              <li>Contactez le support si vous avez besoin d'aide</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-6 flex justify-end space-x-3">
    <a
      href="/fr/docs"
      class="rounded-md bg-neutral-50 px-3 py-2 text-sm font-semibold text-neutral-900 shadow-sm ring-1 ring-inset ring-neutral-300 hover:bg-neutral-100 dark:bg-neutral-800 dark:text-neutral-100 dark:ring-neutral-700 dark:hover:bg-neutral-700"
    >
      Documentation
    </a>
    <a
      href="/dashboard"
      class="rounded-md bg-neutral-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-neutral-800 dark:bg-neutral-700 dark:hover:bg-neutral-600"
    >
      Aller au dashboard
    </a>
  </div>
</div>

<script>
  // Copier la clé dans le presse-papier
  document.querySelectorAll('[data-copy-key]').forEach((button) => {
    button.addEventListener('click', async () => {
      const key = button.getAttribute('data-copy-key');
      if (key) {
        try {
          await navigator.clipboard.writeText(key);
          // Changer le texte du bouton temporairement
          const originalText = button.innerHTML;
          button.innerHTML = `
            <svg class="-ml-0.5 mr-1.5 h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            Copié !
          `;
          setTimeout(() => {
            button.innerHTML = originalText;
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      }
    });
  });
</script>

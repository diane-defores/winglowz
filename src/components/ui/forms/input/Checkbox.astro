---
interface Props {
	id: string
	name: string
	label?: string
	required?: boolean
}

const { id, name = id, label = 'Remember me', required = false } = Astro.props
---

<div class="flex items-center">
	<div class="flex">
		<input
			type="checkbox"
			id={id}
			name={name}
			required={required}
			class="relative h-5 w-5 shrink-0 appearance-none rounded-md border border-neutral-200 bg-white checked:border-magenta checked:bg-magenta checked:before:bg-magenta focus:outline-none focus:ring-1 focus:ring-magenta dark:border-neutral-700 dark:bg-neutral-900 dark:checked:border-magenta dark:checked:bg-magenta dark:focus:ring-offset-neutral-800"
		/>
		<div
			class="pointer-events-none absolute ml-1 mt-1 hidden h-3 w-3 rotate-45 border-2 border-l-0 border-t-0 border-white opacity-0 peer-checked:opacity-100"
		>
		</div>
	</div>
	<label for={id} class="ml-3 text-neutral-800 dark:text-neutral-200">
		{label}
	</label>
</div>

---
import EmailInput from './input/EmailInput.astro'
import PasswordInput from './input/PasswordInput.astro'
import Checkbox from './input/Checkbox.astro'
import AuthBtn from '@components/ui/buttons/AuthBtn.astro'
import { getLangFromUrl, useTranslations } from '@/utils/i18n'

const lang = getLangFromUrl(Astro.url)
const t = await useTranslations(lang, 'auth')

// Variables for customization of the LoginModal Component
const config = {
	id: 'hs-toggle-between-modals-login-modal', // Modal IDENTIFIER
	title: t?.login?.title ?? 'Sign in', // Main HEADING
	subTitle: t?.login?.subtitle ?? "Don't have an account yet?", // Sub-Heading TEXT
	registerBtn: t?.login?.registerLink ?? 'Sign up here', // Text for REGISTRATION BUTTON
	registerBtnDataHS: '#hs-toggle-between-modals-register-modal', // TARGET LINK for registration button
}
---

<div
	id={config.id}
	class="hs-overlay absolute start-0 top-0 z-50 hidden h-full w-full hs-overlay-backdrop-open:bg-neutral-900/90"
>
	<div
		class="m-3 mt-0 opacity-0 transition-all ease-out hs-overlay-open:mt-7 hs-overlay-open:opacity-100 hs-overlay-open:duration-500 sm:mx-auto sm:w-full sm:max-w-lg"
	>
		<div class="mx-auto w-full max-w-md p-6">
			<div
				class="mt-7 rounded-xl border border-neutral-200 bg-neutral-100 shadow-sm dark:border-neutral-700 dark:bg-neutral-800"
			>
				<div class="p-4 sm:p-7">
					<div class="text-center">
						<h2
							class="block text-2xl font-bold text-neutral-800 dark:text-neutral-200"
						>
							{config.title}
						</h2>
						<p
							class="mt-2 text-neutral-600 dark:text-neutral-400"
						>
							{config.subTitle}
							<button
								class="rounded-lg p-1 font-medium text-magenta decoration-2 outline-none ring-zinc-500 hover:underline focus-visible:ring dark:text-magenta dark:ring-zinc-200 dark:focus:outline-none"
								data-hs-overlay={config.registerBtnDataHS}
							>
								{config.registerBtn}
							</button>
						</p>
					</div>
					<div class="mt-5">
						<div
							class="flex items-center py-3 uppercase text-neutral-400 before:me-6 before:flex-[1_1_0%] before:border-t before:border-neutral-200 after:ms-6 after:flex-[1_1_0%] after:border-t after:border-neutral-200 dark:text-neutral-500 dark:before:border-neutral-600 dark:after:border-neutral-600"
						>
							{t?.login?.or ?? 'Or'}
						</div>
						<!-- The container for the form -->
						<form id="login-form" action="/api/auth/signin" method="POST">
							<!-- A grid layout for the form fields -->
							<div class="grid gap-y-4">
								<!-- The email input field -->
								<EmailInput
									id="login-email"
									name="email"
									errorId="login-email-error"
									label={t?.fields?.email?.label}
									placeholder={t?.fields?.email?.placeholder}
									required
								/>
								<!-- The password input field -->
								<PasswordInput
									forgot={true}
									id="password"
									name="password"
									errorId="login-password-error"
									content={t?.fields?.password?.hint}
									label={t?.fields?.password?.label}
									placeholder={t?.fields?.password?.placeholder}
									forgotText={t?.login?.forgotPassword}
									required
								/>
								<!-- The remember-me checkbox -->
								<Checkbox
									id="remember-me"
									name="remember-me"
									label={t?.login?.rememberMe ?? 'Remember me'}
								/>
								<!-- The sign-in button -->
								<AuthBtn title={t?.login?.submit ?? 'Sign in'} />
							</div>
						</form>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<script>
	import { setupLoginForm } from './LoginForm'

	// Initialiser le formulaire une fois que le DOM est chargé
	document.addEventListener('astro:page-load', setupLoginForm)
</script>

---
/* Lead Magnet — free resource in exchange for email capture */
import { getLangFromUrl } from '@/utils/i18n'

const lang = getLangFromUrl(Astro.url)

const content = lang === 'fr'
  ? {
      badge: "Ressource Gratuite",
      title: "Top 10 des Hacks Productivite Windows",
      sub: "Un guide PDF avec les 10 astuces Windows les plus impactantes, testees et approuvees par des centaines d'utilisateurs. Envoi immediat par email.",
      placeholder: "Votre email",
      cta: "Recevoir le guide",
      privacy: "Pas de spam. Desabonnement en un clic.",
      success: "Merci ! Verifiez votre boite mail.",
      error: "Erreur. Veuillez reessayer.",
    }
  : {
      badge: "Free Resource",
      title: "Top 10 Windows Productivity Hacks",
      sub: "A PDF guide with the 10 most impactful Windows tips, tested and approved by hundreds of users. Delivered instantly to your inbox.",
      placeholder: "Your email",
      cta: "Get the Free Guide",
      privacy: "No spam. Unsubscribe in one click.",
      success: "Thanks! Check your inbox.",
      error: "Something went wrong. Please try again.",
    }
---

<section class="py-24 px-4">
  <div class="reveal max-w-3xl mx-auto">
    <div class="relative rounded-2xl border border-zinc-800 bg-zinc-900/80 p-8 sm:p-12 overflow-hidden">
      <!-- Background glow -->
      <div class="absolute -top-24 -right-24 w-64 h-64 rounded-full blur-3xl pointer-events-none" style="background: radial-gradient(circle, rgba(255,0,200,0.15), transparent 70%);"></div>

      <div class="relative z-10 text-center">
        <!-- Badge -->
        <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-800 border border-zinc-700 text-xs text-zinc-400 mb-6">
          <svg class="w-3 h-3" style="color: var(--brand-green);" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19.5 21a3 3 0 0 0 3-3v-4.5a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3V18a3 3 0 0 0 3 3h15zM1.5 10.146V6a3 3 0 0 1 3-3h5.379a2.25 2.25 0 0 1 1.59.659l2.122 2.121c.14.141.331.22.53.22H19.5a3 3 0 0 1 3 3v1.146A4.483 4.483 0 0 0 19.5 9h-15a4.483 4.483 0 0 0-3 1.146z"/></svg>
          {content.badge}
        </span>

        <h2
          class="text-3xl sm:text-4xl font-bold text-white mb-4"
          style="font-family: var(--font-instrument-sans);"
        >
          {content.title}
        </h2>

        <p class="text-zinc-400 max-w-xl mx-auto mb-8">
          {content.sub}
        </p>

        <!-- Email form -->
        <form id="lead-magnet-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input
            type="email"
            name="email"
            required
            placeholder={content.placeholder}
            class="flex-1 rounded-full px-5 py-3 bg-zinc-800 border border-zinc-700 text-white placeholder:text-zinc-500 focus:outline-none focus:border-zinc-500 text-sm"
          />
          <button
            type="submit"
            class="shimmer-btn bg-white text-zinc-950 hover:bg-zinc-200 rounded-full px-6 py-3 text-sm font-medium shadow-lg shadow-white/10 inline-flex items-center justify-center gap-2 whitespace-nowrap"
            data-track="lead-magnet-cta"
          >
            {content.cta}
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>
        </form>

        <p id="lead-magnet-success" class="hidden mt-4 text-sm" style="color: var(--brand-green);">{content.success}</p>
        <p id="lead-magnet-error" class="hidden mt-4 text-sm" style="color: var(--brand-red);">{content.error}</p>

        <p class="mt-4 text-xs text-zinc-600">{content.privacy}</p>
      </div>
    </div>
  </div>
</section>

<script>
  const leadForm = document.getElementById('lead-magnet-form') as HTMLFormElement | null;
  leadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const emailInput = leadForm.querySelector('input[type="email"]') as HTMLInputElement;
    const email = emailInput?.value;
    const successEl = document.getElementById('lead-magnet-success');
    const errorEl = document.getElementById('lead-magnet-error');
    const submitBtn = leadForm.querySelector('button[type="submit"]') as HTMLButtonElement;

    if (!email) return;

    submitBtn.disabled = true;
    emailInput.disabled = true;

    try {
      const res = await fetch('/api/newsletter/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: 'lead-magnet' }),
      });

      if (res.ok) {
        successEl?.classList.remove('hidden');
        errorEl?.classList.add('hidden');
        emailInput.value = '';
        setTimeout(() => successEl?.classList.add('hidden'), 5000);
      } else {
        errorEl?.classList.remove('hidden');
        successEl?.classList.add('hidden');
        setTimeout(() => errorEl?.classList.add('hidden'), 5000);
      }
    } catch {
      errorEl?.classList.remove('hidden');
      successEl?.classList.add('hidden');
      setTimeout(() => errorEl?.classList.add('hidden'), 5000);
    } finally {
      submitBtn.disabled = false;
      emailInput.disabled = false;
    }
  });
</script>

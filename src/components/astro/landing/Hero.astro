---
/* Hero section — pure Astro, CSS animations replace framer-motion */
import { getLangFromUrl } from '@/utils/i18n'

const lang = getLangFromUrl(Astro.url)
const windowsMasteryUrl = lang === 'fr' ? '/fr/maitrise-windows' : '/windows-mastery'

const avatars = [
  "/professional-headshot-1.png",
  "/professional-headshot-2.png",
  "/professional-headshot-3.png",
  "/professional-headshot-4.png",
  "/professional-headshot-5.png",
]

const stats = lang === 'fr'
  ? [
      { value: "8", label: "modules" },
      { value: "40", label: "lecons" },
      { value: "200+", label: "astuces testees" },
      { value: "2", label: "langues" },
    ]
  : [
      { value: "8", label: "modules" },
      { value: "40", label: "lessons" },
      { value: "200+", label: "tested tips & tools" },
      { value: "2", label: "languages" },
    ]

const heroText = lang === 'fr'
  ? {
      badge: "Formation Windows & outils de workflow",
      h1Line1: "Moins de friction.",
      h1Line2: "Plus de travail utile.",
      sub: "WinFlowz vous aide a reprendre le controle d'un environnement Windows trop bruyant, trop fragmente et trop fatigant. Commencez par la page dediee a la formation Windows.",
      cta: "Voir la formation Windows",
      testimonials: "Temoignages",
      reviews: "sur des dizaines d'avis 5 etoiles AppSumo",
    }
  : {
      badge: "Windows training & workflow tools",
      h1Line1: "Less friction.",
      h1Line2: "More real work.",
      sub: "WinFlowz helps you regain control over a Windows environment that is too noisy, too fragmented, and too tiring. Start with the dedicated Windows course page.",
      cta: "See the Windows course",
      testimonials: "Testimonials",
      reviews: "from dozens of 5-star AppSumo reviews",
    }
---

<section class="relative flex flex-col items-center justify-center overflow-hidden px-4 pb-16 pt-32">
  <!-- Background gradient -->
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-neutral-50 via-white to-neutral-100 dark:from-black dark:via-black dark:to-zinc-950"></div>

  <!-- Subtle radial glow -->
  <div class="pointer-events-none absolute left-1/2 top-1/4 h-[600px] w-[800px] -translate-x-1/2 rounded-full bg-fuchsia-400/10 blur-3xl dark:bg-zinc-800/20"></div>

  <div class="relative z-10 max-w-5xl mx-auto text-center">
    <!-- Badge -->
    <div class="hero-fade landing-surface mb-8 hidden items-center gap-2 rounded-full border px-4 py-2 md:inline-flex" style="animation-delay: 0.2s;">
      <span class="w-2 h-2 rounded-full pulse-glow" style="background-color: var(--brand-green);"></span>
      <span class="text-sm text-neutral-600 dark:text-zinc-400">{heroText.badge}</span>
    </div>

    <!-- Headline with text mask animation -->
    <h1
      class="mb-6 text-6xl font-bold tracking-tight text-neutral-950 dark:text-white sm:text-7xl lg:text-8xl"
      style="font-family: var(--font-cal-sans), sans-serif;"
    >
      <span class="block overflow-hidden">
        <span class="hero-text-line block" style="animation-delay: 0s;">
          {heroText.h1Line1}
        </span>
      </span>
      <span class="block overflow-hidden">
        <span class="hero-text-line block text-neutral-400 dark:text-zinc-500" style="animation-delay: 0.1s;">
          {heroText.h1Line2}
        </span>
      </span>
    </h1>

    <!-- Subheadline -->
    <p class="hero-fade mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-neutral-600 dark:text-zinc-400 sm:text-xl" style="animation-delay: 0.5s;">
      {heroText.sub}
    </p>

    <!-- CTAs -->
    <div class="hero-fade flex flex-col sm:flex-row items-center justify-center gap-4 mb-16" style="animation-delay: 0.6s;">
      <a href={windowsMasteryUrl} data-track="hero-primary-cta">
        <button class="shimmer-btn inline-flex h-12 items-center justify-center gap-2 rounded-full bg-neutral-950 px-8 text-base font-medium text-white shadow-lg shadow-neutral-950/10 hover:bg-neutral-800 dark:bg-white dark:text-zinc-950 dark:shadow-white/10 dark:hover:bg-zinc-200">
          {heroText.cta}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
      </a>
      <a href="#testimonials" data-track="hero-testimonials-cta">
        <button class="inline-flex h-12 items-center justify-center rounded-full border border-neutral-300 bg-transparent px-8 text-base font-medium text-neutral-700 hover:border-neutral-400 hover:bg-neutral-100 hover:text-neutral-950 dark:border-zinc-800 dark:text-zinc-300 dark:hover:border-zinc-700 dark:hover:bg-zinc-900 dark:hover:text-white">
          {heroText.testimonials}
        </button>
      </a>
    </div>

    <!-- Social Proof Avatars -->
    <div class="hero-fade flex flex-col items-center gap-4 mb-12" style="animation-delay: 0.7s;">
      <div class="flex items-center -space-x-3">
        {avatars.map((avatar, index) => (
          <div class="hero-avatar relative" style={`animation-delay: ${0.8 + index * 0.1}s;`}>
            <img
              src={avatar}
              alt=""
              class="h-10 w-10 rounded-full border-2 border-white object-cover dark:border-black"
              loading="eager"
            />
          </div>
        ))}
      </div>
      <p class="text-sm text-neutral-500 dark:text-zinc-500">
        <span class="font-medium text-neutral-800 dark:text-zinc-300">5 / 5</span> {heroText.reviews}
      </p>
    </div>

    <!-- Stats -->
    <div class="hero-fade grid grid-cols-2 sm:grid-cols-4 gap-8 max-w-2xl mx-auto" style="animation-delay: 0.9s;">
      {stats.map((stat, index) => (
        <div class="hero-stat text-center" style={`animation-delay: ${1.0 + index * 0.1}s;`}>
          <div class="text-2xl font-bold text-neutral-950 dark:text-white sm:text-3xl">{stat.value}</div>
          <div class="mt-1 text-xs text-neutral-500 dark:text-zinc-500 sm:text-sm">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero-text-line {
    opacity: 0;
    transform: translateY(100%);
    animation: hero-text-reveal 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-fade {
    opacity: 0;
    transform: translateY(20px);
    animation: hero-fade-up 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-avatar {
    opacity: 0;
    transform: scale(0.5) translateX(-20px);
    animation: avatar-pop 0.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-stat {
    opacity: 0;
    transform: scale(0.8);
    animation: hero-fade-up 0.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
</style>

---
/* Hero section — pure Astro, CSS animations replace framer-motion */
import { getLangFromUrl } from '@/utils/i18n'

const lang = getLangFromUrl(Astro.url)
const productsUrl = lang === 'fr' ? '/fr/produits' : '/products'

const avatars = [
  "/professional-headshot-1.png",
  "/professional-headshot-2.png",
  "/professional-headshot-3.png",
  "/professional-headshot-4.png",
  "/professional-headshot-5.png",
]

const stats = lang === 'fr'
  ? [
      { value: "70k+", label: "lecons completees" },
      { value: "35%", label: "gain d'efficacite" },
      { value: "200+", label: "astuces testees" },
      { value: "2x", label: "plus rapide" },
    ]
  : [
      { value: "70k+", label: "lessons completed" },
      { value: "35%", label: "efficiency increase" },
      { value: "200+", label: "tested tips & tools" },
      { value: "2x", label: "faster workflows" },
    ]

const heroText = lang === 'fr'
  ? {
      badge: "Plugins Productivite & Formation Windows",
      h1Line1: "Redefinir la Productivite",
      h1Line2: "Numerique.",
      sub: "Extensions Chrome pour YouTube, plugins Obsidian pour la gestion de contenu et un guide complet de productivite Windows avec 200+ astuces testees. Travaillez plus intelligemment.",
      cta: "Decouvrir nos outils",
      testimonials: "Temoignages",
      reviews: "sur 6 avis",
    }
  : {
      badge: "Productivity Plugins & Windows Training",
      h1Line1: "Redefining Digital",
      h1Line2: "Productivity.",
      sub: "Chrome extensions for YouTube, Obsidian plugins for content management, and a complete Windows productivity guide with 200+ tested tips. Work smarter, not harder.",
      cta: "Explore Our Tools",
      testimonials: "Testimonials",
      reviews: "from 6 reviews",
    }
---

<section class="relative flex flex-col items-center justify-center px-4 pt-32 pb-16 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-black via-black to-zinc-950 pointer-events-none"></div>

  <!-- Subtle radial glow -->
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-zinc-800/20 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative z-10 max-w-5xl mx-auto text-center">
    <!-- Badge -->
    <div class="hero-fade inline-flex items-center gap-2 px-4 py-2 rounded-full bg-zinc-900 border border-zinc-800 mb-8" style="animation-delay: 0.2s;">
      <span class="w-2 h-2 rounded-full pulse-glow" style="background-color: var(--brand-green);"></span>
      <span class="text-sm text-zinc-400">{heroText.badge}</span>
    </div>

    <!-- Headline with text mask animation -->
    <h1
      class="text-6xl sm:text-7xl lg:text-8xl font-bold tracking-tight text-white mb-6"
      style="font-family: var(--font-cal-sans), sans-serif;"
    >
      <span class="block overflow-hidden">
        <span class="hero-text-line block" style="animation-delay: 0s;">
          {heroText.h1Line1}
        </span>
      </span>
      <span class="block overflow-hidden">
        <span class="hero-text-line block text-zinc-500" style="animation-delay: 0.1s;">
          {heroText.h1Line2}
        </span>
      </span>
    </h1>

    <!-- Subheadline -->
    <p class="hero-fade text-lg sm:text-xl text-zinc-400 max-w-2xl mx-auto mb-10 leading-relaxed" style="animation-delay: 0.5s;">
      {heroText.sub}
    </p>

    <!-- CTAs -->
    <div class="hero-fade flex flex-col sm:flex-row items-center justify-center gap-4 mb-16" style="animation-delay: 0.6s;">
      <a href={productsUrl} data-track="hero-primary-cta">
        <button class="shimmer-btn bg-white text-zinc-950 hover:bg-zinc-200 rounded-full px-8 h-12 text-base font-medium shadow-lg shadow-white/10 inline-flex items-center justify-center gap-2">
          {heroText.cta}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
      </a>
      <a href="#testimonials" data-track="hero-testimonials-cta">
        <button class="rounded-full px-8 h-12 text-base font-medium border border-zinc-800 text-zinc-300 hover:bg-zinc-900 hover:text-white hover:border-zinc-700 bg-transparent inline-flex items-center justify-center">
          {heroText.testimonials}
        </button>
      </a>
    </div>

    <!-- Social Proof Avatars -->
    <div class="hero-fade flex flex-col items-center gap-4 mb-12" style="animation-delay: 0.7s;">
      <div class="flex items-center -space-x-3">
        {avatars.map((avatar, index) => (
          <div class="hero-avatar relative" style={`animation-delay: ${0.8 + index * 0.1}s;`}>
            <img
              src={avatar}
              alt=""
              class="w-10 h-10 rounded-full border-2 border-black object-cover"
              loading="eager"
            />
          </div>
        ))}
      </div>
      <p class="text-sm text-zinc-500">
        <span class="text-zinc-300 font-medium">5 / 5</span> {heroText.reviews}
      </p>
    </div>

    <!-- Stats -->
    <div class="hero-fade grid grid-cols-2 sm:grid-cols-4 gap-8 max-w-2xl mx-auto" style="animation-delay: 0.9s;">
      {stats.map((stat, index) => (
        <div class="hero-stat text-center" style={`animation-delay: ${1.0 + index * 0.1}s;`}>
          <div class="text-2xl sm:text-3xl font-bold text-white">{stat.value}</div>
          <div class="text-xs sm:text-sm text-zinc-500 mt-1">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero-text-line {
    opacity: 0;
    transform: translateY(100%);
    animation: hero-text-reveal 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-fade {
    opacity: 0;
    transform: translateY(20px);
    animation: hero-fade-up 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-avatar {
    opacity: 0;
    transform: scale(0.5) translateX(-20px);
    animation: avatar-pop 0.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-stat {
    opacity: 0;
    transform: scale(0.8);
    animation: hero-fade-up 0.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
</style>

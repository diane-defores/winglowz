---
/* BentoGrid — Astro wrapper with small React islands for animated widgets */
import { PluginActivityTicker } from '@components/react/landing/PluginActivityTicker'
import { KeyboardShortcutAnim } from '@components/react/landing/KeyboardShortcutAnim'
import { SmartOrgAnim } from '@components/react/landing/SmartOrgAnim'
import { getLangFromUrl } from '@/utils/i18n'

const lang = getLangFromUrl(Astro.url)

const bentoText = lang === 'fr'
  ? {
      sectionTitle: "Tout ce dont vous avez besoin pour etre productif",
      sectionSub: "En tant que personne atteinte de TDAH et d'autisme, j'ai cree des outils qui rendent deraisonnable et impossible de ne pas atteindre nos objectifs.",
      obsiTitle: "ObsiFlowz -- Plugins Obsidian",
      obsiDesc: "Transformez votre curation de contenu avec RSSFlowz et optimisez votre gestion de plugins avec PluginFlowz. Des plugins puissants pour la productivite et la gestion de contenu.",
      tubeTitle: "TubeFlowz",
      tubeDesc: "Revolutionnez vos recherches YouTube avec une puissante extension Chrome d'annotation et de mise en favoris.",
      winTitle: "Maitrise Windows",
      winDesc: "Debloquez tout le potentiel de Windows avec plus de 200 conseils et outils de productivite testes et approuves.",
      blazingTitle: "Resultats Fulgurants",
      blazingDesc: "35% d'augmentation d'efficacite rapportee par les utilisateurs. Des outils qui vous font vraiment gagner du temps.",
      smartTitle: "Organisation Intelligente",
      smartDesc: "Categorisez, decouvrez et sauvegardez -- un flux de travail structure pour dompter le chaos numerique.",
      avgEfficiency: "efficacite moyenne",
    }
  : {
      sectionTitle: "Everything you need to be productive",
      sectionSub: "As someone with ADHD and autism, I created tools that make it unreasonable and impossible not to achieve our goals.",
      obsiTitle: "ObsiFlowz -- Obsidian Plugins",
      obsiDesc: "Transform your content curation with RSSFlowz and optimize your plugin management with PluginFlowz. Powerful plugins designed for productivity and content management.",
      tubeTitle: "TubeFlowz",
      tubeDesc: "Revolutionize your YouTube searches with a powerful Chrome extension for annotation and bookmarking.",
      winTitle: "Windows Mastery",
      winDesc: "Unlock the full potential of Windows with over 200 tested and approved productivity tips and tools.",
      blazingTitle: "Blazing Fast Results",
      blazingDesc: "35% efficiency increase reported by users. Tools that actually save you time, not just look good.",
      smartTitle: "Smart Organization",
      smartDesc: "Categorize, discover and save -- a structured workflow to tame digital chaos and find anything instantly.",
      avgEfficiency: "avg efficiency",
    }
---

<section id="features" class="py-24 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="reveal text-center mb-16">
      <h2
        class="text-3xl sm:text-4xl font-bold text-white mb-4"
        style="font-family: var(--font-instrument-sans);"
      >
        {bentoText.sectionTitle}
      </h2>
      <p class="text-zinc-400 max-w-2xl mx-auto">
        {bentoText.sectionSub}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <!-- Large card - ObsiFlowz -->
      <div class="reveal md:col-span-2 group relative p-6 rounded-2xl bg-zinc-900 border border-zinc-800 hover:border-zinc-600 hover:scale-[1.02] transition-all duration-300 overflow-hidden">
        <div class="flex items-start justify-between mb-8">
          <div>
            <div class="p-2 rounded-lg bg-zinc-800 w-fit mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-400"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-white mb-2">{bentoText.obsiTitle}</h3>
            <p class="text-zinc-400 text-sm">
              {bentoText.obsiDesc}
            </p>
          </div>
          <PluginActivityTicker client:only="react" />
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {["RSSFlowz", "PluginFlowz", "ContentFlowz", "NoteFlowz"].map((plugin) => (
            <div class="text-center">
              <div class="text-sm font-medium text-white mb-1">{plugin}</div>
              <div class="text-xs text-zinc-500">Active</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Chrome Extension -->
      <div class="reveal delay-1 group relative p-6 rounded-2xl bg-zinc-900 border border-zinc-800 hover:border-zinc-600 hover:scale-[1.02] transition-all duration-300">
        <div class="p-2 rounded-lg bg-zinc-800 w-fit mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-400"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="21.17" x2="12" y1="8" y2="8"/><line x1="3.95" x2="8.54" y1="6.06" y2="14"/><line x1="10.88" x2="15.46" y1="21.94" y2="14"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">{bentoText.tubeTitle}</h3>
        <p class="text-zinc-400 text-sm mb-6">
          {bentoText.tubeDesc}
        </p>
        <KeyboardShortcutAnim client:only="react" />
      </div>

      <!-- Windows Tools -->
      <div class="reveal delay-2 group relative p-6 rounded-2xl bg-zinc-900 border border-zinc-800 hover:border-zinc-600 hover:scale-[1.02] transition-all duration-300">
        <div class="p-2 rounded-lg bg-zinc-800 w-fit mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-400"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">{bentoText.winTitle}</h3>
        <p class="text-zinc-400 text-sm mb-4">
          {bentoText.winDesc}
        </p>
        <!-- Animated chart (CSS only) -->
        <svg viewBox="0 0 100 70" class="w-full h-24 bento-chart">
          <defs>
            <linearGradient id="chartGradient" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="rgb(255,255,255)" stop-opacity="0.2" />
              <stop offset="100%" stop-color="rgb(255,255,255)" stop-opacity="0" />
            </linearGradient>
          </defs>
          <path d="M 0 60 L 20 45 L 40 55 L 60 30 L 80 40 L 100 15 L 100 70 L 0 70 Z" fill="url(#chartGradient)" class="opacity-50" />
          <path d="M 0 60 L 20 45 L 40 55 L 60 30 L 80 40 L 100 15" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" class="draw-line" />
        </svg>
      </div>

      <!-- Productivity Boost -->
      <div class="reveal delay-3 group relative p-6 rounded-2xl bg-zinc-900 border border-zinc-800 hover:border-zinc-600 hover:scale-[1.02] transition-all duration-300">
        <div class="p-2 rounded-lg bg-zinc-800 w-fit mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-400"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">{bentoText.blazingTitle}</h3>
        <p class="text-zinc-400 text-sm mb-4">
          {bentoText.blazingDesc}
        </p>
        <div class="flex items-center gap-2 text-sm" style="color: var(--brand-green);">
          <span class="font-mono">+35%</span>
          <span class="text-zinc-500">{bentoText.avgEfficiency}</span>
        </div>
      </div>

      <!-- Smart Organization -->
      <div class="reveal delay-4 group relative p-6 rounded-2xl bg-zinc-900 border border-zinc-800 hover:border-zinc-600 hover:scale-[1.02] transition-all duration-300 overflow-hidden">
        <div class="p-2 rounded-lg bg-zinc-800 w-fit mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-400"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M22 10v6"/><path d="M6 12.5V16c0 1 2.5 3 6 3s6-2 6-3v-3.5"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">{bentoText.smartTitle}</h3>
        <p class="text-zinc-400 text-sm mb-6">
          {bentoText.smartDesc}
        </p>
        <SmartOrgAnim client:only="react" />
      </div>
    </div>
  </div>
</section>

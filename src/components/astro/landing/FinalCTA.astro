---
/* Final CTA section — pure Astro with .reveal scroll animation */
import { getLangFromUrl } from '@/utils/i18n'

const lang = getLangFromUrl(Astro.url)
const productsUrl = lang === 'fr' ? '/fr/produits' : '/products'
const contactUrl = lang === 'fr' ? '/fr/contact' : '/contact'

const ctaText = lang === 'fr'
  ? {
      title: "Construisons Ensemble",
      sub: "WinFlowz est un ecosysteme de productivite, meticuleusement concu par Diane Defores. Rejoignez des milliers d'utilisateurs Windows qui ont transforme leur flux de travail.",
      cta: "Decouvrir nos outils",
      consult: "Planifier une consultation",
      note: "Gratuit pour les particuliers. Plans Pro a partir de 9,99$/mois.",
    }
  : {
      title: "Let's Build Together",
      sub: "WinFlowz is a productivity ecosystem, meticulously designed by Diane Defores. Join thousands of Windows users who have transformed their workflow.",
      cta: "Explore Our Tools",
      consult: "Schedule a Consultation",
      note: "Free forever for individuals. Pro plans start at $9.99/month.",
    }
---

<section class="py-24 px-4">
  <div class="reveal max-w-4xl mx-auto text-center">
    <h2
      class="mb-6 text-4xl font-bold tracking-tight text-neutral-950 dark:text-white sm:text-5xl lg:text-6xl"
      style="font-family: var(--font-cal-sans);"
    >
      {ctaText.title}
    </h2>
    <p class="mx-auto mb-10 max-w-2xl text-lg text-neutral-600 dark:text-zinc-400 sm:text-xl">
      {ctaText.sub}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={productsUrl} data-track="final-cta-products">
        <button class="shimmer-btn inline-flex h-14 items-center justify-center gap-2 rounded-full bg-neutral-950 px-8 text-base font-medium text-white shadow-lg shadow-neutral-950/20 hover:bg-neutral-800 dark:bg-white dark:text-zinc-950 dark:shadow-white/20 dark:hover:bg-zinc-200">
          {ctaText.cta}
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
      </a>
      <a href={contactUrl} data-track="final-cta-consult">
        <button class="inline-flex h-14 items-center justify-center rounded-full border border-neutral-300 bg-transparent px-8 text-base font-medium text-neutral-700 hover:border-neutral-400 hover:bg-neutral-100 hover:text-neutral-950 dark:border-zinc-800 dark:text-zinc-300 dark:hover:border-zinc-700 dark:hover:bg-zinc-900 dark:hover:text-white">
          {ctaText.consult}
        </button>
      </a>
    </div>

    <p class="mt-8 text-sm text-neutral-500 dark:text-zinc-500">{ctaText.note}</p>
  </div>
</section>

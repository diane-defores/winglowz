---
const { t } = Astro.props;

interface SupportItem {
  title: string;
  description: string;
  link: string;
}

const supportItems = (t.support?.items ?? []) as SupportItem[];
---

<section class="py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-bold tracking-tight text-neutral-900 dark:text-white sm:text-6xl">
        {t.hero.title}
      </h1>
      <p class="mt-6 text-lg leading-8 text-neutral-600 dark:text-neutral-400">
        {t.hero.subtitle}
      </p>
    </div>

    <div class="mx-auto mt-16 grid max-w-4xl grid-cols-1 gap-8 sm:mt-20 lg:grid-cols-2">
      <!-- Formulaire de Contact -->
      <div class="rounded-2xl border border-neutral-200 bg-white p-8 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
        <form id="contact-form" class="space-y-6">
          <div>
            <label for="name" class="block font-medium text-neutral-900 dark:text-white">
              {t.form.name.label}
            </label>
            <input
              type="text"
              name="name"
              id="contact-name"
              required
              placeholder={t.form.name.placeholder}
              class="mt-2 block w-full rounded-md border-0 bg-neutral-50 px-3.5 py-2 text-neutral-900 shadow-sm ring-1 ring-inset ring-neutral-300 placeholder:text-neutral-400 focus:ring-2 focus:ring-inset focus:ring-magenta dark:bg-neutral-800 dark:text-white dark:ring-neutral-700 dark:placeholder:text-neutral-500 dark:focus:ring-magenta sm:text-sm sm:leading-6"
            />
          </div>

          <div>
            <label for="email" class="block font-medium text-neutral-900 dark:text-white">
              {t.form.email.label}
            </label>
            <input
              type="email"
              name="email"
              id="contact-email"
              required
              placeholder={t.form.email.placeholder}
              class="mt-2 block w-full rounded-md border-0 bg-neutral-50 px-3.5 py-2 text-neutral-900 shadow-sm ring-1 ring-inset ring-neutral-300 placeholder:text-neutral-400 focus:ring-2 focus:ring-inset focus:ring-magenta dark:bg-neutral-800 dark:text-white dark:ring-neutral-700 dark:placeholder:text-neutral-500 dark:focus:ring-magenta sm:text-sm sm:leading-6"
            />
          </div>

          <div>
            <label for="subject" class="block font-medium text-neutral-900 dark:text-white">
              {t.form.subject.label}
            </label>
            <input
              type="text"
              name="subject"
              id="contact-subject"
              required
              placeholder={t.form.subject.placeholder}
              class="mt-2 block w-full rounded-md border-0 bg-neutral-50 px-3.5 py-2 text-neutral-900 shadow-sm ring-1 ring-inset ring-neutral-300 placeholder:text-neutral-400 focus:ring-2 focus:ring-inset focus:ring-magenta dark:bg-neutral-800 dark:text-white dark:ring-neutral-700 dark:placeholder:text-neutral-500 dark:focus:ring-magenta sm:text-sm sm:leading-6"
            />
          </div>

          <div>
            <label for="message" class="block font-medium text-neutral-900 dark:text-white">
              {t.form.message.label}
            </label>
            <textarea
              name="message"
              id="contact-message"
              rows="4"
              required
              placeholder={t.form.message.placeholder}
              class="mt-2 block w-full rounded-md border-0 bg-neutral-50 px-3.5 py-2 text-neutral-900 shadow-sm ring-1 ring-inset ring-neutral-300 placeholder:text-neutral-400 focus:ring-2 focus:ring-inset focus:ring-magenta dark:bg-neutral-800 dark:text-white dark:ring-neutral-700 dark:placeholder:text-neutral-500 dark:focus:ring-magenta sm:text-sm sm:leading-6"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full rounded-md bg-magenta px-3.5 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-magenta"
          >
            {t.form.submit}
          </button>

          <!-- Success/Error messages -->
          <div id="contact-success" class="hidden rounded-md bg-green/10 p-3 text-sm text-green">
            {t.form.success}
          </div>
          <div id="contact-error" class="hidden rounded-md bg-red/10 p-3 text-sm text-red">
            {t.form.error}
          </div>
        </form>

        <script>
          const form = document.getElementById('contact-form') as HTMLFormElement | null;
          form?.addEventListener('submit', (e) => {
            e.preventDefault();
            const name = (document.getElementById('contact-name') as HTMLInputElement)?.value || '';
            const email = (document.getElementById('contact-email') as HTMLInputElement)?.value || '';
            const subject = (document.getElementById('contact-subject') as HTMLInputElement)?.value || '';
            const message = (document.getElementById('contact-message') as HTMLTextAreaElement)?.value || '';

            const mailtoUrl = `mailto:contact@winflowz.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(`From: ${name} (${email})\n\n${message}`)}`;
            window.location.href = mailtoUrl;

            const successEl = document.getElementById('contact-success');
            if (successEl) {
              successEl.classList.remove('hidden');
              setTimeout(() => successEl.classList.add('hidden'), 5000);
            }
          });
        </script>
      </div>

      <!-- Informations de Contact -->
      <div class="space-y-10">
        <div>
          <h2 class="text-2xl font-bold text-neutral-900 dark:text-white">
            {t.contact.title}
          </h2>
          <dl class="mt-4 space-y-4">
            <div>
              <dt class="font-medium text-neutral-600 dark:text-neutral-400">
                {t.contact.email.label}
              </dt>
              <dd class="mt-1">
                <a
                  href={`mailto:${t.contact.email.value}`}
                  class="text-magenta hover:text-magenta dark:text-magenta dark:hover:text-magenta"
                >
                  {t.contact.email.value}
                </a>
              </dd>
            </div>
            <div>
              <dt class="font-medium text-neutral-600 dark:text-neutral-400">
                {t.contact.location.label}
              </dt>
              <dd class="mt-1 text-neutral-900 dark:text-white">
                {t.contact.location.value}
              </dd>
            </div>
            <div>
              <dt class="font-medium text-neutral-600 dark:text-neutral-400">
                {t.contact.hours.label}
              </dt>
              <dd class="mt-1 text-neutral-900 dark:text-white">
                {t.contact.hours.value}
              </dd>
            </div>
          </dl>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-neutral-900 dark:text-white">
            {t.support.title}
          </h2>
          <ul class="mt-4 space-y-4">
            {supportItems.map((item: SupportItem) => (
              <li>
                <a
                  href={item.link}
                  class="group flex items-start space-x-3 text-neutral-600 hover:text-magenta dark:text-neutral-400 dark:hover:text-magenta"
                >
                  <div>
                    <p class="font-medium text-neutral-900 group-hover:text-magenta dark:text-white dark:group-hover:text-magenta">
                      {item.title}
                    </p>
                    <p class="mt-1">{item.description}</p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section> 

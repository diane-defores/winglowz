}

const { lang = 'en' as Language } = Astro.props
const copy = copyByLang[lang]
const pagePath = lang === 'fr' ? '/fr/socialglowz-founder' : '/socialglowz-founder'

function checkoutUrl() {
	const successUrl = `/purchase/success?offerId=${encodeURIComponent(OFFER_ID)}`
	const cancelUrl = `/purchase/cancel?offerId=${encodeURIComponent(OFFER_ID)}`
	return `/api/commerce/checkout?offerId=${encodeURIComponent(OFFER_ID)}&provider=lemonsqueezy&source=direct&sourceRef=${encodeURIComponent(pagePath)}&successUrl=${encodeURIComponent(successUrl)}&cancelUrl=${encodeURIComponent(cancelUrl)}`
}
---

<MainLayout
	title={copy.metaTitle}
	meta={{
		title: copy.metaTitle,
		description: copy.metaDescription,
	}}
	lang={lang}
	structuredData={{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		'@id': getLocalizedSiteUrl(lang, '/socialglowz-founder'),
		url: getLocalizedSiteUrl(lang, '/socialglowz-founder'),
		name: copy.metaTitle,
		description: copy.metaDescription,
		inLanguage: lang,
	}}
>
	<div class="space-y-16 pb-16">
		<section class="relative overflow-hidden rounded-2xl border border-neutral-200 bg-neutral-950 text-white shadow-2xl dark:border-neutral-700">
			<div class="absolute inset-x-0 top-0 h-2 bg-gradient-rainbow-horizontal" />
			<div class="absolute inset-0 bg-gradient-to-br from-magenta/30 via-neutral-950 to-cyan/20" />
			<div class="relative mx-auto grid max-w-6xl gap-12 px-6 py-12 md:px-10 lg:grid-cols-2 lg:items-center">
				<div class="max-w-2xl">
					<p class="mb-5 inline-flex rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-white">
						{copy.badge}
					</p>
					<h1 class="max-w-3xl text-4xl font-bold text-white sm:text-5xl md:text-6xl">
						{copy.heroTitle}
					</h1>
					<p class="mt-6 max-w-2xl text-lg leading-relaxed text-neutral-200">
						{copy.heroSubtitle}
					</p>
					<div class="mt-8 flex flex-col gap-3 sm:flex-row">
						<a
							href={checkoutUrl()}
							class="no-hover-animation inline-flex items-center justify-center rounded-xl bg-white px-6 py-3 text-sm font-bold text-neutral-950 transition-colors hover:bg-neutral-100"
						>
							{copy.primaryAction}
						</a>
						<a
							href="#offer"
							class="no-hover-animation inline-flex items-center justify-center rounded-xl border border-white/25 bg-white/10 px-6 py-3 text-sm font-bold text-white transition-colors hover:bg-white/20"
						>
							{copy.secondaryAction}
						</a>
					</div>
				</div>

				<div class="relative">
					<div class="mx-auto max-w-md rounded-2xl border border-white/15 bg-white/10 p-4 shadow-2xl backdrop-blur">
						<div class="rounded-xl bg-white p-4 text-neutral-900 shadow-xl">
							<div class="mb-4 flex items-center justify-between">
								<div>
									<p class="text-xs font-semibold uppercase tracking-wider text-magenta">SocialGlowz</p>
									<p class="text-sm font-bold text-neutral-900">Launch board</p>
								</div>
								<img src="/images/WinFlowz.png" alt="WinFlowz suite mark" class="h-10 w-10 rounded-lg" loading="eager" />
							</div>
							<div class="grid gap-3">
								<div class="rounded-xl border border-neutral-200 bg-neutral-50 p-4">
									<div class="mb-3 flex items-center justify-between gap-3">
										<p class="text-sm font-bold text-neutral-900">Founder campaign</p>
										<span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">Live</span>
									</div>
									<div class="grid gap-2 sm:grid-cols-3">
										<div class="rounded-lg bg-white p-3">
											<p class="text-xs font-semibold uppercase tracking-wider text-neutral-500">Hooks</p>
											<p class="mt-1 text-2xl font-bold text-neutral-900">18</p>
										</div>
										<div class="rounded-lg bg-white p-3">
											<p class="text-xs font-semibold uppercase tracking-wider text-neutral-500">Assets</p>
											<p class="mt-1 text-2xl font-bold text-neutral-900">07</p>
										</div>
										<div class="rounded-lg bg-white p-3">
											<p class="text-xs font-semibold uppercase tracking-wider text-neutral-500">Replies</p>
											<p class="mt-1 text-2xl font-bold text-neutral-900">12</p>
										</div>
									</div>
								</div>
								<div class="grid gap-3 sm:grid-cols-2">
									<div class="rounded-xl bg-magenta/10 p-4">
										<p class="text-xs font-bold uppercase tracking-wider text-magenta">Next post</p>
										<p class="mt-2 text-sm font-semibold text-neutral-900">Founder offer angle</p>
									</div>
									<div class="rounded-xl bg-cyan/10 p-4">
										<p class="text-xs font-bold uppercase tracking-wider text-cyan">Follow-up</p>
										<p class="mt-2 text-sm font-semibold text-neutral-900">Warm replies queue</p>
									</div>
								</div>
								<div class="rounded-xl bg-neutral-950 p-4 text-white">
									<p class="text-xs font-semibold uppercase tracking-wider text-neutral-400">Checkout route</p>
									<p class="mt-2 break-words text-sm font-semibold">{OFFER_ID}</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-2 lg:items-start">
			<div>
				<p class="text-sm font-semibold uppercase tracking-wider text-magenta">{copy.productKicker}</p>
				<h2 class="mt-3 text-3xl font-bold text-neutral-900 dark:text-white">{copy.productHeading}</h2>
				<p class="mt-4 text-lg text-neutral-600 dark:text-neutral-300">{copy.productText}</p>
			</div>
			<div class="grid gap-3">
				{copy.productPoints.map((item) => (
					<div class="rounded-xl border border-neutral-200 bg-white p-4 text-sm font-medium text-neutral-700 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-200">
						{item}
					</div>
				))}
			</div>
		</section>

		<section class="mx-auto max-w-6xl rounded-2xl border border-neutral-200 bg-white p-6 dark:border-neutral-700 dark:bg-neutral-900 md:p-8">
			<div class="max-w-3xl">
				<h2 class="text-3xl font-bold text-neutral-900 dark:text-white">{copy.workflowHeading}</h2>
				<p class="mt-4 text-lg text-neutral-600 dark:text-neutral-300">{copy.workflowText}</p>
			</div>
			<div class="mt-8 grid gap-4 md:grid-cols-3">
				{copy.workflowSteps.map((item) => (
					<div class="rounded-xl border border-neutral-200 bg-neutral-50 p-5 dark:border-neutral-700 dark:bg-neutral-800">
						<p class="text-xs font-bold uppercase tracking-wider text-magenta">Step {item.step}</p>
						<h3 class="mt-3 text-xl font-bold text-neutral-900 dark:text-white">{item.title}</h3>
						<p class="mt-3 text-sm text-neutral-600 dark:text-neutral-300">{item.description}</p>
					</div>
				))}
			</div>
		</section>

		<section id="offer" class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-5">
			<div class="lg:col-span-2">
				<p class="text-sm font-semibold uppercase tracking-wider text-magenta">{copy.offerKicker}</p>
				<h2 class="mt-3 text-3xl font-bold text-neutral-900 dark:text-white">{copy.offerHeading}</h2>
				<p class="mt-4 text-lg text-neutral-600 dark:text-neutral-300">{copy.offerText}</p>
			</div>
			<div class="overflow-hidden rounded-2xl border border-magenta/40 bg-white shadow-2xl shadow-neutral-900/10 dark:bg-neutral-900 lg:col-span-3">
				<div class="bg-gradient-rainbow-horizontal p-1">
					<div class="rounded-xl bg-white p-6 dark:bg-neutral-950 md:p-8">
						<div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
							<div>
								<p class="text-sm font-semibold uppercase tracking-wider text-magenta">{copy.offerName}</p>
								<h3 class="mt-3 text-3xl font-bold text-neutral-900 dark:text-white">{copy.offerPrice}</h3>
								<p class="mt-3 max-w-2xl text-sm text-neutral-600 dark:text-neutral-300">{copy.offerNote}</p>
							</div>
							<span class="rounded-full border border-neutral-200 px-4 py-2 text-xs font-bold uppercase tracking-wider text-neutral-600 dark:border-neutral-700 dark:text-neutral-300">
								{OFFER_ID}
							</span>
						</div>
						<div class="mt-6 grid gap-3 md:grid-cols-2">
							{copy.offerIncludes.map((item) => (
								<div class="rounded-xl bg-neutral-50 p-4 text-sm text-neutral-700 dark:bg-neutral-800 dark:text-neutral-200">
									{item}
								</div>
							))}
						</div>
						<a
							href={checkoutUrl()}
							class="no-hover-animation mt-6 inline-flex w-full items-center justify-center rounded-xl bg-neutral-950 px-6 py-4 text-sm font-bold text-white transition-colors hover:bg-neutral-800 dark:bg-white dark:text-neutral-950 dark:hover:bg-neutral-200"
						>
							{copy.checkoutAction}
						</a>
					</div>
				</div>
			</div>
		</section>

		<section class="mx-auto max-w-6xl rounded-2xl border border-neutral-200 bg-neutral-950 p-6 text-white dark:border-neutral-700 md:p-8">
			<div class="max-w-3xl">
				<h2 class="text-3xl font-bold text-white">{copy.trustHeading}</h2>
				<p class="mt-4 text-lg text-neutral-300">{copy.trustText}</p>
			</div>
			<div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
				{copy.trustPoints.map((point) => (
					<div class="rounded-xl border border-white/10 bg-white/10 p-4">
						<p class="text-xs font-semibold uppercase tracking-wider text-neutral-400">{point.label}</p>
						<p class="mt-2 text-sm font-bold text-white">{point.value}</p>
					</div>
				))}
			</div>
		</section>

		<section class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-2">
			<div>
				<h2 class="text-3xl font-bold text-neutral-900 dark:text-white">{copy.limitsHeading}</h2>
				<p class="mt-4 text-lg text-neutral-600 dark:text-neutral-300">{copy.limitsText}</p>
			</div>
			<div class="grid gap-3">
				{copy.limits.map((item) => (
					<div class="rounded-xl border border-neutral-200 bg-white p-4 text-sm text-neutral-700 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-200">
						{item}
					</div>
				))}
			</div>
		</section>

		<section class="mx-auto max-w-6xl rounded-2xl border border-neutral-200 bg-white p-6 dark:border-neutral-700 dark:bg-neutral-900 md:p-8">
			<h2 class="text-3xl font-bold text-neutral-900 dark:text-white">{copy.faqHeading}</h2>
			<p class="mt-3 text-lg text-neutral-600 dark:text-neutral-300">{copy.faqText}</p>
			<div class="mt-6 grid gap-3">
				{copy.faqItems.map((item) => (
					<div class="rounded-xl border border-neutral-200 bg-neutral-50 p-5 dark:border-neutral-700 dark:bg-neutral-800">
						<p class="text-sm font-bold text-neutral-900 dark:text-white">{item.question}</p>
						<p class="mt-2 text-sm text-neutral-600 dark:text-neutral-300">{item.answer}</p>
					</div>
				))}
			</div>
		</section>

		<section class="mx-auto max-w-6xl rounded-2xl border border-magenta/30 bg-gradient-to-r from-magenta to-cyan p-8 text-white md:p-10">
			<div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
				<div class="max-w-2xl">
					<h2 class="text-3xl font-bold text-white">{copy.finalHeading}</h2>
					<p class="mt-4 text-lg text-white/90">{copy.finalText}</p>
				</div>
				<a
					href={checkoutUrl()}
					class="no-hover-animation inline-flex items-center justify-center rounded-xl bg-white px-6 py-3 text-sm font-bold text-neutral-950 transition-colors hover:bg-neutral-100"
				>
					{copy.finalAction}
				</a>
			</div>
		</section>
	</div>
</MainLayout>

			{
				step: '01',
				title: 'Capturer le signal',
				description:
					'Regrouper hooks, angles, reponses, assets et notes de contact dans une meme vue operationnelle.',
			},
			{
				step: '02',
				title: 'Former la campagne',
				description:
					'Transformer les idees brutes en sequences avec statut, contexte et prochaine action.',
			},
			{
				step: '03',
				title: 'Assurer le suivi',

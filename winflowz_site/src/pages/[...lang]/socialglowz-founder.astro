---
import MainLayout from '@/layouts/MainLayout.astro'
import type { Language } from '@/types'
import { getLocalizedSiteUrl } from '@/constants'

export const prerender = true

export async function getStaticPaths() {
	return [
		{
			params: { lang: undefined },
			props: { lang: 'en' as Language },
		},
		{
			params: { lang: 'fr' },
			props: { lang: 'fr' as Language },
		},
	]
}

interface WorkflowStep {
	step: string
	title: string
	description: string
}

interface ProofPoint {
	label: string
	value: string
}

interface FaqItem {
	question: string
	answer: string
}

interface CopyBlock {
	metaTitle: string
	metaDescription: string
	badge: string
	heroTitle: string
	heroSubtitle: string
	primaryAction: string
	secondaryAction: string
	productKicker: string
	productHeading: string
	productText: string
	productPoints: string[]
	workflowHeading: string
	workflowText: string
	workflowSteps: WorkflowStep[]
	offerKicker: string
	offerHeading: string
	offerText: string
	offerName: string
	offerPrice: string
	offerNote: string
	offerIncludes: string[]
	checkoutAction: string
	trustHeading: string
	trustText: string
	trustPoints: ProofPoint[]
	limitsHeading: string
	limitsText: string
	limits: string[]
	faqHeading: string
	faqText: string
	faqItems: FaqItem[]
	finalHeading: string
	finalText: string
	finalAction: string
}

const OFFER_ID = 'socialglowz/lifetime_deal'

const copyByLang: Record<Language, CopyBlock> = {

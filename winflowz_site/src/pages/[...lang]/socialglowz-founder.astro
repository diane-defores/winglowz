		trustHeading: 'Base sur le modele d acces deja present dans le repo',
		trustText:
			'La page ne cree pas un systeme de vente parallele. Elle pointe vers l offre SocialGlowz et le bridge provider deja en place.',
		trustPoints: [
			{ label: 'Offer ID', value: 'socialglowz/lifetime_deal' },
			{ label: 'Product ID', value: 'socialglowz' },
			{ label: 'Plan', value: 'lifetime_deal' },
			{ label: 'Provider', value: 'Lemon Squeezy d abord' },
		],
		limitsHeading: 'Limites claires pour le lancement',
		limitsText:
			'Le copy reste honnete pendant que le prix public exact et les mentions legales sont finalises.',
		limits: [
			'Pas de fausse rarete, de chiffres de revenus, ni de preuve client inventee.',
			'Pas de promesse de parite marketplace non supportee hors des termes publies.',
			'Pas de raccourci d acces cote client; l acces vient des evenements provider et de l etat suite.',
			'Le checkout demande la configuration Lemon Squeezy live avant de finaliser un achat en production.',
		],
		faqHeading: 'FAQ founder',
		faqText: 'Reponses courtes pour l offre SocialGlowz directe.',

---
export const prerender = true
import MainLayout from '@/layouts/MainLayout.astro'
import type { Language } from '@/types'
import { generateStaticPaths } from '@/utils/routing'
import { testimonials } from '@/components/react/landing/TestimonialCarousel'
import { getLocalizedSiteUrl } from '@/constants'

export const getStaticPaths = () => generateStaticPaths('testimonials')

interface Props {
  lang: Language
}

const { lang } = Astro.props
const title = lang === 'fr' ? 'Livre d’or' : 'Wall of Love'
const description =
  lang === 'fr'
    ? 'Une collection vivante de preuves sociales, avis clients et captures de confiance.'
    : 'A living collection of social proof, customer reviews, and trust signals.'
---

<MainLayout
  title={title}
  meta={{
    description,
  }}
  lang={lang}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': getLocalizedSiteUrl(lang, lang === 'fr' ? '/temoignages' : '/testimonials'),
    url: getLocalizedSiteUrl(lang, lang === 'fr' ? '/temoignages' : '/testimonials'),
    name: title,
    description,
    inLanguage: lang,
  }}
>
  <main class="bg-background text-foreground">
    <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500 dark:text-zinc-500">
          {lang === 'fr' ? 'Preuves sociales' : 'Social proof'}
        </p>
        <h1 class="mt-4 text-balance text-4xl font-bold tracking-tight text-neutral-950 dark:text-white sm:text-5xl">
          {title}
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-pretty text-lg leading-relaxed text-neutral-600 dark:text-zinc-400">
          {description}
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {testimonials.map((testimonial) => (
          <article class="landing-surface rounded-2xl border p-6 shadow-sm transition-transform duration-300 hover:-translate-y-1">
            <div class="flex items-center gap-3">
              <img
                src={testimonial.avatarSrc}
                alt={`${testimonial.name} avatar`}
                class="h-12 w-12 rounded-full object-cover ring-2 ring-white dark:ring-zinc-900"
                loading="lazy"
              />
              <div>
                <p class="font-semibold text-neutral-950 dark:text-white">{testimonial.name}</p>
                <p class="text-sm text-neutral-500 dark:text-zinc-500">{testimonial.role}</p>
              </div>
            </div>
            <div class="mt-4 flex gap-0.5">
              {Array.from({ length: testimonial.rating }).map((_, i) => (
                <svg key={i} class="h-4 w-4" viewBox="0 0 24 24" fill="var(--brand-yellow)" stroke="var(--brand-yellow)" stroke-width="1">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
              ))}
            </div>
            <h2 class="mt-4 text-lg font-semibold text-neutral-950 dark:text-white">{testimonial.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-neutral-600 dark:text-zinc-400">
              {testimonial.quote}
            </p>
            {testimonial.verified && (
              <p class="mt-4 text-xs font-medium uppercase tracking-[0.16em]" style="color: var(--brand-green);">
                {lang === 'fr' ? 'Achat verifie' : 'Verified purchase'}
              </p>
            )}
          </article>
        ))}
      </div>
    </section>
  </main>
</MainLayout>

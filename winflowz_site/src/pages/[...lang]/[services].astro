---
export const prerender = true
import MainLayout from '@/layouts/MainLayout.astro'
import { useTranslations } from '@/utils/i18n'
import type { Language } from '@/types'
import { getCollection } from 'astro:content'
import MainSection from '@components/ui/blocks/MainSection.astro'
import LeftSection from '@components/ui/blocks/LeftSection.astro'
import RightSection from '@components/ui/blocks/RightSection.astro'
import FeaturesStats from '@components/sections/features/FeaturesStats.astro'
import { getLocalizedSiteUrl } from '@/constants'

// Import distinct service images
import chromeExtImg from '@/assets/images/services/chrome-extensions.svg'
import obsidianPluginsImg from '@/assets/images/services/obsidian-plugins.svg'
import windowsMasteryImg from '@/assets/images/services/windows-mastery.svg'
import productivitySuiteImg from '@/assets/images/services/productivity-suite.svg'

// Distinct images per service section
const defaultImages = [chromeExtImg, obsidianPluginsImg, windowsMasteryImg, productivitySuiteImg]

interface Article {
	isRightSection: boolean
	title: string
	subTitle: string
	btnExists?: boolean
	btnTitle?: string
	btnURL?: string
	single?: boolean
	img?: any
	imgAlt?: string
	imgOne?: any
	imgOneAlt?: string
	imgTwo?: any
	imgTwoAlt?: string
}

interface TranslatedArticle {
	isRightSection: boolean
	title: string
	subtitle: string
	single?: boolean
	imgAlt?: string
	imgOneAlt?: string
	imgTwoAlt?: string
	btnExists?: boolean
	btnTitle?: string
	btnURL?: string
}

export async function getStaticPaths() {
	return [
		// Route anglaise
		{
			params: { lang: undefined, services: 'services' },
			props: { lang: 'en' as Language },
		},
		// Route française
		{
			params: { lang: 'fr', services: 'services' },
			props: { lang: 'fr' as Language },
		},
	]
}

interface Props {
	lang: Language
}

const { lang } = Astro.props
const t = await useTranslations(lang, 'services')

// Articles statiques qui donnent plus de contexte
const staticArticles: Article[] = t.articles.map(
	(article: TranslatedArticle, index: number) => {
		const imgIndex = index % defaultImages.length
		const nextImgIndex = (index + 1) % defaultImages.length
		if (article.isRightSection) {
			return {
				isRightSection: article.isRightSection,
				title: article.title,
				subTitle: article.subtitle,
				single: article.single ?? false,
				imgOne: defaultImages[imgIndex],
				imgOneAlt: article.imgOneAlt,
				imgTwo: defaultImages[nextImgIndex],
				imgTwoAlt: article.imgTwoAlt,
				btnExists: article.btnExists,
				btnTitle: article.btnTitle,
				btnURL: article.btnURL || '/contact',
			}
		} else {
			return {
				isRightSection: article.isRightSection,
				title: article.title,
				subTitle: article.subtitle,
				img: defaultImages[imgIndex],
				imgAlt: article.imgAlt,
				btnExists: article.btnExists,
				btnTitle: article.btnTitle,
				btnURL: article.btnURL || '/contact',
			}
		}
	}
)

// Charger les services en fonction de la langue
const services = await getCollection('services', ({ id }) => {
	return id.startsWith(lang === 'en' ? 'en/' : 'fr/')
})

// Transformer les services en articles pour l'affichage
const serviceArticles = services.map((service, index) => {
	const isRightSection = index % 2 === 0
	const imageIndex = index % defaultImages.length
	const nextImageIndex = (index + 1) % defaultImages.length

	if (isRightSection) {
		return {
			isRightSection,
			title: service.data.title,
			subTitle: service.data.description,
			single: false,
			imgOne: defaultImages[imageIndex],
			imgOneAlt: service.data.imageAlt || service.data.title,
			imgTwo: defaultImages[nextImageIndex],
			imgTwoAlt: service.data.imageAlt || service.data.title,
			btnExists: true,
			btnTitle: t.learnMore || 'Learn More',
			btnURL: '/contact',
		}
	} else {
		return {
			isRightSection,
			title: service.data.title,
			subTitle: service.data.description,
			img: defaultImages[imageIndex],
			imgAlt: service.data.imageAlt || service.data.title,
			btnExists: true,
			btnTitle: t.learnMore || 'Learn More',
			btnURL: '/contact',
		}
	}
})

// Combiner les articles statiques et dynamiques
const allArticles = [...staticArticles, ...serviceArticles]
---

<MainLayout
	title={t.title}
	meta={{
		title: t.title,
		description: t.description,
	}}
	lang={lang}
	structuredData={{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		'@id': getLocalizedSiteUrl(lang, '/services'),
		url: getLocalizedSiteUrl(lang, '/services'),
		name: t.title,
		description: t.description,
		inLanguage: lang,
	}}
>
	<MainSection
		title={t.hero.title}
		subTitle={t.hero.subtitle}
		btnExists={true}
		btnTitle={t.hero.cta}
		btnURL="/contact"
	/>

	{
		allArticles.map((article) => {
			return article.isRightSection ? (
				<RightSection
					title={article.title}
					subTitle={article.subTitle}
					single={article.single}
					imgOne={article.imgOne}
					imgOneAlt={article.imgOneAlt}
					imgTwo={article.imgTwo}
					imgTwoAlt={article.imgTwoAlt}
					btnExists={article.btnExists}
					btnTitle={article.btnTitle}
					btnURL={article.btnURL}
				/>
			) : (
				<LeftSection
					title={article.title}
					subTitle={article.subTitle}
					img={article.img}
					imgAlt={article.imgAlt}
					btnExists={article.btnExists}
					btnTitle={article.btnTitle}
					btnURL={article.btnURL}
				/>
			)
		})
	}

	<FeaturesStats
		title={t.stats.title}
		subTitle={t.stats.subtitle}
		mainStatTitle={t.stats.mainStat.title}
		mainStatSubTitle={t.stats.mainStat.subtitle}
		stats={t.stats.items}
	/>
</MainLayout>

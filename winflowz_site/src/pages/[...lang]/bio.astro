---
import type { Language } from '@/types'
import { getLocalizedSiteUrl, SITE_VISUAL_TOKENS } from '@/constants'
import '@/theme/bio-page.css'

export const prerender = true

export async function getStaticPaths() {
	return [
		{
			params: { lang: undefined },
			props: { lang: 'en' as Language },
		},
		{
			params: { lang: 'fr' },
			props: { lang: 'fr' as Language },
		},
	]
}

interface Props {
	lang: Language
}

const { lang } = Astro.props
const isEn = lang === 'en'

const title = isEn ? 'WinFlowz | Links' : 'WinFlowz | Liens'
const description = isEn
	? 'Chrome extensions, Obsidian plugins & Windows productivity guide with 200+ tested tips.'
	: 'Extensions Chrome, plugins Obsidian et guide de productivité Windows avec 200+ astuces testées.'
const canonical = getLocalizedSiteUrl(lang, '/bio')
---

<!DOCTYPE html>
<html lang={lang} class="dark">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>{title}</title>
	<meta name="description" content={description} />
	<meta name="robots" content="index, follow" />
	<link rel="canonical" href={canonical} />

	<link rel="alternate" hreflang="en" href={getLocalizedSiteUrl('en', '/bio')} />
	<link rel="alternate" hreflang="fr" href={getLocalizedSiteUrl('fr', '/bio')} />
	<link rel="alternate" hreflang="x-default" href={getLocalizedSiteUrl('en', '/bio')} />

	<meta property="og:title" content={title} />
	<meta property="og:description" content={description} />
	<meta property="og:url" content={canonical} />
	<meta property="og:type" content="website" />
	<meta property="og:site_name" content="WinFlowz" />
	<meta property="og:locale" content={isEn ? 'en_US' : 'fr_FR'} />

	<meta name="twitter:card" content="summary" />
	<meta name="twitter:title" content={title} />
	<meta name="twitter:description" content={description} />

	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Audiowide&family=Manrope:wght@400;500;600;700&family=DM+Sans:opsz,wght@9..40,400;9..40,500&display=swap" rel="stylesheet" />

</head>
<body>
	<div class="bio-container">
		<div class="bio-avatar">
			<img
				src="/images/WinFlowz.png"
				alt="WinFlowz"
				width={SITE_VISUAL_TOKENS.bio.avatarSize}
				height={SITE_VISUAL_TOKENS.bio.avatarSize}
			/>
		</div>

		<h1 class="bio-name">WinFlowz</h1>

		<p class="bio-tagline">
			{isEn
				? 'Chrome extensions, Obsidian plugins & Windows productivity guide.'
				: 'Extensions Chrome, plugins Obsidian et guide productivité Windows.'
			}
		</p>

		<div class="bio-links">
			<a href={getLocalizedSiteUrl(lang, '/landing')} class="bio-link">
				{isEn ? 'Homepage' : 'Accueil'}
			</a>
			<a href={getLocalizedSiteUrl(lang, lang === 'fr' ? '/produits' : '/products')} class="bio-link">
				{isEn ? 'Products' : 'Produits'}
			</a>
			<a href={getLocalizedSiteUrl(lang, '/blog')} class="bio-link">Blog</a>
			<a href={getLocalizedSiteUrl(lang, '/landing#pricing')} class="bio-link">
				{isEn ? 'Pricing' : 'Tarifs'}
			</a>
			<a href={getLocalizedSiteUrl(lang, '/landing')} class="bio-link cta">
				{isEn ? 'Get Started Free' : 'Commencer Gratuitement'}
			</a>
			<a href={getLocalizedSiteUrl(lang, '/contact')} class="bio-link">Contact</a>
		</div>

		<div class="bio-socials">
			<!-- GitHub -->
			<a href="https://github.com/winflowz" aria-label="GitHub" rel="noopener noreferrer" target="_blank">
				<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
			</a>
			<!-- Twitter/X -->
			<a href="https://x.com/winflowz" aria-label="Twitter / X" rel="noopener noreferrer" target="_blank">
				<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
			</a>
			<!-- LinkedIn -->
			<a href="https://linkedin.com/company/winflowz" aria-label="LinkedIn" rel="noopener noreferrer" target="_blank">
				<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
			</a>
		</div>

		<p class="bio-footer">
			&copy; {SITE_VISUAL_TOKENS.bio.footerYear} WinFlowz
		</p>
	</div>
</body>
</html>

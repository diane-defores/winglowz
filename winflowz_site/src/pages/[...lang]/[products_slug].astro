---
export const prerender = true
// Import section components
import MainLayout from '@/layouts/MainLayout.astro'
import ProductTabBtn from '@components/ui/buttons/ProductTabBtn.astro'
import PrimaryCTA from '@components/ui/buttons/PrimaryCTA.astro'
import { getCollection } from 'astro:content'
import { SITE } from '@/constants'

export async function getStaticPaths() {
	const products = await getCollection('products')
	return products.map((product) => {
		const isEnglish = product.id.startsWith('en/')
		const slug = product.id
			.replace(isEnglish ? /^en\// : /^fr\//, '')
			.replace(/\.md$/, '')

		if (isEnglish) {
			return {
				params: {
					lang: undefined,
					products_slug: `products/${slug}`,
				},
				props: { product },
			}
		} else {
			return {
				params: {
					lang: 'fr',
					products_slug: `produits/${slug}`,
				},
				props: { product },
			}
		}
	})
}

const { product } = Astro.props

const pageTitle: string = `${product.data.title} | ${SITE.title}`
const pageLang = product.id.startsWith('fr/') ? 'fr' : 'en'
const status = product.data.status ?? 'available'
const statusLabel =
	pageLang === 'fr'
		? {
				available: 'Disponible',
				beta: 'BETA',
				coming_soon: 'A VENIR',
			}[status]
		: {
				available: 'Available',
				beta: 'BETA',
				coming_soon: 'Coming Soon',
			}[status]
const statusClasses =
	{
		available: 'bg-green/15 text-green ring-1 ring-green/30',
		beta: 'bg-cyan/15 text-cyan ring-1 ring-cyan/30',
		coming_soon: 'bg-yellow/15 text-yellow ring-1 ring-yellow/30',
	}[status]
const isPurchasable = status === 'available'
const hasActionCta = product.data.longDescription.btnURL !== '#'
const hasOverview = Boolean(product.data.longDescription)
const hasSpecifications = Boolean(
	product.data.specificationsLeft?.length ||
	product.data.specificationsRight?.length ||
	product.data.tableData?.length
)
const visibleTabs = product.data.tabs.filter((_, index) => {
	if (index === 0) return hasOverview
	if (index === 1) return hasSpecifications
	return false
})
---

<MainLayout title={pageTitle}>
	<section
		class="mx-auto flex max-w-screen-2xl flex-col px-4 py-10 sm:px-6 lg:px-8 lg:py-14"
	>
		<div>
			<p
				class="mb-8 max-w-prose text-pretty font-light text-neutral-700 dark:text-neutral-300 sm:text-xl"
			>
				{product.data.main.content}
			</p>
		</div>
		<div
			class="flex flex-col items-center justify-between space-y-4 sm:flex-row sm:space-y-0"
		>
			<div class="w-full sm:w-1/2">
				<div class="mb-4">
					<span class={`inline-flex rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wider ${statusClasses}`}>
						{statusLabel}
					</span>
				</div>
				<h1
					class="block text-4xl font-bold tracking-tighter text-neutral-800 dark:text-neutral-200 sm:text-5xl md:text-6xl lg:text-7xl"
				>
					{product.data.title}
				</h1>
				<p class="text-lg text-neutral-600 dark:text-neutral-400">
					{product.data.description}
				</p>
			</div>
			<div class="w-full sm:w-1/2">
				<img
					src={product.data.main.imgMain.toString()}
					class="w-full max-w-xl"
					alt={product.data.main.imgAlt}
					draggable="false"
					loading="eager"
				/>
			</div>
		</div>
	</section>

	<div class="mx-auto max-w-screen-2xl px-4 pt-10 sm:px-6 lg:px-8 lg:pt-14">
		<nav
			class="mx-auto grid max-w-6xl gap-y-px sm:flex sm:gap-x-4 sm:gap-y-0"
			aria-label="Tabs"
			role="tablist"
		>
			{
				visibleTabs.map((tab, index) => (
					<ProductTabBtn
						title={tab.title}
						id={tab.id}
						dataTab={tab.dataTab}
						first={index === 0}
					/>
				))
			}
		</nav>

		<div class="mt-12 md:mt-16">
			{hasOverview && (
				<div id="tabs-with-card-1" role="tabpanel">
					<div
						class="mx-auto max-w-screen-2xl px-4 pb-10 sm:px-6 lg:px-8 lg:pb-14"
					>
						<div class="grid gap-12 md:grid-cols-2">
							<div class="lg:w-3/4">
								<h2
									class="text-balance text-3xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:leading-tight lg:text-4xl"
								>
									{product.data.longDescription.title}
								</h2>
								<p
									class="mt-3 text-pretty text-neutral-600 dark:text-neutral-400"
								>
									{product.data.longDescription.subTitle}
								</p>
								<p class="mt-5">
									{
										isPurchasable ? (
											<PrimaryCTA
												title={product.data.longDescription.btnTitle}
												url={product.data.longDescription.btnURL}
											/>
										) : hasActionCta ? (
											<PrimaryCTA
												title={product.data.longDescription.btnTitle}
												url={product.data.longDescription.btnURL}
											/>
										) : (
											<span class="inline-flex w-full items-center justify-center rounded-xl border border-neutral-300 bg-neutral-100 px-6 py-2.5 font-bold text-neutral-600 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-300 sm:w-auto sm:px-8 sm:py-3">
												{statusLabel}
											</span>
										)
									}
								</p>
							</div>

							<div class="space-y-6 lg:space-y-10">
								{
									product.data.descriptionList.map((list) => (
										<div class="flex">
											<div>
												<h3 class="text-base font-bold text-neutral-800 dark:text-neutral-200 sm:text-lg">
													{list.title}
												</h3>
												<p class="mt-1 text-neutral-600 dark:text-neutral-400">
													{list.subTitle}
												</p>
											</div>
										</div>
									))
								}
							</div>
						</div>
					</div>
				</div>
			)}

			{hasSpecifications && (
				<div id="tabs-with-card-2" class={hasOverview ? 'hidden' : undefined} role="tabpanel">
					<div
						class="mx-auto max-w-screen-2xl px-4 pb-10 sm:px-6 lg:px-8 lg:pb-14"
					>
						<div class="grid w-full grid-cols-1 gap-x-16 md:grid-cols-2">
							<div class="max-w-md space-y-6">
								{
									product.data.specificationsLeft.map((spec) => (
										<div>
											<h3 class="block font-bold text-neutral-800 dark:text-neutral-200">
												{spec.title}
											</h3>
											<p class="text-neutral-600 dark:text-neutral-400">
												{spec.subTitle}
											</p>
										</div>
									))
								}
							</div>
							{
								product.data.specificationsRight ? (
									<div class="mt-6 max-w-md space-y-6 md:ml-auto md:mt-0">
										{product.data.specificationsRight?.map((spec) => (
											<div>
												<h3 class="block font-bold text-neutral-800 dark:text-neutral-200">
													{spec.title}
												</h3>
												<p class="text-neutral-600 dark:text-neutral-400">
													{spec.subTitle}
												</p>
											</div>
										))}
									</div>
								) : product.data.tableData ? (
									<div class="mt-6 space-y-6 md:ml-auto md:mt-0">
										<div class="flex flex-col">
											<div class="-m-1.5 overflow-x-auto">
												<div class="inline-block min-w-full p-1.5 align-middle">
													<div class="overflow-hidden">
														<table class="min-w-full divide-y divide-neutral-300 dark:divide-neutral-700">
															<thead>
																<tr>
																	{product.data.tableData?.[0].feature?.map(
																		(header) => (
																			<th
																				scope="col"
																				class="px-6 py-3 text-start text-xs font-medium uppercase text-neutral-500 dark:text-neutral-500"
																			>
																				{header}
																			</th>
																		)
																	)}
																</tr>
															</thead>
															<tbody class="divide-y divide-neutral-300 dark:divide-neutral-700">
																{product.data.tableData?.map((row) =>
																	row.description.map((rowData) => (
																		<tr>
																			{rowData.map((cellValue) => (
																				<td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-neutral-600 dark:text-neutral-400">
																					{cellValue}
																				</td>
																			))}
																		</tr>
																	))
																)}
															</tbody>
														</table>
													</div>
												</div>
											</div>
										</div>
									</div>
								) : null
							}
						</div>
					</div>
				</div>
			)}
		</div>
	</div>
</MainLayout>

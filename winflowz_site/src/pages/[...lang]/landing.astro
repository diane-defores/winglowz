---
import MainLayout from '@/layouts/MainLayout.astro'
import HeroSection from '@components/sections/landing/HeroSection.astro'
import HeroSectionAlt from '@components/sections/landing/HeroSectionAlt.astro'
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro'
import Pricing from '@components/astro/landing/Pricing.astro'
import FAQ from '@components/sections/misc/FAQ.astro'
import { useTranslations } from '@/utils/i18n'
import type { Language } from '@/types'
import { getLocalizedSiteUrl } from '@/constants'
import { getLocalizedPath } from '@/utils/routing'

export const prerender = true

export async function getStaticPaths() {
	return [
		{
			params: { lang: undefined },
			props: { lang: 'en' as Language },
		},
		{
			params: { lang: 'fr' },
			props: { lang: 'fr' as Language },
		},
	]
}

interface Props {
	lang: Language
}

const { lang } = Astro.props
const t = await useTranslations(lang, 'home')
const metaDescription = t.meta?.description ?? ''
const windowsMasteryUrl = lang === 'fr' ? '/fr/maitrise-windows' : '/windows-mastery'
const recommendationsUrl = getLocalizedPath(lang, 'recommendations')

const appScreenshots = [
	{
		src: 'https://winflowz.b-cdn.net/winflowz_app_1.jpg',
		alt: lang === 'fr' ? 'Capture de l’application WinFlowz' : 'WinFlowz app screenshot',
	},
	{
		src: 'https://winflowz.b-cdn.net/winflowz_app_2.jpg',
		alt: lang === 'fr' ? 'Deuxième capture de l’application WinFlowz' : 'Second WinFlowz app screenshot',
	},
	{
		src: 'https://winflowz.b-cdn.net/winflowz_app_3.jpg',
		alt: lang === 'fr' ? 'Troisième capture de l’application WinFlowz' : 'Third WinFlowz app screenshot',
	},
	{
		src: 'https://winflowz.b-cdn.net/winflowz_app_dark_mode.jpg',
		alt: lang === 'fr' ? 'Capture WinFlowz en mode sombre' : 'WinFlowz dark mode screenshot',
	},
]

const proofCards = [
	{
		heading: lang === 'fr' ? 'L’app WinFlowz' : 'The WinFlowz app',
		content:
			lang === 'fr'
				? 'Les captures Android montrent l’interface réelle que les visiteurs verront bientôt plus souvent que des mockups.'
				: 'The Android captures show the real interface visitors will see, not placeholder mockups.',
		svg: 'dashboard',
	},
	{
		heading: lang === 'fr' ? 'La formation' : 'The training',
		content:
			lang === 'fr'
				? 'La page reste centrée sur la formation Windows, qui est le cœur du parcours public.'
				: 'The page stays centered on the Windows training, which remains the core public path.',
		svg: 'tools',
	},
	{
		heading: lang === 'fr' ? 'Les preuves sociales' : 'The proof',
		content:
			lang === 'fr'
				? 'La page Recommandations garde les captures AppSumo et les retours existants, sans dépendre de visuels introuvables.'
				: 'The Recommendations page keeps the AppSumo captures and existing feedback, without relying on missing visuals.',
		svg: 'house',
	},
]
---

<MainLayout
	title={String(t.title)}
	meta={{
		description: metaDescription,
	}}
	lang={lang}
	structuredData={{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		'@id': getLocalizedSiteUrl(lang, '/landing'),
		url: getLocalizedSiteUrl(lang, '/landing'),
		name: t.title,
		description: metaDescription,
		inLanguage: lang,
	}}
>
	<HeroSection
		title={t.hero.title}
		subTitle={t.hero.subTitle}
		primaryBtn={t.hero.primaryBtn}
		primaryBtnURL={t.hero.primaryBtnURL}
		secondaryBtn={t.hero.secondaryBtn}
		secondaryBtnURL={recommendationsUrl}
		src={appScreenshots[0].src}
		alt={appScreenshots[0].alt}
	/>

	<FeaturesGeneral
		title={lang === 'fr' ? 'Ce que le site met en avant maintenant' : 'What the site highlights now'}
		subTitle={lang === 'fr'
			? 'On garde ce qui peut être montré tout de suite: l’app, la formation, et les captures de preuve.'
			: 'We keep only what can be shown right now: the app, the training, and proof screenshots.'}
		src={appScreenshots[1].src}
		alt={appScreenshots[1].alt}
		features={proofCards}
	/>

	<section class="mx-auto max-w-[85rem] px-3 py-8 sm:px-6 sm:py-10 lg:px-8 lg:py-14 2xl:max-w-full">
		<div class="mx-auto max-w-3xl text-center">
			<p class="text-xs font-semibold uppercase tracking-[0.18em] text-neutral-500 dark:text-zinc-500">
				{lang === 'fr' ? 'Captures disponibles' : 'Available screenshots'}
			</p>
			<h2 class="mt-3 text-balance text-2xl font-bold text-neutral-800 dark:text-neutral-200 sm:text-3xl lg:text-4xl">
				{lang === 'fr' ? 'Les seules images qu’on garde pour le moment' : 'The only images we keep for now'}
			</h2>
			<p class="mt-3 text-pretty text-neutral-600 dark:text-neutral-400">
				{lang === 'fr'
					? 'Le site est prêt à avancer sans dépendre de visuels manquants. Dès que tu as d’autres captures, on les replace au bon endroit.'
					: 'The site can move forward without depending on missing visuals. As soon as you have more screenshots, we can slot them in.'}
			</p>
		</div>
		<div class="mt-8 grid gap-4 sm:grid-cols-2">
			{appScreenshots.map((image) => (
				<figure class="landing-surface overflow-hidden rounded-2xl border border-neutral-200 shadow-sm dark:border-zinc-800">
					<img src={image.src} alt={image.alt} class="h-full w-full object-cover" loading="lazy" />
				</figure>
			))}
		</div>
	</section>

	<Pricing />

	<FAQ />

	<HeroSectionAlt
		title={t.cta.title}
		subTitle={t.cta.subTitle}
		url={windowsMasteryUrl}
	/>
</MainLayout>

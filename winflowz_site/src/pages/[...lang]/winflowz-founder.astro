				<div class="relative">
					<div class="mx-auto w-full max-w-sm rounded-3xl border border-neutral-200 bg-white p-4 shadow-2xl shadow-black/10 ring-1 ring-black/5 dark:border-neutral-700 dark:bg-neutral-900 dark:ring-white/5">

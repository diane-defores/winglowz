const { lang = 'en' as Language } = Astro.props
const copy = copyByLang[lang]
const pagePath = lang === 'fr' ? '/fr/winflowz-founder' : '/winflowz-founder'
const defaultOfferId = 'winflowz_app/power'

function checkoutUrl(offerId: string) {
	const successUrl = `/purchase/success?offerId=${encodeURIComponent(offerId)}`
	const cancelUrl = `/purchase/cancel?offerId=${encodeURIComponent(offerId)}`
	return `/api/commerce/checkout?offerId=${encodeURIComponent(offerId)}&provider=lemonsqueezy&source=direct&sourceRef=${encodeURIComponent(pagePath)}&successUrl=${encodeURIComponent(successUrl)}&cancelUrl=${encodeURIComponent(cancelUrl)}`
}
---

<MainLayout
	title={copy.metaTitle}
	meta={{
		title: copy.metaTitle,
		description: copy.metaDescription,
	}}
	lang={lang}
	structuredData={{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		'@id': getLocalizedSiteUrl(lang, '/winflowz-founder'),
		url: getLocalizedSiteUrl(lang, '/winflowz-founder'),
		name: copy.metaTitle,
		description: copy.metaDescription,
		inLanguage: lang,
	}}
>
	<div class="space-y-16 pb-16">
		<section class="relative overflow-hidden rounded-2xl border border-neutral-200/80 bg-gradient-to-br from-white to-neutral-50 p-8 md:p-12 dark:border-neutral-700 dark:from-neutral-900 dark:to-neutral-950">
			<div class="absolute inset-x-0 top-0 h-2 bg-gradient-rainbow-horizontal opacity-80" />
			<div class="absolute inset-0 bg-gradient-to-br from-magenta/10 via-transparent to-cyan/10" />
			<div class="relative mx-auto grid max-w-6xl gap-12 lg:grid-cols-2 lg:items-center">
				<div class="max-w-2xl">
					<p class="mb-4 inline-flex rounded-full border border-magenta/40 bg-magenta/10 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-magenta">
						{copy.badge}
					</p>
					<h1 class="mb-6 text-4xl font-bold text-neutral-900 dark:text-white sm:text-5xl">
						{copy.heroTitle}
					</h1>
					<p class="mb-8 text-lg leading-relaxed text-neutral-600 dark:text-neutral-300">
						{copy.heroSubtitle}

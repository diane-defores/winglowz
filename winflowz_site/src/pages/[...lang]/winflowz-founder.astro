						>
							{copy.primaryAction}
						</a>
						<a
							href="#architecture"
							class="inline-flex items-center rounded-xl border border-neutral-300 bg-white/80 px-6 py-3 text-sm font-semibold text-neutral-900 transition-colors hover:bg-neutral-100 dark:border-neutral-700 dark:bg-neutral-800 dark:text-white dark:hover:bg-neutral-700"
						>
							{copy.secondaryAction}

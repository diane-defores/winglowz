---
export const prerender = true
import LandingLayout from '@layouts/LandingLayout.astro'
import Navbar from '@components/shared/site/Navbar.astro'
import Hero from '@components/astro/landing/Hero.astro'
import LogoMarquee from '@components/astro/landing/LogoMarquee.astro'
import BentoGrid from '@components/astro/landing/BentoGrid.astro'
import LeadMagnet from '@components/astro/landing/LeadMagnet.astro'
import Pricing from '@components/astro/landing/Pricing.astro'
import FinalCTA from '@components/astro/landing/FinalCTA.astro'
import Footer from '@components/shared/site/Footer.astro'
import type { Language } from '@/types'

export async function getStaticPaths() {
	return [
		{ params: { lang: undefined }, props: { lang: 'en' as Language } },
		{ params: { lang: 'fr' }, props: { lang: 'fr' as Language } },
	]
}

const { lang } = Astro.props

const landingNavItems = [
  { label: lang === 'fr' ? 'Maîtrise Windows' : 'Windows Mastery', href: lang === 'fr' ? '/fr/maitrise-windows' : '/windows-mastery' },
  { label: lang === 'fr' ? 'Apps & outils' : 'Apps & Tools', href: "#features" },
  { label: lang === 'fr' ? 'Produits' : 'Products', href: lang === 'fr' ? '/fr/produits' : '/products' },
  { label: lang === 'fr' ? 'Parcours' : 'Courses', href: lang === 'fr' ? '/fr/formations/' : '/en/formations/' },
  { label: "Roadmap", href: lang === 'fr' ? '/fr/roadmap' : '/roadmap' },
  { label: "Blog", href: lang === 'fr' ? '/fr/blog' : '/blog' },
]
---

<LandingLayout lang={lang}>
	<main class="min-h-screen bg-background transition-colors duration-300">
		<Navbar navItems={landingNavItems} />
		<Hero />
		<LogoMarquee />
		<BentoGrid />
		<LeadMagnet />
		<Pricing />
		<FinalCTA />
		<Footer />
	</main>
</LandingLayout>

---
import MainLayout from '@/layouts/MainLayout.astro'

const offerId = Astro.url.searchParams.get('offerId')
const isWinFlowzAppOffer = offerId?.startsWith('winflowz_app/') ?? false
const isSocialGlowzOffer = offerId === 'socialglowz/lifetime_deal'
const returnUrl = isWinFlowzAppOffer
	? '/winflowz-founder'
	: isSocialGlowzOffer
		? '/socialglowz-founder'
		: '/products'
---

<MainLayout title="Checkout Cancelled">
	<div class="flex min-h-screen items-center justify-center py-12">
		<div class="mx-auto max-w-lg text-center">
			<div class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-full bg-neutral-100 dark:bg-neutral-800">
				<svg class="h-8 w-8 text-neutral-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M18 6 6 18"/>
					<path d="m6 6 12 12"/>
				</svg>
			</div>

			<h1 class="mb-4 text-3xl font-bold text-neutral-900 dark:text-neutral-100">Checkout cancelled</h1>
			<p class="mb-8 text-lg text-neutral-500 dark:text-neutral-400">
				No payment was completed. You can return to the offer when you are ready.
			</p>

			<a href={returnUrl} class="inline-flex items-center justify-center rounded-lg bg-magenta px-6 py-3 font-medium text-white transition-opacity hover:opacity-90">
				Return to the offer
			</a>
		</div>
	</div>
</MainLayout>

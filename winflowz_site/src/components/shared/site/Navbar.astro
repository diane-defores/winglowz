---
import ThemePicker from '@/components/ui/ThemePicker.astro'
import NavLink from '@components/ui/links/NavLink.astro'
import TextLogo from '@components/ui/TextLogo.astro'
import { getLangFromUrl, useTranslations } from '@/utils/i18n'

interface NavItem {
  label: string
  href: string
}

interface Props {
  navItems?: NavItem[]
  forceDark?: boolean
  showThemePicker?: boolean
}

const {
  navItems: propNavItems,
  forceDark = false,
  showThemePicker = true,
} = Astro.props

const lang = getLangFromUrl(Astro.url)
const t = await useTranslations(lang, 'navigation')
const homeUrl = lang === 'fr' ? '/fr' : '/'

const navItems: NavItem[] =
  propNavItems ||
  t.navBarLinks?.map((link: { name: string; url: string }) => ({
    label: link.name,
    href: link.url,
  })) ||
  []

const altLang = lang === 'fr' ? 'en' : 'fr'
const altLangLabel = lang === 'fr' ? 'EN' : 'FR'

const routeMappings: Record<string, string> = {
  about: 'a-propos',
  'windows-mastery': 'maitrise-windows',
  recommendations: 'recommandations',
  testimonials: 'temoignages',
  'en/formations': 'formations',
  'products/obsidian-plugins': 'produits/obsidian-plugins',
  'products/chrome-extensions': 'produits/chrome-extensions',
  'products/productivity-suite': 'produits/productivity-suite',
  terms: 'cgu',
  disclaimer: 'non-responsabilite',
  privacy: 'confidentialite',
  copyright: 'droits',
  legal: 'mentions-legales',
  products: 'produits',
  'products/obsidian': 'produits/obsidian',
  'products/chrome': 'produits/chrome',
  'products/windows': 'produits/windows',
  services: 'services',
  blog: 'blog',
  contact: 'contact',
  roadmap: 'roadmap',
  signin: 'signin',
}

function getTranslatedPath(path: string, targetLang: string): string {
  if (path === '/' || path === '/fr' || path === '/fr/') {
    return targetLang === 'fr' ? '/fr' : '/'
  }

  const cleanPath = path.replace(/^\/fr\//, '/')

  if (targetLang === 'fr') {
    for (const [en, fr] of Object.entries(routeMappings)) {
      if (cleanPath === `/${en}` || cleanPath.startsWith(`/${en}/`)) {
        return `/fr/${fr}${cleanPath.substring(en.length + 1)}`
      }
    }
    return `/fr${cleanPath}`
  }

  for (const [en, fr] of Object.entries(routeMappings)) {
    if (cleanPath === `/${fr}` || cleanPath.startsWith(`/${fr}/`)) {
      return `/${en}${cleanPath.substring(fr.length + 1)}`
    }
  }

  return cleanPath
}

const altLangUrl = getTranslatedPath(Astro.url.pathname, altLang)

const signInLabel = lang === 'fr' ? 'Connexion' : 'Sign In'
const ctaLabel = lang === 'fr' ? 'Parcours Windows' : 'Start with WinFlowz'
const signInUrl = lang === 'fr' ? '/fr/signin' : '/signin'
const ctaUrl =
  lang === 'fr'
    ? '/fr/signin?next=%2Fdashboard%2Fdocs%2Ffr%2Fformations%2Fmodule-2-windows%2F'
    : '/signin?next=%2Fdashboard%2Fdocs%2Fen%2Fformations%2Fmodule-2-windows%2F'
const menuLabel = lang === 'fr' ? 'Ouvrir le menu' : 'Open menu'
const darkModeLabel = lang === 'fr' ? 'Mode sombre' : 'Dark mode'
const lightModeLabel = lang === 'fr' ? 'Mode clair' : 'Light mode'
const mobileTagline =
  lang === 'fr'
    ? 'Apps & Formation pour la Productivité'
    : 'Productivity Apps & Training'

const navShellClass = forceDark
  ? 'relative flex items-center justify-between rounded-full border border-zinc-800 bg-zinc-950/88 px-4 py-3 shadow-none backdrop-blur-md'
  : 'relative flex items-center justify-between rounded-full border border-neutral-200/60 bg-white/80 px-4 py-3 shadow-sm backdrop-blur-md dark:border-zinc-800 dark:bg-zinc-900/80 dark:shadow-none'

const navLinkClass =
  'no-hover-animation relative rounded-full px-3 py-2 text-sm font-medium transition-colors'
const navLinkActiveClass = forceDark
  ? 'text-white'
  : 'text-neutral-950 dark:text-white'
const navLinkInactiveClass = forceDark
  ? 'text-zinc-400 hover:text-white'
  : 'text-neutral-600 hover:text-neutral-950 dark:text-zinc-400 dark:hover:text-white'

const langLinkClass = forceDark
  ? 'no-hover-animation rounded-full px-2.5 py-1.5 text-xs font-semibold text-zinc-500 transition-colors hover:bg-zinc-800 hover:text-white'
  : 'no-hover-animation rounded-full px-2.5 py-1.5 text-xs font-semibold text-neutral-700 transition-colors hover:bg-neutral-100 hover:text-neutral-950 dark:text-zinc-500 dark:hover:bg-zinc-800 dark:hover:text-white'

const signInButtonClass = forceDark
  ? 'rounded-full px-3 py-1.5 text-sm text-zinc-400 transition-colors hover:bg-zinc-800 hover:text-white'
  : 'rounded-full px-3 py-1.5 text-sm font-medium text-neutral-800 transition-colors hover:bg-neutral-100 hover:text-neutral-950 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-white'

const ctaButtonClass = forceDark
  ? 'shimmer-btn rounded-full bg-white px-4 py-1.5 text-sm font-medium text-zinc-950 hover:bg-zinc-200'
  : 'shimmer-btn rounded-full bg-neutral-900 px-4 py-1.5 text-sm font-medium text-white hover:bg-neutral-700 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200'
---

<header
  class="navbar-header fixed inset-x-0 top-4 z-50 mx-auto w-full max-w-4xl px-4"
>
  <nav class={navShellClass}>
    <a href={homeUrl} class="no-hover-animation flex items-center gap-2">
      <TextLogo class="w-28" />
    </a>

    <p
      class="mx-4 hidden flex-1 text-center text-xs font-semibold uppercase tracking-wider text-neutral-600 dark:text-zinc-400 max-md:block"
    >
      {mobileTagline}
    </p>

    <div class="hidden items-center gap-1 md:flex">
      {
        navItems.map((item) => (
          <NavLink
            url={item.href}
            name={item.label}
            class={navLinkClass}
            activeClass={navLinkActiveClass}
            inactiveClass={navLinkInactiveClass}
          />
        ))
      }
    </div>

    <div class="hidden items-center gap-1 md:flex">
      <a href={altLangUrl} class={langLinkClass}>
        {altLangLabel}
      </a>
      {showThemePicker && !forceDark && <ThemePicker />}
      <a href={signInUrl} class="no-hover-animation">
        <button class={signInButtonClass}>
          {signInLabel}
        </button>
      </a>
      <a href={ctaUrl} class="no-hover-animation">
        <button class={ctaButtonClass}>
          {ctaLabel}
        </button>
      </a>
    </div>

    <details class="mobile-menu relative md:hidden">
      <summary
        class="mobile-menu-toggle flex h-9 w-9 cursor-pointer list-none items-center justify-center rounded-full text-neutral-800 transition-colors hover:bg-neutral-100 hover:text-neutral-950 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-white"
        aria-label={menuLabel}
      >
        <span class="sr-only">{menuLabel}</span>
        <span class="hamburger-lines" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </summary>

      <div
        class={forceDark
          ? 'absolute right-0 top-full mt-3 min-w-[280px] max-w-sm rounded-2xl border border-zinc-800 bg-zinc-950/96 p-4 shadow-2xl backdrop-blur-md'
          : 'absolute right-0 top-full mt-3 min-w-[280px] max-w-sm rounded-2xl border border-neutral-200/60 bg-white/95 p-4 shadow-lg backdrop-blur-md dark:border-zinc-800 dark:bg-zinc-900/95 dark:shadow-none'}
      >
        <div class="flex flex-col gap-2">
          {
            navItems.map((item) => (
              <NavLink
                url={item.href}
                name={item.label}
                class="rounded-lg px-4 py-3.5 text-base font-semibold text-neutral-800 transition-all duration-200 hover:-translate-y-0.5 hover:bg-neutral-100 hover:text-neutral-950 hover:shadow-sm dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-white"
                activeClass={
                  forceDark ? 'text-white' : 'text-neutral-950 dark:text-white'
                }
                inactiveClass={
                  forceDark
                    ? 'text-zinc-400'
                    : 'text-neutral-800 dark:text-zinc-400'
                }
              />
            ))
          }
          <hr class="my-2 border-neutral-200 dark:border-zinc-800" />
          <div
            class={`grid ${showThemePicker && !forceDark ? 'grid-cols-3' : 'grid-cols-2'} gap-2`}
          >
            <a
              href={altLangUrl}
              class="rounded-lg px-2 py-3 text-center text-sm font-bold text-neutral-700 transition-all duration-200 hover:-translate-y-0.5 hover:bg-neutral-100 hover:text-neutral-950 dark:text-zinc-500 dark:hover:bg-zinc-800 dark:hover:text-white"
            >
              {altLangLabel}
            </a>
            {
              showThemePicker && !forceDark && (
                <div class="flex items-center justify-center">
                  <button
                    type="button"
                    data-hs-theme-click-value="dark"
                    aria-label={darkModeLabel}
                    class="flex h-10 w-10 items-center justify-center rounded-lg text-neutral-800 transition-all duration-200 hover:-translate-y-0.5 hover:bg-neutral-100 hover:text-neutral-950 hover:shadow-sm hs-dark-mode-active:hidden dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-white"
                  >
                    <svg class="h-5 w-5" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
                    </svg>
                  </button>
                  <button
                    type="button"
                    data-hs-theme-click-value="light"
                    aria-label={lightModeLabel}
                    class="hidden h-10 w-10 items-center justify-center rounded-lg text-neutral-800 transition-all duration-200 hover:-translate-y-0.5 hover:bg-neutral-100 hover:text-neutral-950 hover:shadow-sm hs-dark-mode-active:flex dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-white"
                  >
                    <svg class="h-5 w-5" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="4"></circle>
                      <path d="M12 8a2 2 0 1 0 4 4"></path>
                      <path d="M12 2v2"></path>
                      <path d="M12 20v2"></path>
                      <path d="m4.93 4.93 1.41 1.41"></path>
                      <path d="m17.66 17.66 1.41 1.41"></path>
                      <path d="M2 12h2"></path>
                      <path d="M20 12h2"></path>
                      <path d="m6.34 17.66-1.41 1.41"></path>
                      <path d="m19.07 4.93-1.41 1.41"></path>
                    </svg>
                  </button>
                </div>
              )
            }
            <a href={signInUrl} class="flex items-center">
              <span
                class="block w-full rounded-lg px-2 py-3 text-center text-base font-semibold text-neutral-800 transition-all duration-200 hover:-translate-y-0.5 hover:bg-neutral-100 hover:text-neutral-950 hover:shadow-sm dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-white"
              >
                {signInLabel}
              </span>
            </a>
          </div>
          <a href={ctaUrl}>
            <span
              class="shimmer-btn inline-flex w-full items-center justify-center rounded-full bg-neutral-900 px-4 py-2.5 text-base font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:brightness-110 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200"
            >
              {ctaLabel}
            </span>
          </a>
        </div>
      </div>
    </details>
  </nav>
</header>

<style>
  .navbar-header {
    animation: var(--navbar-slide-down-animation);
  }

  @keyframes navbar-slide-down {
    0% {
      opacity: 0;
      transform: translateY(-12px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .navbar-header :global(.text-logo) {
    width: fit-content;
  }

  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .hamburger-lines {
    display: inline-flex;
    flex-direction: column;
    gap: var(--navbar-hamburger-gap);
  }

  .hamburger-lines span {
    display: block;
    width: var(--navbar-hamburger-line-width);
    height: var(--navbar-hamburger-line-height);
    border-radius: var(--scrollbar-radius);
    background: currentColor;
  }
</style>

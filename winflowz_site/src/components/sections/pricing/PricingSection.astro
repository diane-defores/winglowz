---
import { getLangFromUrl, useTranslations } from '@/utils/i18n'
import SecondaryCTA from '@components/ui/buttons/SecondaryCTA.astro'
import PricingCard from '@components/ui/blocks/PricingCard.astro'

const lang = getLangFromUrl(Astro.url)
const t = await useTranslations(lang, 'pricing')
const courseHubUrl = lang === 'fr' ? '/fr/formations/' : '/en/formations/'
const windowsMasteryUrl =
  lang === 'fr' ? '/fr/maitrise-windows' : '/windows-mastery'
---

<section
  class="mx-auto max-w-[85rem] px-3 py-8 sm:px-6 sm:py-10 lg:px-8 lg:py-14"
>
  <div class="mx-auto mb-8 max-w-2xl text-center sm:mb-10 lg:mb-14">
    <h2 class="text-balance">
      {t.title}
    </h2>
    <p class="mt-1 text-pretty">
      {t.subtitle}
    </p>
  </div>

  <div class="grid gap-4 lg:grid-cols-2 lg:gap-6">
    <PricingCard
      name={t.plans[0].name}
      description={t.plans[0].description}
      price={t.plans[0].price}
      period={t.plans[0].period}
      features={t.plans[0].features}
      cta={t.plans[0].cta}
      ctaHref={courseHubUrl}
      ctaDataTrack="pricing-free-cta"
      badgeLabel={lang === 'fr' ? 'Gratuit' : 'Free'}
    />

    <PricingCard
      name={t.plans[1].name}
      description={t.plans[1].description}
      price={t.plans[1].price}
      period={t.plans[1].period}
      features={t.plans[1].features}
      cta={t.plans[1].cta}
      popular={true}
      ctaHref={windowsMasteryUrl}
      ctaDataTrack="pricing-pro-cta"
      badgeLabel={lang === 'fr' ? 'Populaire' : 'Popular'}
    />
  </div>

  <div class="mt-6 flex items-center justify-center gap-x-3 sm:mt-8 md:mt-12">
    <p class="text-center text-neutral-600 dark:text-neutral-400">
      {t.plans[2].description}
    </p>
    <SecondaryCTA
      title={t.plans[2].cta}
      url={lang === 'fr' ? '/fr/contact' : '/contact'}
    />
  </div>
</section>

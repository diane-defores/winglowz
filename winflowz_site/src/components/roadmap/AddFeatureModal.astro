---
import { getLangFromUrl, useTranslations } from "@/utils/i18n";
import { projects } from "@/types/roadmap";

const lang = getLangFromUrl(Astro.url);
const t = await useTranslations(lang, "roadmap");

// Préparer les messages de validation pour le JavaScript
const validationMessages = {
  projectRequired: t?.addFeature?.validation?.projectRequired ?? "Please select a project",
  titleRequired: t?.addFeature?.validation?.titleRequired ?? "Please enter a title",
  titleMinLength: t?.addFeature?.validation?.titleMinLength ?? "Title must be at least 3 characters long",
  descriptionRequired: t?.addFeature?.validation?.descriptionRequired ?? "Please enter a description",
  descriptionMinLength: t?.addFeature?.validation?.descriptionMinLength ?? "Description must be at least 10 characters long"
};
---

<div
	id="addFeatureModal"
	class="hs-overlay fixed start-0 top-0 z-50 hidden size-full overflow-x-hidden overflow-y-auto pointer-events-none"
>
	<div
		class="hs-overlay-open:mt-7 hs-overlay-open:opacity-100 hs-overlay-open:duration-500 m-3 mt-0 min-h-screen opacity-0 ease-out transition-all sm:w-full sm:max-w-lg sm:mx-auto"
	>
		<div class="relative flex flex-col rounded-xl border border-neutral-200 bg-white shadow-sm pointer-events-auto dark:border-neutral-700 dark:bg-neutral-800">
			<div class="flex justify-between items-center py-3 px-4 border-b dark:border-neutral-700">
				<h3 class="font-bold text-neutral-800 dark:text-white">
					{t?.addFeature?.title ?? "Add Feature"}
				</h3>
				<button
					type="button"
					class="flex justify-center items-center size-7 text-sm font-semibold rounded-full border border-transparent text-neutral-800 hover:bg-neutral-100 disabled:opacity-50 disabled:pointer-events-none dark:text-white dark:hover:bg-neutral-700 dark:focus:outline-none dark:focus:ring-1 dark:focus:ring-neutral-600"
					data-hs-overlay="#addFeatureModal"
				>
					<span class="sr-only">Close</span>
					<svg
						class="flex-shrink-0 size-4"
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M18 6 6 18"></path>
						<path d="m6 6 12 12"></path>
					</svg>
				</button>
			</div>

			<form
				id="addFeatureForm"
				data-duplicate-message={t?.addFeature?.duplicatePending ?? "You already submitted this suggestion"}
				data-account-message={t?.addFeature?.accountNotReady ?? "Your account is still syncing"}
				data-submit-error={t?.addFeature?.submitError ?? t?.addFeature?.error ?? "Suggestion failed"}
				data-submit-success={t?.addFeature?.submitSuccess ?? t?.addFeature?.success ?? "Suggestion submitted for review"}
			>
				<div class="p-4 overflow-y-auto">
					<div class="grid gap-y-4">
						<!-- Sélection du projet -->
						<div>
							<label
								for="project"
								class="block text-sm font-medium mb-2 dark:text-white"
							>
								{t?.addFeature?.project ?? "Project"}
							</label>
							<select
								id="project"
								name="project"
								class="block w-full rounded-lg border border-neutral-200 px-4 py-3 text-sm focus:border-magenta focus:ring-magenta disabled:pointer-events-none disabled:opacity-50 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-400 dark:focus:ring-neutral-600"
								required
							>
								<option value="" disabled selected>
									{t?.addFeature?.selectProject ?? "Select a project"}
								</option>
								{
									projects.map((project) => (
										<option value={project.id}>
											{t?.projects?.[project.id]?.name ?? project.name}
										</option>
									))
								}
							</select>
						</div>

						<!-- Titre de la fonctionnalité -->
						<div>
							<label
								for="title"
								class="block text-sm font-medium mb-2 dark:text-white"
							>
								{t?.addFeature?.featureTitle ?? "Feature Title"}
							</label>
							<input
								type="text"
								id="title"
								name="title"
								class="block w-full rounded-lg border border-neutral-200 px-4 py-3 text-sm focus:border-magenta focus:ring-magenta disabled:pointer-events-none disabled:opacity-50 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-400 dark:focus:ring-neutral-600"
								required
								minlength="3"
							/>
						</div>

						<!-- Description de la fonctionnalité -->
						<div>
							<label
								for="description"
								class="block text-sm font-medium mb-2 dark:text-white"
							>
								{t?.addFeature?.description ?? "Description"}
							</label>
							<textarea
								id="description"
								name="description"
								rows="4"
								class="block w-full rounded-lg border border-neutral-200 px-4 py-3 text-sm focus:border-magenta focus:ring-magenta disabled:pointer-events-none disabled:opacity-50 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-400 dark:focus:ring-neutral-600"
								required
								minlength="10"
							></textarea>
						</div>
						<p
							id="featureFormStatus"
							class="hidden rounded-lg border border-neutral-200 bg-neutral-50 px-3 py-2 text-sm text-neutral-700 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-300"
						></p>
					</div>
				</div>

				<div class="flex justify-end items-center gap-x-2 py-3 px-4 border-t dark:border-neutral-700">
					<button
						type="button"
						class="inline-flex items-center gap-x-2 rounded-lg border border-neutral-200 bg-white px-3 py-2 text-sm font-medium text-neutral-800 shadow-sm hover:bg-neutral-50 disabled:pointer-events-none disabled:opacity-50 dark:border-neutral-700 dark:bg-neutral-800 dark:text-white dark:hover:bg-neutral-700 dark:focus:outline-none dark:focus:ring-1 dark:focus:ring-neutral-600"
						data-hs-overlay="#addFeatureModal"
					>
						{t?.addFeature?.cancel ?? "Cancel"}
					</button>
					<button
						type="submit"
						class="inline-flex items-center gap-x-2 rounded-lg border border-transparent bg-magenta px-3 py-2 text-sm font-semibold text-white hover:bg-magenta disabled:pointer-events-none disabled:opacity-50 dark:focus:outline-none dark:focus:ring-1 dark:focus:ring-neutral-600"
					>
						{t?.addFeature?.submit ?? "Submit"}
					</button>
				</div>
			</form>
		</div>
	</div>
</div>

<script is:inline define:vars={{ validationMessages }}>
document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('addFeatureModal');
    const backdrop = document.querySelector('.hs-overlay-backdrop');
    const form = document.getElementById('addFeatureForm');
    const projectSelect = document.getElementById('project');
    const titleInput = document.getElementById('title');
    const descriptionInput = document.getElementById('description');
    const statusNode = document.getElementById('featureFormStatus');

    // Configuration de la validation personnalisée
    function setupValidation(input, requiredMessage, minLengthMessage) {
        input.addEventListener('invalid', () => {
            if (input.validity.valueMissing) {
                input.setCustomValidity(requiredMessage);
            } else if (input.validity.tooShort) {
                input.setCustomValidity(minLengthMessage);
            }
        });

        input.addEventListener('input', () => {
            input.setCustomValidity('');
        });
    }

    // Configuration de la validation du select
    projectSelect?.addEventListener('invalid', () => {
        projectSelect.setCustomValidity(validationMessages.projectRequired);
    });

    projectSelect?.addEventListener('change', () => {
        projectSelect.setCustomValidity('');
    });

    // Configurer la validation pour chaque champ
    setupValidation(titleInput, validationMessages.titleRequired, validationMessages.titleMinLength);
    setupValidation(descriptionInput, validationMessages.descriptionRequired, validationMessages.descriptionMinLength);

    // Fonction pour nettoyer la modale et le backdrop
    function cleanupModal() {
        document.body.classList.remove('overflow-hidden');
        document.body.style.paddingRight = '';
        if (backdrop) {
            backdrop.remove();
        }
        modal?.classList.remove('hs-overlay-open');
        modal?.classList.add('hidden');
        if (statusNode) {
            statusNode.classList.add('hidden');
            statusNode.textContent = '';
        }
    }

    // Gestionnaire pour le clic en dehors de la modale
    modal?.addEventListener('click', (e) => {
        if (e.target === modal) {
            cleanupModal();
        }
    });

    // Gestionnaire pour la touche Escape
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal?.classList.contains('hs-overlay-open')) {
            cleanupModal();
        }
    });

    // Nettoyer aussi quand on ferme avec le bouton
    const closeButtons = document.querySelectorAll('[data-hs-overlay="#addFeatureModal"]');
    closeButtons.forEach(button => {
        button.addEventListener('click', cleanupModal);
    });

    form?.addEventListener('submit', async (event) => {
        event.preventDefault();

        const submitButton = form.querySelector('button[type="submit"]');
        submitButton?.setAttribute('disabled', 'true');

        try {
            const response = await fetch('/api/features/suggest', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    projectId: projectSelect?.value ?? '',
                    title: titleInput?.value ?? '',
                    description: descriptionInput?.value ?? '',
                }),
            });

            if (response.status === 401) {
                const redirectUrl = encodeURIComponent(window.location.pathname + window.location.search);
                window.location.href = `/signin?redirect_url=${redirectUrl}`;
                return;
            }

            const data = await response.json();

            if (statusNode) {
                statusNode.classList.remove('hidden');
            }

            if (response.ok) {
                if (statusNode) {
                    statusNode.textContent = form.dataset.submitSuccess ?? 'Suggestion submitted for review';
                }
                form.reset();
                setTimeout(() => cleanupModal(), 600);
                return;
            }

            if (!statusNode) {
                return;
            }

            if (data.error === 'duplicate_suggestion') {
                statusNode.textContent = form.dataset.duplicateMessage ?? 'Duplicate suggestion';
                return;
            }

            if (data.error === 'account_not_ready') {
                statusNode.textContent = form.dataset.accountMessage ?? 'Account syncing';
                return;
            }

            statusNode.textContent = form.dataset.submitError ?? 'Suggestion failed';
        } catch (error) {
            console.error('Error submitting feature suggestion:', error);
            if (statusNode) {
                statusNode.classList.remove('hidden');
                statusNode.textContent = form?.dataset.submitError ?? 'Suggestion failed';
            }
        } finally {
            submitButton?.removeAttribute('disabled');
        }
    });
});
</script>

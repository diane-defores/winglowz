---
import Icon from "@components/ui/icons/Icon.astro";
// Destructure the properties from Astro.props
const { title, url, noArrow } = Astro.props;
// Define TypeScript interface for the properties
interface Props {
  title?: string;
  url?: string;
  noArrow?: boolean;
}
// Define CSS classes for styling the button
const baseClasses =
  "font-pj inline-flex w-full items-center justify-center rounded-xl border-2 border-transparent px-6 py-2.5 font-bold text-white transition-all duration-200 hover:bg-gradient-rainbow focus:outline-none focus:ring-2 focus:ring-magenta focus:ring-offset-2 sm:w-auto sm:px-8 sm:py-3";
const borderClasses = "border border-transparent";
const bgColorClasses =
  "bg-gray-900 hover:bg-magenta active:bg-magenta dark:focus:outline-none";
const disableClasses = "disabled:pointer-events-none disabled:opacity-50";
const ringClasses = "dark:ring-magenta";
---

<!-- Link styled as a button, with dynamic title, URL, and optional arrow -->
<a
  class={`${baseClasses} ${borderClasses} ${bgColorClasses} ${disableClasses} ${ringClasses}`}
  href={url}
>
  {title}
  <!-- Display the arrow based on the 'noArrow' property -->

  {noArrow ? null : <Icon name="arrowRight" />}
</a>
---
interface Props {
	type: "success" | "error" | "warning" | "info";
	title: string;
	message: string;
	show: boolean;
}

const { type = "info", title, message, show = true } = Astro.props;

const styles = {
	success: {
		bg: "bg-green/10 dark:bg-green/10",
		icon: "text-green",
		title: "text-neutral-800 dark:text-neutral-200",
		message: "text-neutral-700 dark:text-neutral-300",
		iconPath:
			"M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z",
	},
	error: {
		bg: "bg-red/10 dark:bg-red/10",
		icon: "text-red",
		title: "text-neutral-800 dark:text-neutral-200",
		message: "text-neutral-700 dark:text-neutral-300",
		iconPath:
			"M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z",
	},
	warning: {
		bg: "bg-yellow/10 dark:bg-yellow/10",
		icon: "text-yellow",
		title: "text-neutral-800 dark:text-neutral-200",
		message: "text-neutral-700 dark:text-neutral-300",
		iconPath:
			"M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z",
	},
	info: {
		bg: "bg-neutral-100 dark:bg-neutral-800",
		icon: "text-cyan",
		title: "text-cyan dark:text-cyan",
		message: "text-cyan dark:text-cyan",
		iconPath:
			"M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z",
	},
} as const;

const currentStyle = styles[type];
---

{
	show && (
		<div class={`rounded-lg p-4 ${currentStyle.bg}`}>
			<div class="flex">
				<div class="flex-shrink-0">
					<svg
						class={`h-5 w-5 ${currentStyle.icon}`}
						viewBox="0 0 20 20"
						fill="currentColor"
					>
						<path
							fill-rule="evenodd"
							d={currentStyle.iconPath}
							clip-rule="evenodd"
						/>
					</svg>
				</div>
				<div class="ml-3">
					<h3 class={`text-sm font-medium ${currentStyle.title}`}>{title}</h3>
					<div class={`mt-2 text-sm ${currentStyle.message}`}>
						<p>{message}</p>
					</div>
				</div>
			</div>
		</div>
	)
}

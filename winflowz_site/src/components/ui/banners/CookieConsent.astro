---
import { getLangFromUrl } from '@/utils/i18n'

interface Props {
  forceDark?: boolean
}

const { forceDark = false } = Astro.props
const lang = getLangFromUrl(Astro.url)

const text = lang === 'fr'
  ? {
      message: "Ce site utilise des cookies essentiels pour faire fonctionner le compte, la connexion et les preferences d'affichage.",
      accept: "Compris",
      decline: "Fermer",
      privacy: "Politique de confidentialite",
      privacyUrl: "/fr/confidentialite",
    }
  : {
      message: "This site uses essential cookies to support your account, sign-in flow, and display preferences.",
      accept: "Understood",
      decline: "Close",
      privacy: "Privacy Policy",
      privacyUrl: "/privacy",
    }

const panelClass = forceDark
  ? 'rounded-xl border border-zinc-800 bg-zinc-950/96 p-4 shadow-2xl backdrop-blur sm:p-6'
  : 'rounded-xl border border-neutral-200 bg-white p-4 shadow-lg dark:border-zinc-800 dark:bg-zinc-900 sm:p-6'

const messageClass = forceDark
  ? 'text-sm text-zinc-300'
  : 'text-sm text-neutral-600 dark:text-zinc-400'

const declineButtonClass = forceDark
  ? 'rounded-full border border-zinc-700 px-4 py-2 text-sm font-medium text-zinc-300 transition-colors hover:bg-zinc-800 hover:text-white'
  : 'rounded-full border border-neutral-300 px-4 py-2 text-sm font-medium text-neutral-600 transition-colors hover:bg-neutral-100 dark:border-zinc-700 dark:text-zinc-400 dark:hover:bg-zinc-800'
---

<div
  id="cookie-consent"
  class="fixed bottom-0 left-0 right-0 z-[100] hidden transform transition-transform duration-300 translate-y-full"
  role="dialog"
  aria-label={lang === 'fr' ? 'Consentement aux cookies' : 'Cookie consent'}
>
  <div class="mx-auto max-w-4xl px-4 pb-4">
    <div class={panelClass}>
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex-1">
          <p class={messageClass}>
            {text.message}
            <a href={text.privacyUrl} class="ml-1 font-medium text-magenta hover:underline">
              {text.privacy}
            </a>
          </p>
        </div>
        <div class="flex shrink-0 items-center gap-2">
          <button
            id="cookie-decline"
            class={declineButtonClass}
          >
            {text.decline}
          </button>
          <button
            id="cookie-accept"
            class="rounded-full bg-magenta px-4 py-2 text-sm font-medium text-white transition-colors hover:opacity-90"
          >
            {text.accept}
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function initCookieConsent() {
    const banner = document.getElementById('cookie-consent')
    const acceptBtn = document.getElementById('cookie-accept')
    const declineBtn = document.getElementById('cookie-decline')

    if (!banner || !acceptBtn || !declineBtn) return

    const consent = localStorage.getItem('cookie-consent')

    if (!consent) {
      banner.classList.remove('hidden')
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          banner.classList.remove('translate-y-full')
        })
      })
    }

    acceptBtn.addEventListener('click', () => {
      localStorage.setItem('cookie-consent', 'accepted')
      banner.classList.add('translate-y-full')
      setTimeout(() => banner.classList.add('hidden'), 300)
    })

    declineBtn.addEventListener('click', () => {
      localStorage.setItem('cookie-consent', 'declined')
      banner.classList.add('translate-y-full')
      setTimeout(() => banner.classList.add('hidden'), 300)
    })
  }

  // Run on initial load
  initCookieConsent()

  // Run on Astro page transitions
  document.addEventListener('astro:page-load', initCookieConsent)
</script>

---
import Icon from '@components/ui/icons/Icon.astro'

interface Props {
  name: string
  description: string
  price: string
  period: string
  features: string[]
  cta: string
  popular?: boolean
  ctaHref?: string
  ctaDataTrack?: string
  badgeLabel?: string
}

const {
  name,
  description,
  price,
  period,
  features,
  cta,
  popular = false,
  ctaHref,
  ctaDataTrack,
  badgeLabel,
} = Astro.props

const tagLabel = badgeLabel ?? (popular ? 'Popular' : 'Standard')
const cardClass = popular
  ? 'relative flex flex-col overflow-hidden rounded-xl shadow-xl'
  : 'relative flex flex-col rounded-xl bg-white p-8 shadow-sm dark:bg-neutral-800'
const innerClass = popular
  ? 'relative m-[3px] flex h-full w-full flex-col rounded-[10px] bg-neutral-900 p-8'
  : 'flex h-full flex-col'
const badgeClass = popular
  ? 'badge-rainbow absolute right-0 top-0 rounded-tr-[10px] rounded-bl-xl'
  : 'badge-neutral absolute right-0 top-0 rounded-tr-xl rounded-bl-xl'
const titleClass = popular
  ? 'text-xl font-bold text-white lg:text-2xl'
  : 'text-xl font-bold text-neutral-800 dark:text-neutral-200 lg:text-2xl'
const descriptionClass = popular
  ? 'mt-2 text-neutral-300'
  : 'mt-2 text-neutral-600 dark:text-neutral-400'
const priceClass = popular
  ? 'text-4xl font-bold text-white lg:text-5xl'
  : 'text-4xl font-bold text-neutral-800 dark:text-neutral-200 lg:text-5xl'
const periodClass = popular
  ? 'text-neutral-400'
  : 'text-neutral-600 dark:text-neutral-400'
const featureClass = popular
  ? 'flex items-center gap-x-2 text-neutral-300'
  : 'flex items-center gap-x-2 text-neutral-600 dark:text-neutral-400'
const ctaClass = popular
  ? 'inline-flex w-full items-center justify-center rounded-lg bg-gradient-rainbow px-4 py-3 text-sm font-semibold text-white transition-all hover:opacity-90 disabled:pointer-events-none disabled:opacity-50'
  : 'inline-flex w-full items-center justify-center rounded-lg border-2 border-magenta px-4 py-3 text-sm font-semibold text-magenta transition-all hover:bg-magenta hover:text-white disabled:pointer-events-none disabled:opacity-50'
---

<div class={cardClass}>
  {popular && <div class="absolute inset-0 rounded-xl bg-gradient-rainbow" />}

  <div class={innerClass}>
    <span class={badgeClass}>
      {tagLabel}
    </span>

    <div class="mb-6">
      <h3 class={titleClass}>
        {name}
      </h3>
      <p class={descriptionClass}>
        {description}
      </p>
    </div>

    <div class="mb-6">
      <span class={priceClass}>
        {price}
      </span>
      {period && <span class={periodClass}>{period}</span>}
    </div>

    <ul class="mb-6 space-y-2">
      {
        features.map((feature) => (
          <li class={featureClass}>
            <Icon name="checkCircle" />
            <span>{feature}</span>
          </li>
        ))
      }
    </ul>

    <div class="mt-auto">
      {
        ctaHref ? (
          <a href={ctaHref} data-track={ctaDataTrack} class={ctaClass}>
            {cta}
          </a>
        ) : (
          <button type="button" class={ctaClass}>
            {cta}
          </button>
        )
      }
    </div>
  </div>
</div>

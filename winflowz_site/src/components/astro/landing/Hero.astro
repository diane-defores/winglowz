---
/* Hero section — pure Astro, CSS animations replace framer-motion */
import Button from '@/components/Button.astro'
import { getLangFromUrl } from '@/utils/i18n'
import { getLocalizedPath } from '@/utils/routing'

const lang = getLangFromUrl(Astro.url)
const windowsMasteryUrl = lang === 'fr' ? '/fr/maitrise-windows' : '/windows-mastery'
const testimonialsUrl = getLocalizedPath(lang, 'recommendations')

const avatars = [
  "/images/headshots/professional-headshot-1.png",
  "/images/headshots/professional-headshot-2.png",
  "/images/headshots/professional-headshot-3.png",
  "/images/headshots/professional-headshot-4.png",
  "/images/headshots/professional-headshot-5.png",
]

const stats = lang === 'fr'
  ? [
      { value: "8", label: "modules" },
      { value: "2", label: "langues" },
      { value: "3", label: "piliers de parcours" },
    ]
  : [
      { value: "8", label: "modules" },
      { value: "2", label: "languages" },
      { value: "3", label: "core tracks" },
    ]

const heroText = lang === 'fr'
  ? {
      badge: "Formation Windows & outils de workflow",
      h1Line1: "Moins de friction.",
      h1Line2: "Plus de travail utile.",
      sub: "WinFlowz vous aide à reprendre le contrôle d’un environnement Windows trop bruyant, trop fragmenté et trop fatigant. Le premier pas reste la page dédiée à la formation.",
      cta: "Voir la formation Windows",
      testimonials: "Témoignages",
      reviews: "issues de la communauté",
    }
  : {
      badge: "Windows training & workflow tools",
      h1Line1: "Less friction.",
      h1Line2: "More real work.",
      sub: "WinFlowz helps you regain control over a Windows environment that is too noisy, too fragmented, and too tiring. Start from the dedicated Windows course path.",
      cta: "See the Windows course",
      testimonials: "Testimonials",
      reviews: "from community feedback",
    }
---

<section class="landing-hero-shell relative flex flex-col items-center justify-center overflow-hidden px-4 pb-16">
  <!-- Background gradient -->
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-neutral-50 via-white to-neutral-100 dark:from-black dark:via-black dark:to-zinc-950"></div>

  <!-- Subtle radial glow -->
  <div class="landing-hero-glow pointer-events-none absolute left-1/2 -translate-x-1/2 rounded-full bg-fuchsia-400/10 blur-3xl dark:bg-zinc-800/20"></div>

  <div class="relative z-10 max-w-5xl mx-auto text-center">
    <!-- Badge -->
    <div class="landing-hero-fade landing-hero-fade--badge landing-surface mb-8 hidden items-center gap-2 rounded-full border px-4 py-2 md:inline-flex">
      <span class="landing-hero-status-dot pulse-glow h-2 w-2 rounded-full"></span>
      <span class="text-sm text-neutral-600 dark:text-zinc-400">{heroText.badge}</span>
    </div>

    <!-- Headline with text mask animation -->
    <h1 class="mb-6 text-6xl font-bold tracking-tight text-neutral-950 dark:text-white sm:text-7xl lg:text-8xl">
      <span class="block overflow-hidden">
        <span class="landing-hero-text-line landing-hero-text-line--primary block">
          {heroText.h1Line1}
        </span>
      </span>
      <span class="block overflow-hidden">
        <span class="landing-hero-text-line landing-hero-text-line--secondary block text-neutral-400 dark:text-zinc-500">
          {heroText.h1Line2}
        </span>
      </span>
    </h1>

    <!-- Subheadline -->
    <p class="landing-hero-fade landing-hero-fade--copy mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-neutral-600 dark:text-zinc-400 sm:text-xl">
      {heroText.sub}
    </p>

    <!-- CTAs -->
    <div class="landing-hero-fade landing-hero-fade--actions mb-16 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <Button variant="primary" link={windowsMasteryUrl} track="hero-primary-cta" icon={{ type: 'icon', name: 'arrow-right' }}>
        {heroText.cta}
      </Button>
      <Button variant="secondary" link={testimonialsUrl} track="hero-recommendations-cta">
        {lang === 'fr' ? 'Recommandations' : 'Recommendations'}
      </Button>
    </div>

    <!-- Social Proof Avatars -->
      <div class="landing-hero-fade landing-hero-fade--proof mb-12 flex flex-col items-center gap-4">
      <div class="flex items-center -space-x-3">
        {avatars.map((avatar) => (
          <div class="landing-hero-avatar relative">
            <img
              src={avatar}
              alt=""
              class="h-10 w-10 rounded-full border-2 border-white object-cover dark:border-black"
              loading="eager"
            />
          </div>
        ))}
      </div>
      <p class="text-sm text-neutral-500 dark:text-zinc-500">
        <span class="font-medium text-neutral-800 dark:text-zinc-300">Avis</span> {heroText.reviews}
      </p>
    </div>

    <!-- Stats -->
    <div class="landing-hero-fade landing-hero-fade--stats mx-auto grid max-w-2xl grid-cols-2 gap-8 sm:grid-cols-4">
      {stats.map((stat) => (
        <div class="landing-hero-stat relative text-center">
          <div class="text-2xl font-bold text-neutral-950 dark:text-white sm:text-3xl">{stat.value}</div>
          <div class="mt-1 text-xs text-neutral-500 dark:text-zinc-500 sm:text-sm">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .landing-hero-shell {
    --landing-hero-shell-padding-top: 4.625rem;
    --landing-hero-glow-width: 50rem;
    --landing-hero-glow-height: 37.5rem;
    --landing-hero-glow-top: 25%;
    --landing-hero-fade-duration: 0.6s;
    --landing-hero-text-duration: 0.8s;
    --landing-hero-avatar-duration: 0.4s;
    --landing-hero-stat-duration: 0.4s;
    --landing-hero-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --landing-hero-badge-delay: 0.2s;
    --landing-hero-copy-delay: 0.5s;
    --landing-hero-actions-delay: 0.6s;
    --landing-hero-proof-delay: 0.7s;
    --landing-hero-stats-delay: 0.9s;
    --landing-hero-title-secondary-delay: 0.1s;
    padding-top: var(--landing-hero-shell-padding-top);
  }

  .landing-hero-glow {
    width: var(--landing-hero-glow-width);
    height: var(--landing-hero-glow-height);
    top: var(--landing-hero-glow-top);
  }

  .landing-hero-status-dot {
    background-color: var(--brand-green);
  }

  .landing-hero-text-line {
    opacity: 0;
    transform: translateY(100%);
    animation: hero-text-reveal var(--landing-hero-text-duration) var(--landing-hero-ease) forwards;
  }

  .landing-hero-text-line--secondary {
    animation-delay: var(--landing-hero-title-secondary-delay);
  }

  .landing-hero-fade {
    opacity: 0;
    transform: translateY(20px);
    animation: hero-fade-up var(--landing-hero-fade-duration) var(--landing-hero-ease) forwards;
  }

  .landing-hero-fade--badge {
    animation-delay: var(--landing-hero-badge-delay);
  }

  .landing-hero-fade--copy {
    animation-delay: var(--landing-hero-copy-delay);
  }

  .landing-hero-fade--actions {
    animation-delay: var(--landing-hero-actions-delay);
  }

  .landing-hero-fade--proof {
    animation-delay: var(--landing-hero-proof-delay);
  }

  .landing-hero-fade--stats {
    animation-delay: var(--landing-hero-stats-delay);
  }

  .landing-hero-avatar {
    opacity: 0;
    transform: scale(0.5) translateX(-20px);
    animation: avatar-pop var(--landing-hero-avatar-duration) var(--landing-hero-ease) forwards;
  }

  .landing-hero-stat {
    opacity: 0;
    transform: scale(0.8);
    animation: hero-fade-up var(--landing-hero-stat-duration) var(--landing-hero-ease) forwards;
  }
</style>

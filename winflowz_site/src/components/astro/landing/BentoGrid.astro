---
/* BentoGrid — Astro wrapper with small React islands for animated widgets */
import { PluginActivityTicker } from '@components/react/landing/PluginActivityTicker'
import { KeyboardShortcutAnim } from '@components/react/landing/KeyboardShortcutAnim'
import { SmartOrgAnim } from '@components/react/landing/SmartOrgAnim'
import { getLangFromUrl } from '@/utils/i18n'

const lang = getLangFromUrl(Astro.url)

const bentoText = lang === 'fr'
  ? {
      sectionTitle: "Tout ce qu'il vous faut pour travailler sans friction",
      sectionSub:
        "Je développe pour les personnes avec TDAH et autisme des outils qui transforment un poste de travail éclaté en environnement stable.",
      obsiTitle: "ObsiFlowz -- Plugins Obsidian",
      obsiDesc:
        "Gérez vos contenus avec RSSFlowz et PluginFlowz pour garder une organisation simple et durable.",
      tubeTitle: "ReplayGlowz",
      tubeDesc:
        "Rationalisez vos recherches YouTube avec une extension Chrome pour l'annotation et la navigation par marque-pages.",
      winTitle: "Maîtrise Windows",
      winDesc: "Débloquez votre environnement Windows avec une méthode d'adoption pratique et répétable.",
      blazingTitle: "Formation structurée",
      blazingDesc: "8 modules pour construire un système Windows plus simple, plus net.",
      smartTitle: "Organisation Intelligente",
      smartDesc: "Classez, découvrez et reprenez le contrôle de vos informations sans surcharge cognitive.",
      avgEfficiency: "modules de formation",
    }
  : {
      sectionTitle: "Everything you need to be productive",
      sectionSub:
        "I build tools for people with ADHD and autism to replace noisy, fragmented workflows with calmer systems.",
      obsiTitle: "ObsiFlowz -- Obsidian Plugins",
      obsiDesc: "Use RSSFlowz and PluginFlowz to keep content curation reliable, searchable, and easy to maintain.",
      tubeTitle: "ReplayGlowz",
      tubeDesc:
        "Streamline YouTube research with a Chrome extension for quick annotation and bookmark workflows.",
      winTitle: "Windows Mastery",
      winDesc: "Build a practical training path for a clearer Windows system and fewer setup blocks.",
      blazingTitle: "Structured training",
      blazingDesc: "8 practical modules to build a clearer Windows system.",
      smartTitle: "Smart Organization",
      smartDesc: "Create a repeatable process to classify, retrieve, and reuse what matters.",
      avgEfficiency: "training modules",
    }
---

<section id="features" class="py-16 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="reveal text-center mb-16">
      <h2
        class="mb-4 text-3xl font-bold text-neutral-950 dark:text-white sm:text-4xl"
        style="font-family: var(--font-instrument-sans);"
      >
        {bentoText.sectionTitle}
      </h2>
      <p class="mx-auto max-w-2xl text-neutral-600 dark:text-zinc-400">
        {bentoText.sectionSub}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <!-- Large card - ObsiFlowz -->
      <div class="landing-surface reveal group relative overflow-hidden rounded-2xl border p-6 transition-all duration-300 hover:scale-[1.02] hover:border-neutral-300 dark:hover:border-zinc-600 md:col-span-2">
        <div class="flex items-start justify-between mb-8">
          <div>
            <div class="mb-4 w-fit rounded-lg bg-neutral-100 p-2 dark:bg-zinc-800">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-500 dark:text-zinc-400"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <h3 class="mb-2 text-xl font-semibold text-neutral-950 dark:text-white">{bentoText.obsiTitle}</h3>
            <p class="text-sm text-neutral-600 dark:text-zinc-400">
              {bentoText.obsiDesc}
            </p>
          </div>
          <PluginActivityTicker client:only="react" />
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {["RSSFlowz", "PluginFlowz", "ContentFlowz", "NoteFlowz"].map((plugin) => (
            <div class="text-center">
              <div class="mb-1 text-sm font-medium text-neutral-900 dark:text-white">{plugin}</div>
              <div class="text-xs text-neutral-500 dark:text-zinc-500">Active</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Chrome Extension -->
      <div class="landing-surface reveal delay-1 group relative rounded-2xl border p-6 transition-all duration-300 hover:scale-[1.02] hover:border-neutral-300 dark:hover:border-zinc-600">
        <div class="mb-4 w-fit rounded-lg bg-neutral-100 p-2 dark:bg-zinc-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-500 dark:text-zinc-400"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="21.17" x2="12" y1="8" y2="8"/><line x1="3.95" x2="8.54" y1="6.06" y2="14"/><line x1="10.88" x2="15.46" y1="21.94" y2="14"/></svg>
        </div>
        <h3 class="mb-2 text-lg font-semibold text-neutral-950 dark:text-white">{bentoText.tubeTitle}</h3>
        <p class="mb-6 text-sm text-neutral-600 dark:text-zinc-400">
          {bentoText.tubeDesc}
        </p>
        <KeyboardShortcutAnim client:only="react" />
      </div>

      <!-- Windows Tools -->
      <div class="landing-surface reveal delay-2 group relative rounded-2xl border p-6 transition-all duration-300 hover:scale-[1.02] hover:border-neutral-300 dark:hover:border-zinc-600">
        <div class="mb-4 w-fit rounded-lg bg-neutral-100 p-2 dark:bg-zinc-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-500 dark:text-zinc-400"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
        </div>
        <h3 class="mb-2 text-lg font-semibold text-neutral-950 dark:text-white">{bentoText.winTitle}</h3>
        <p class="mb-4 text-sm text-neutral-600 dark:text-zinc-400">
          {bentoText.winDesc}
        </p>
        <!-- Animated chart (CSS only) -->
        <svg viewBox="0 0 100 70" class="w-full h-24 bento-chart">
          <defs>
            <linearGradient id="chartGradient" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="rgb(17,24,39)" stop-opacity="0.2" />
              <stop offset="100%" stop-color="rgb(17,24,39)" stop-opacity="0" />
            </linearGradient>
          </defs>
          <path d="M 0 60 L 20 45 L 40 55 L 60 30 L 80 40 L 100 15 L 100 70 L 0 70 Z" fill="url(#chartGradient)" class="opacity-50" />
          <path d="M 0 60 L 20 45 L 40 55 L 60 30 L 80 40 L 100 15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="draw-line text-neutral-900 dark:text-white" />
        </svg>
      </div>

      <!-- Productivity Boost -->
      <div class="landing-surface reveal delay-3 group relative rounded-2xl border p-6 transition-all duration-300 hover:scale-[1.02] hover:border-neutral-300 dark:hover:border-zinc-600">
        <div class="mb-4 w-fit rounded-lg bg-neutral-100 p-2 dark:bg-zinc-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-500 dark:text-zinc-400"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
        </div>
        <h3 class="mb-2 text-lg font-semibold text-neutral-950 dark:text-white">{bentoText.blazingTitle}</h3>
        <p class="mb-4 text-sm text-neutral-600 dark:text-zinc-400">
          {bentoText.blazingDesc}
        </p>
        <div class="flex items-center gap-2 text-sm" style="color: var(--brand-green);">
          <span class="font-mono">8</span>
          <span class="text-neutral-500 dark:text-zinc-500">{bentoText.avgEfficiency}</span>
        </div>
      </div>

      <!-- Smart Organization -->
      <div class="landing-surface reveal delay-4 group relative overflow-hidden rounded-2xl border p-6 transition-all duration-300 hover:scale-[1.02] hover:border-neutral-300 dark:hover:border-zinc-600">
        <div class="mb-4 w-fit rounded-lg bg-neutral-100 p-2 dark:bg-zinc-800">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-500 dark:text-zinc-400"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M22 10v6"/><path d="M6 12.5V16c0 1 2.5 3 6 3s6-2 6-3v-3.5"/></svg>
        </div>
        <h3 class="mb-2 text-lg font-semibold text-neutral-950 dark:text-white">{bentoText.smartTitle}</h3>
        <p class="mb-6 text-sm text-neutral-600 dark:text-zinc-400">
          {bentoText.smartDesc}
        </p>
        <SmartOrgAnim client:only="react" />
      </div>
    </div>
  </div>
</section>

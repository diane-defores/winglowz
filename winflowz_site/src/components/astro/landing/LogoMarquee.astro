---
/* LogoMarquee — Astro wrapper with TestimonialCarousel React island */
import { TestimonialCarousel } from '@components/react/landing/TestimonialCarousel'
import { getLangFromUrl } from '@/utils/i18n'

const lang = getLangFromUrl(Astro.url)

const tools = [
  { name: "ObsiFlowz" },
  { name: "TubeFlowz" },
  { name: "RSSFlowz" },
  { name: "PluginFlowz" },
  { name: "Windows Mastery" },
  { name: "Obsidian" },
  { name: "Chrome" },
  { name: "AppSumo" },
]

const trustText = lang === 'fr'
  ? { trust: "Approuve par les entrepreneurs, freelances et professionnels", reviews: "Des dizaines d'avis 5 etoiles sur", allFive: "" }
  : { trust: "Trusted by entrepreneurs, freelancers & professionals", reviews: "Dozens of 5-star reviews on", allFive: "" }
---

<section id="testimonials" class="py-24 overflow-hidden">
  <div class="reveal text-center mb-6">
    <p class="text-sm font-medium uppercase tracking-wider text-neutral-500 dark:text-zinc-500">
      {trustText.trust}
    </p>
    <div class="flex items-center justify-center gap-2 mt-3">
      <!-- Star rating -->
      <div class="flex gap-0.5">
        {Array.from({ length: 5 }).map(() => (
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="var(--brand-yellow)" stroke="var(--brand-yellow)" stroke-width="1">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
          </svg>
        ))}
      </div>
      <span class="text-sm text-neutral-600 dark:text-zinc-400">
        {trustText.reviews} <span class="font-medium text-neutral-800 dark:text-zinc-300">AppSumo</span> {trustText.allFive}
      </span>
    </div>
  </div>

  <!-- Testimonials carousel (React island) -->
  <div class="reveal delay-2 max-w-3xl mx-auto px-4 mb-8">
    <TestimonialCarousel client:only="react" />
  </div>

  <!-- Marquee -->
  <div class="relative mt-12">
    <div class="landing-marquee-fade-left pointer-events-none absolute bottom-0 left-0 top-0 z-10 w-32"></div>
    <div class="landing-marquee-fade-right pointer-events-none absolute bottom-0 right-0 top-0 z-10 w-32"></div>

    <div class="flex animate-marquee">
      {[...tools, ...tools].map((tool) => (
        <div
          class="flex items-center justify-center min-w-[160px] h-16 mx-8 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
        >
          <div class="flex items-center gap-2 text-neutral-600 dark:text-zinc-400">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-neutral-200 dark:bg-zinc-800">
              <span class="text-xs font-bold">{tool.name[0]}</span>
            </div>
            <span class="font-medium">{tool.name}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

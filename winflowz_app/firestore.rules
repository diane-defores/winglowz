rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasWinFlowzAppAccess(userId) {
      return isOwner(userId) &&
          exists(/databases/$(database)/documents/suiteAccess/$(userId)) &&
          get(/databases/$(database)/documents/suiteAccess/$(userId)).data.products.winflowz_app.active == true;
    }

    function hasValidRetentionHours(payload) {
      return !('retentionHours' in payload) ||
          (payload.retentionHours is int &&
            (payload.retentionHours in [1, 12, 24, 72, 168]));
    }

    function hasValidThemeMode(payload) {
      return !('themeMode' in payload) ||
          (payload.themeMode is string &&
            (payload.themeMode in ['system', 'light', 'dark']));
    }

    function hasSafeClientEventMetadata(payload) {
      return !('metadata' in payload) ||
          (payload.metadata is map &&
            !payload.metadata.keys().hasAny(
              ['rawText', 'audioBytes', 'audioBase64', 'transcript', 'providerPayload', 'openaiKey', 'anthropicKey']));
    }

    function isDefaultKeyboardConfig(configId) {
      return configId == 'default';
    }

    function hasKeyboardConfigAllowedKeys(payload) {
      return payload.keys().hasOnly([
        'schemaVersion',
        'profileRevision',
        'baseCloudRevision',
        'updatedAt',
        'updatedByDeviceId',
        'sourcePlatform',
        'sanitizationPolicy',
        'checksum',
        'payload',
        'lastSyncedAt',
      ]);
    }

    function hasKeyboardConfigRequiredKeys(payload) {
      return payload.keys().hasAll([
        'schemaVersion',
        'profileRevision',
        'baseCloudRevision',
        'updatedAt',
        'updatedByDeviceId',
        'sourcePlatform',
        'sanitizationPolicy',
        'checksum',
        'payload',
      ]);
    }

    function hasKeyboardSyncV1Header(payload) {
      return payload.schemaVersion == 1 &&
        payload.sanitizationPolicy == 'keyboard_sync_v1';
    }

    function hasKeyboardConfigBoundedRevisions(payload) {
      return payload.profileRevision is int &&
        payload.baseCloudRevision is int &&
        payload.profileRevision >= 0 &&
        payload.baseCloudRevision >= 0 &&
        payload.profileRevision <= 1000000 &&
        payload.baseCloudRevision <= 1000000;
    }

    function hasKeyboardConfigBoundedStrings(payload) {
      return payload.updatedAt is string &&
        payload.updatedAt.size() >= 10 &&
        payload.updatedAt.size() <= 64 &&
        payload.updatedByDeviceId is string &&
        payload.updatedByDeviceId.size() >= 1 &&
        payload.updatedByDeviceId.size() <= 128 &&
        payload.sourcePlatform is string &&
        payload.sourcePlatform.size() >= 2 &&
        payload.sourcePlatform.size() <= 32 &&
        payload.checksum is string &&
        payload.checksum.size() >= 32 &&
        payload.checksum.size() <= 128;
    }

    function hasSafeKeyboardPayloadMap(payload) {
      return payload.payload is map &&
        !payload.payload.keys().hasAny([
          'recents',
          'clipboard',
          'clipboardHistory',
          'diagnostics',
          'voiceArtifacts',
          'rawVoiceArtifacts',
          'token',
          'tokens',
          'secret',
          'secrets',
          'jwt',
          'providerPayload',
          'openaiKey',
          'anthropicKey',
          'imageBytes',
          'imagePath',
          'localImagePath',
          'privatePaths',
        ]);
    }

    function hasValidKeyboardConfig(payload) {
      return hasKeyboardConfigAllowedKeys(payload) &&
        hasKeyboardConfigRequiredKeys(payload) &&
        hasKeyboardSyncV1Header(payload) &&
        hasKeyboardConfigBoundedRevisions(payload) &&
        hasKeyboardConfigBoundedStrings(payload) &&
        hasSafeKeyboardPayloadMap(payload);
    }

    match /users/{uid} {
      allow read, write: if false;

      match /settings/{settingId} {
        allow read: if hasWinFlowzAppAccess(uid);
        allow create, update: if hasWinFlowzAppAccess(uid) &&
          hasValidThemeMode(request.resource.data) &&
          hasValidRetentionHours(request.resource.data) &&
          hasSafeClientEventMetadata(request.resource.data);
        allow delete: if hasWinFlowzAppAccess(uid);
      }

      match /clipboardItems/{itemId} {
        allow read: if hasWinFlowzAppAccess(uid);
        allow create, update: if hasWinFlowzAppAccess(uid) && hasValidRetentionHours(request.resource.data);
        allow delete: if hasWinFlowzAppAccess(uid);
      }

      match /transcriptions/{transcriptionId} {
        allow read: if hasWinFlowzAppAccess(uid);
        allow create, update: if hasWinFlowzAppAccess(uid) && hasValidRetentionHours(request.resource.data);
        allow delete: if hasWinFlowzAppAccess(uid);
      }

      match /snippets/{snippetId} {
        allow read: if hasWinFlowzAppAccess(uid);
        allow create, update: if hasWinFlowzAppAccess(uid) && hasValidRetentionHours(request.resource.data);
        allow delete: if hasWinFlowzAppAccess(uid);
      }

      match /dictionaryTerms/{termId} {
        allow read: if hasWinFlowzAppAccess(uid);
        allow create, update: if hasWinFlowzAppAccess(uid) && hasValidRetentionHours(request.resource.data);
        allow delete: if hasWinFlowzAppAccess(uid);
      }

      match /clientEvents/{eventId} {
        allow read: if hasWinFlowzAppAccess(uid);
        allow create, update: if hasWinFlowzAppAccess(uid) &&
          hasValidRetentionHours(request.resource.data) &&
          hasSafeClientEventMetadata(request.resource.data);
        allow delete: if hasWinFlowzAppAccess(uid);
      }

      match /keyboardConfigs/{configId} {
        allow read: if hasWinFlowzAppAccess(uid) && isDefaultKeyboardConfig(configId);
        allow create, update: if hasWinFlowzAppAccess(uid) &&
          isDefaultKeyboardConfig(configId) &&
          hasValidKeyboardConfig(request.resource.data);
        allow delete: if false;
      }
    }

    match /suiteAccess/{uid} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

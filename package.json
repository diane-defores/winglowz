{
  "name": "winflowz",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "clean": "rimraf dist .vercel/output node_modules/.vite",
    "typecheck": "set NODE_OPTIONS=\"--max-old-space-size=4096\" && astro check --tsconfig ./tsconfig.json",
    "build:check": "astro check --tsconfig ./tsconfig.json",
    "build:analyze": "set NODE_OPTIONS=\"--max-old-space-size=4096\" && astro build --analyze",
    "build:astro": "set NODE_OPTIONS=\"--max-old-space-size=4096\" && astro build",
    "build:debug": "set NODE_OPTIONS=\"--inspect --inspect-brk\" && astro build",
    "build": "set NODE_OPTIONS=\"--max-old-space-size=4096\" && astro build --force",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:integration": "pnpm build && vitest run tests/auth/integration",
    "test:e2e": "pnpm build && playwright test",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/vercel": "^10.0.6",
    "@clerk/astro": "^3.1.0",
    "@heroicons/react": "^2.2.0",
    "@polar-sh/sdk": "^0.43.1",
    "@preline/accordion": "^2.6.0",
    "@preline/collapse": "^2.6.0",
    "@preline/dropdown": "^2.6.0",
    "@preline/overlay": "^2.6.0",
    "@preline/tabs": "^2.6.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/cors": "^2.8.19",
    "@vercel/nft": "^1.3.0",
    "astro-compress": "^2.3.9",
    "astro-compressor": "^1.2.0",
    "astro-vtbot": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "clipboard": "^2.0.11",
    "clsx": "^2.1.1",
    "convex": "^1.31.7",
    "globby": "^16.1.0",
    "html-minifier-terser": "^7.2.0",
    "lenis": "^1.3.17",
    "lucide-react": "^0.563.0",
    "preline": "^2.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.2",
    "rimraf": "^6.1.2",
    "sharp": "^0.34.5",
    "sharp-ico": "^0.1.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/node": "10.0.6",
    "@astrojs/react": "^5.0.4",
    "@astrojs/vue": "^6.0.1",
    "@phosphor-icons/web": "^2.1.2",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/forms": "^0.5.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "astro": "6.2.1",
    "astro-icon": "^1.1.5",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.2.3",
    "jsdom": "^27.4.0",
    "msw": "^2.12.7",
    "nanoid": "^5.1.6",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "remark-directive": "^4.0.0",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": "6.3.0",
      "svix": "1.92.2",
      "yaml": "2.8.4"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}

---
import MainLayout from '@/layouts/MainLayout.astro'
import HeroSection from '@components/sections/landing/HeroSection.astro'
import HeroSectionAlt from '@components/sections/landing/HeroSectionAlt.astro'
import ClientsSection from '@components/sections/landing/ClientsSection.astro'
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro'
import FeaturesNavs from '@components/sections/features/FeaturesNavs.astro'
import TestimonialsSection from '@components/sections/testimonials/TestimonialsSection.astro'
import PricingSection from '@components/sections/pricing/PricingSection.astro'
import FAQ from '@components/sections/misc/FAQ.astro'
import heroImage from '@/assets/images/WinGlowz.png'
import featureImage from '@/assets/images/WinGlowz.png'
import windowsTools from '@/assets/images/WinGlowz.png'
import tools from '@/assets/images/WinGlowz.png'
import dashboard from '@/assets/images/WinGlowz.png'
import { useTranslations } from '@/utils/i18n'
import type { Language } from '@/types/i18n'
import { getLocalizedSiteUrl } from '@/constants'

interface FeatureItem {
	title: string
	description: string
}

interface FeaturesData {
	[key: string]: FeatureItem
}

export function getStaticPaths() {
	return [
		{ params: { lang: undefined } }, // Pour la version anglaise sans préfixe
		{ params: { lang: 'fr' } }, // Pour la version française avec préfixe
	]
}

const { lang: paramLang = 'en' } = Astro.params
const lang = paramLang as Language

// Rediriger la racine vers la version anglaise
if (Astro.url.pathname === '/') {
	return Astro.redirect('/')
}

const t = await useTranslations(lang, 'home')
console.log('Translation data:', JSON.stringify(t, null, 2))
console.log('Testimonials data:', JSON.stringify(t.testimonials, null, 2))

const featuresData = (await useTranslations(lang, 'features')) as FeaturesData

const features = Object.entries(featuresData).map(([key, value]) => ({
	heading: value.title,
	content: value.description,
	svg: key,
}))

const avatarSrcs: Array<string> = [
	'https://dynapictures.com/images/team/AlexDesktop.png',
	'https://i.pinimg.com/280x280_RS/cc/50/8a/cc508a8695c6264be42cdcd698181397.jpg',
	'https://images.unsplash.com/photo-1541101767792-f9b2b1c4f127?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&&auto=format&fit=facearea&facepad=3&w=300&h=300&q=80',
	'https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80',
]

// Définir un témoignage par défaut
const defaultTestimonial = {
	content:
		"Congratulations, Diane! I just spent 20 minutes in it and l'm already wondering what I've been doing with my life until now :)) Lots of goodies to improve my work. I love it!",
	author: 'Florin Muresan',
	role: 'CEO and Co-Founder | Squirrly',
	avatarSrc:
		'https://www.squirrly.co/media/2018/09/1516612623-7888933-109x109x119x109x5x0-Screenshot-2016-09-1.png',
}

// Vérifier et préparer les statistiques
const statistics = t.testimonials?.statistics || []
const hasValidStats = Array.isArray(statistics) && statistics.length > 0

if (!hasValidStats) {
	console.error('Statistiques invalides:', {
		hasTestimonials: !!t.testimonials,
		hasStatistics: !!t.testimonials?.statistics,
		statisticsType: typeof t.testimonials?.statistics,
		isArray: Array.isArray(t.testimonials?.statistics),
		length: t.testimonials?.statistics?.length,
	})
}
---

<MainLayout
	title={t.title}
	meta={{
		description: t.meta.description,
	}}
	lang={lang}
	structuredData={{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		'@id': getLocalizedSiteUrl(lang, '/'),
		url: getLocalizedSiteUrl(lang, '/'),
		name: t.title,
		description: t.meta.description,
		inLanguage: lang,
	}}
>
	<HeroSection
		title={t.hero.title}
		subTitle={t.hero.subTitle}
		primaryBtn={t.hero.primaryBtn}
		primaryBtnURL={t.hero.primaryBtnURL}
		secondaryBtn={t.hero.secondaryBtn}
		withReview={true}
		avatars={avatarSrcs}
		rating={t.hero.rating}
		starCount={t.hero.starCount}
		reviews={t.hero.reviews}
		src={heroImage}
		alt="Stack of WinGlows product boxes containing assorted productivity tools"
	/>

	<ClientsSection title={t.clients.title} subTitle={t.clients.subTitle} />

	<FeaturesGeneral
		title={t.features.title}
		subTitle={t.features.subTitle}
		src={featureImage}
		alt="WinGlows products in floating boxes"
		features={features}
	/>

	<FeaturesNavs
		title={t.workflow.title}
		tabs={[
			{
				heading: t.workflow.tabs[0].heading,
				content: t.workflow.tabs[0].content,
				svg: 'tools',
				src: tools,
				alt: 'Productivity tools illustration',
				first: true,
			},
			{
				heading: t.workflow.tabs[1].heading,
				content: t.workflow.tabs[1].content,
				svg: 'dashboard',
				src: dashboard,
				alt: 'Dashboard interface screenshot',
				second: true,
			},
			{
				heading: t.workflow.tabs[2].heading,
				content: t.workflow.tabs[2].content,
				svg: 'house',
				src: windowsTools,
				alt: 'Windows tools illustration',
			},
		]}
	/>

	<TestimonialsSection
		title={t.testimonials.title}
		subTitle={t.testimonials.subTitle}
		testimonials={[defaultTestimonial]}
		statistics={hasValidStats ? statistics : []}
	/>

	<PricingSection />

	<FAQ />

	<HeroSectionAlt
		title={t.cta.title}
		subTitle={t.cta.subTitle}
		url={`/${lang === 'fr' ? 'fr/' : ''}produits`}
	/>
</MainLayout>

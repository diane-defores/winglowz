# App
SITE=https://winglowz.com
PUBLIC_SITE_URL=https://winglowz.com
PUBLIC_CONVEX_URL=https://your-project.convex.cloud
SUITE_API_ALLOWED_ORIGINS=https://winglowz.com,https://www.winglowz.com,https://your-winglowz-app-domain.example
PORT=3011

# Firebase Admin (bridge API)
# Option A (recommended): JSON service account string (single-line JSON)
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: split service account fields
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Clerk
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Shared bridge secret between Astro API and Convex
SUITE_BRIDGE_CONVEX_SECRET=your_bridge_secret_here
# Firebase bridge always enforces revoked/disabled session rejection server-side (no env toggle).
# Optional dedicated secret for internal sync endpoint auth (falls back to SUITE_BRIDGE_CONVEX_SECRET)
SUITE_BRIDGE_SYNC_SECRET=
# Convex webhook runtime URL for Astro internal bridge sync endpoint
SUITE_BRIDGE_SYNC_URL=https://winglowz.com/api/bridge/sync
# ReplayGlowz product token signing (RS256, private key PEM PKCS8; escaped newlines accepted)
REPLAYGLOWZ_PRODUCT_JWT_PRIVATE_KEY_PEM=
REPLAYGLOWZ_PRODUCT_JWT_KEY_ID=replayglowz-suite-2026-06-02
REPLAYGLOWZ_PRODUCT_JWT_ISSUER=https://winglowz.com
REPLAYGLOWZ_PRODUCT_JWT_AUDIENCE=replayglowz-convex
REPLAYGLOWZ_PRODUCT_JWT_PUBLIC_KEY_JWK=
REPLAYGLOWZ_PRODUCT_JWT_PUBLIC_KEY_PEM=

# Polar
POLAR_ACCESS_TOKEN=pol_xxx
POLAR_PRODUCT_ID=product_xxx
POLAR_WINGLOWZ_PRODUCT_ID=product_xxx
POLAR_WEBHOOK_SECRET=whsec_xxx
POLAR_SERVER=production

# Lemon Squeezy (direct LTD checkout)
LEMONSQUEEZY_API_URL=https://api.lemonsqueezy.com
LEMONSQUEEZY_API_KEY=lsv2_xxx
LEMONSQUEEZY_STORE_ID=store_xxx
LEMONSQUEEZY_SOCIALGLOWZ_PRODUCT_ID=prod_xxx
LEMONSQUEEZY_SOCIALGLOWZ_LIFETIME_DEAL_VARIANT_ID=variant_xxx
LEMONSQUEEZY_WINGLOWZ_APP_PRODUCT_ID=prod_xxx
LEMONSQUEEZY_WINGLOWZ_APP_FOCUS_VARIANT_ID=variant_xxx
LEMONSQUEEZY_WINGLOWZ_APP_POWER_VARIANT_ID=variant_xxx
LEMONSQUEEZY_WINGLOWZ_APP_CONTROL_VARIANT_ID=variant_xxx
LEMONSQUEEZY_WINGLOWZ_APP_COMMAND_VARIANT_ID=variant_xxx
LEMONSQUEEZY_WEBHOOK_SECRET=whsec_xxx
COMMERCE_PROVIDER_ORDER=lemonsqueezy,polar

# Resend
RESEND_API_KEY=re_xxx
RESEND_AUDIENCE_ID=audience_xxx

# Gemini CLI / rewrite + OCR for /temu
GEMINI_API_KEY=
# Optional explicit path if gemini is not on PATH
GEMINI_BIN=

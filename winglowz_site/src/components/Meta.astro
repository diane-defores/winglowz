---
import { getImage } from 'astro:assets'
import { OG, SEO, SITE, SITE_VISUAL_TOKENS } from '@/constants'
import faviconSrc from '@/assets/images/WinGlowz.png'
import { getDefaultLocalePath, getLocalizedPath } from '@/utils/i18n'

// Default properties for the Meta component
const defaultProps = {
	meta: SITE.description,
	structuredData: SEO.structuredData,
}

const {
	meta = defaultProps.meta,
	title,
	lang = 'en',
	structuredData = defaultProps.structuredData,
	noindex = false,
	alternateUrls,
} = Astro.props

const metaObject =
	typeof meta === 'object' && meta !== null
		? (meta as { title?: string; description?: string; canonicalURL?: string })
		: undefined
const metaDescription =
	typeof meta === 'string' ? meta : metaObject?.description ?? defaultProps.meta
const metaTitle = metaObject?.title ?? title ?? OG.title

// Define the metadata for your website and individual pages
const siteUrl = `${Astro.site}`
const author = SITE.author
const canonical =
	metaObject?.canonicalURL ?? new globalThis.URL(Astro.url.pathname, Astro.site).toString()
const ogTitle = metaTitle
const ogDescription = metaDescription
const socialImageRes = await getImage({
	src: OG.image,
	width: SITE_VISUAL_TOKENS.socialImage.width,
	height: SITE_VISUAL_TOKENS.socialImage.height,
})
const socialImage = new globalThis.URL(socialImageRes.src, Astro.site).toString()

const localizedPath = Astro.url.pathname.replace(/^\/fr(?=\/|$)/, '') || '/'
const sourcePath = await getDefaultLocalePath(lang, localizedPath)
const alternatePaths = await Promise.all(
	(['en', 'fr'] as const).map(async (targetLang) => ({
		lang: targetLang,
		href: `${siteUrl.slice(0, -1)}${await getLocalizedPath(targetLang, sourcePath)}`,
	})),
)
const resolvedAlternatePaths = alternateUrls
	? (['en', 'fr'] as const)
			.filter((targetLang) => alternateUrls[targetLang])
			.map((targetLang) => ({ lang: targetLang, href: alternateUrls[targetLang]! }))
	: alternatePaths
const alternateLanguageLinks = [
	...resolvedAlternatePaths,
	{ lang: 'x-default', href: resolvedAlternatePaths.find((item) => item.lang === 'en')?.href ?? canonical },
]
	.map(({ lang: alternateLang, href }) => `<link rel="alternate" hreflang="${alternateLang}" href="${href}" />`)
	.join('\n')

const favicon = await getImage({
	src: faviconSrc,
	format: 'png',
	width: SITE_VISUAL_TOKENS.manifestIcons.sizes[0],
	height: SITE_VISUAL_TOKENS.manifestIcons.sizes[0],
})
---

<!-- Inject structured data -->{
	structuredData && (
		<script
			is:inline
			type="application/ld+json"
			set:html={JSON.stringify(structuredData)}
		/>
	)
}

<!-- Meta tags -->
<meta charset="utf-8" />
<meta content={metaDescription} name="description" />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<meta name="web_author" content={author} />
<meta
	name="viewport"
	content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=1.0"
/>
<meta http-equiv="X-UA-Compatible" content="ie=edge" />
<link rel="canonical" href={canonical} />
<Fragment set:html={alternateLanguageLinks} />

<!-- Facebook Meta Tags -->
<meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content="website" />
<meta property="og:title" content={ogTitle} />
<meta property="og:site_name" content={SITE.title} />
<meta property="og:description" content={ogDescription} />
<meta property="og:image" content={socialImage} />
<meta
	content={SITE_VISUAL_TOKENS.socialImage.width.toString()}
	property="og:image:width"
/>
<meta
	content={SITE_VISUAL_TOKENS.socialImage.height.toString()}
	property="og:image:height"
/>
<meta content={SITE_VISUAL_TOKENS.socialImage.type} property="og:image:type" />

<!-- Twitter Meta Tags -->
<meta
	name="twitter:card"
	content={SITE_VISUAL_TOKENS.themeMeta.twitterCard}
/>
<meta property="twitter:domain" content={new globalThis.URL(siteUrl).hostname} />
<meta property="twitter:url" content={canonical} />
<meta name="twitter:title" content={ogTitle} />
<meta name="twitter:description" content={ogDescription} />
<meta name="twitter:image" content={socialImage} />

<!-- Links to the webmanifest and sitemap -->
<link rel="manifest" href="/manifest.json" />
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Links for favicons -->
<link href="/favicon.ico" rel="icon" sizes="any" type="image/x-icon" />
<link href={favicon.src} rel="icon" type="image/png" sizes="32x32" />
<meta name="mobile-web-app-capable" content="yes" />
<link href={favicon.src} rel="shortcut icon" />

<!-- Theme color -->
<meta name="theme-color" content={SITE_VISUAL_TOKENS.themeMeta.website} />

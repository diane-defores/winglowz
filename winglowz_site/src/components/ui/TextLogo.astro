---
interface Props {
  class?: string
  style?: string
}

const { class: className, style } = Astro.props
---

<div class:list={['text-logo', className]} style={style}>
  <span class="text">WinGlowz</span>
  <div class="glow-effect"></div>
</div>

<script>
  const logos = document.querySelectorAll<HTMLElement>('.text-logo')

  document.addEventListener('mousemove', (e: MouseEvent) => {
    logos.forEach((card) => {
      const text = card.querySelector<HTMLElement>('.text')
      const glow = card.querySelector<HTMLElement>('.glow-effect')

      if (!text || !glow) return

      const rect = card.getBoundingClientRect()
      const cardCenterX = rect.left + rect.width / 2
      const cardCenterY = rect.top + rect.height / 2

      const distanceX = e.clientX - cardCenterX
      const distanceY = e.clientY - cardCenterY

      const maxDistance = 500
      const rotateX = Math.min(
        Math.max((distanceY / maxDistance) * 12, -12),
        12
      )
      const rotateY = Math.min(
        Math.max((-distanceX / maxDistance) * 12, -12),
        12
      )

      requestAnimationFrame(() => {
        card.style.transform = `perspective(1000px) rotateX(${rotateX * 0.5}deg) rotateY(${rotateY * 0.5}deg)`
        text.style.transform = `translateZ(20px) rotateX(${rotateX * 0.8}deg) rotateY(${rotateY * 0.8}deg)`
        glow.style.transform = `translateZ(10px) rotateX(${rotateX * 0.2}deg) rotateY(${rotateY * 0.2}deg)`
      })
    })
  })

  document.addEventListener('mouseleave', () => {
    logos.forEach((card) => {
      const text = card.querySelector<HTMLElement>('.text')
      const glow = card.querySelector<HTMLElement>('.glow-effect')

      if (!text || !glow) return

      requestAnimationFrame(() => {
        card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0)'
        text.style.transform = 'translateZ(0) rotateX(0) rotateY(0)'
        glow.style.transform = 'translateZ(0) rotateX(0) rotateY(0)'
      })
    })
  })
</script>

<!-- Styles in global.css @layer components (.text-logo) -->

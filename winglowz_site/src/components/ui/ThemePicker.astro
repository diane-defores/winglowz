<!-- Dark Theme Toggle Button -->
<button
	type="button"
	aria-label="Basculer vers le thème sombre"
	class="flex h-9 w-9 items-center justify-center rounded-full font-medium text-neutral-700 outline-none ring-zinc-500 transition duration-300 hover:bg-navbar-bg-hover hover:text-navbar-textPrimary hs-dark-mode-active:hidden dark:text-zinc-300 dark:ring-zinc-200 dark:hover:bg-navbar-bg-hover dark:hover:text-navbar-textPrimary dark:focus:outline-none"
	data-hs-theme-click-value="dark"
>
	<svg
		class="h-5 w-5 flex-shrink-0"
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
	>
		<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
	</svg>
</button>

<!-- Light Theme Toggle Button -->
<button
	type="button"
	aria-label="Basculer vers le thème clair"
	class="hidden h-9 w-9 items-center justify-center rounded-full font-medium text-neutral-700 outline-none ring-zinc-500 transition duration-300 hover:bg-navbar-bg-hover hover:text-navbar-textPrimary hs-dark-mode-active:flex dark:text-zinc-300 dark:ring-zinc-200 dark:hover:bg-navbar-bg-hover dark:hover:text-navbar-textPrimary dark:focus:outline-none"
	data-hs-theme-click-value="light"
>
	<svg
		class="h-5 w-5 flex-shrink-0"
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
	>
		<circle cx="12" cy="12" r="4"></circle>
		<path d="M12 8a2 2 0 1 0 4 4"></path>
		<path d="M12 2v2"></path>
		<path d="M12 20v2"></path>
		<path d="m4.93 4.93 1.41 1.41"></path>
		<path d="m17.66 17.66 1.41 1.41"></path>
		<path d="M2 12h2"></path>
		<path d="M20 12h2"></path>
		<path d="m6.34 17.66-1.41 1.41"></path>
		<path d="m19.07 4.93-1.41 1.41"></path>
	</svg>
</button>

<script>
	// Définition du type Theme
	type Theme = 'light' | 'dark'

	const THEME_SELECTOR = '[data-hs-theme-click-value]'
	let systemThemeListenerBound = false

	// Fonction pour appliquer le thème
	function applyTheme(theme: Theme) {
		const root = document.documentElement

		// Supprimer toutes les classes de thème
		root.classList.remove('dark', 'light')

		// Appliquer le nouveau thème
		root.classList.add(theme)

		// Mettre à jour l'attribut data-theme pour le thème global
		root.setAttribute('data-theme', theme)

		// Sauvegarder le thème
		localStorage.setItem('hs_theme', theme)

		// Mettre à jour les boutons
		document
			.querySelectorAll(THEME_SELECTOR)
			.forEach((button) => {
				const buttonTheme = button.getAttribute(
					'data-hs-theme-click-value'
				) as Theme
				if (buttonTheme === theme) {
					button.classList.add('hidden')
				} else {
					button.classList.remove('hidden')
				}
			})

	}

	function initThemePicker() {
		const savedTheme = localStorage.getItem('hs_theme') as Theme | null
		const systemTheme = window.matchMedia('(prefers-color-scheme: dark)')
			.matches
			? 'dark'
			: 'light'
		const theme = savedTheme || systemTheme

		applyTheme(theme)

		document.querySelectorAll(THEME_SELECTOR).forEach((button) => {
			if ((button as HTMLElement).dataset.themeBound === 'true') return

			button.addEventListener('click', () => {
				const newTheme = button.getAttribute(
					'data-hs-theme-click-value'
				) as Theme
				applyTheme(newTheme)
			})

			;(button as HTMLElement).dataset.themeBound = 'true'
		})

		if (!systemThemeListenerBound) {
			window
				.matchMedia('(prefers-color-scheme: dark)')
				.addEventListener('change', (e) => {
					if (!localStorage.getItem('hs_theme')) {
						applyTheme(e.matches ? 'dark' : 'light')
					}
				})
			systemThemeListenerBound = true
		}
	}

	// Initialisation au chargement de la page
	initThemePicker()
	document.addEventListener('astro:page-load', initThemePicker)
</script>

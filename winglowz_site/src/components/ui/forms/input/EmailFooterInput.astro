---
const {
  label = "Search",
  title = Astro.currentLocale === "fr" ? "S'abonner" : "Subscribe",
  id = "footer-input",
} = Astro.props;

interface Props {
  label?: string;
  title?: string;
  id?: string;
}

const placeholder = Astro.currentLocale === "fr" ? "Entrez votre email" : "Enter your email";
const successMsg = Astro.currentLocale === "fr" ? "Merci ! Vous etes inscrit(e)." : "Thanks! You're subscribed.";
const errorMsg = Astro.currentLocale === "fr" ? "Erreur. Veuillez reessayer." : "Something went wrong. Please try again.";
---

<form id="newsletter-form" data-lang={Astro.currentLocale === "fr" ? "fr" : "en"} class="mt-4 flex flex-col items-center gap-2 rounded-lg bg-neutral-200 p-2 dark:bg-neutral-800 sm:flex-row sm:gap-3">
  <div class="w-full">
    <label for={id} class="sr-only">{label}</label>
    <input
      type="email"
      id={id}
      name="email"
      required
      class="block w-full rounded-lg border-transparent bg-neutral-100 px-4 py-3 text-neutral-600 focus:border-magenta focus:ring-magenta disabled:pointer-events-none disabled:opacity-50 dark:border-transparent dark:bg-neutral-700 dark:text-gray-300 dark:placeholder:text-neutral-300 caret-magenta"
      placeholder={placeholder}
    />
  </div>
  <button
    type="submit"
    class="inline-flex w-full items-center justify-center gap-x-2 whitespace-nowrap rounded-lg border border-transparent bg-magenta p-3 font-bold text-neutral-50 outline-none ring-zinc-500 transition duration-300 hover:opacity-90 focus-visible:ring disabled:pointer-events-none disabled:opacity-50 dark:ring-zinc-200 dark:focus:outline-none dark:focus:ring-1 sm:w-auto"
    data-track="newsletter-subscribe"
  >
    {title}
  </button>
</form>
<p id="newsletter-success" class="mt-2 hidden text-sm text-green">{successMsg}</p>
<p id="newsletter-error" class="mt-2 hidden text-sm text-red">{errorMsg}</p>

<script>
  const newsletterForm = document.getElementById('newsletter-form') as HTMLFormElement | null;
  newsletterForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const emailInput = newsletterForm.querySelector('input[type="email"]') as HTMLInputElement;
    const email = emailInput?.value;
    const successEl = document.getElementById('newsletter-success');
    const errorEl = document.getElementById('newsletter-error');
    const submitBtn = newsletterForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    const currentLang = newsletterForm.dataset.lang === 'fr' ? 'fr' : 'en';

    if (!email) return;

    // Disable form while submitting
    submitBtn.disabled = true;
    emailInput.disabled = true;

    try {
      const res = await fetch('/api/newsletter/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: 'footer', lang: currentLang }),
      });

      if (res.ok) {
        if (successEl) {
          successEl.classList.remove('hidden');
          errorEl?.classList.add('hidden');
          emailInput.value = '';
          setTimeout(() => successEl.classList.add('hidden'), 5000);
        }
      } else {
        errorEl?.classList.remove('hidden');
        successEl?.classList.add('hidden');
        setTimeout(() => errorEl?.classList.add('hidden'), 5000);
      }
    } catch {
      errorEl?.classList.remove('hidden');
      successEl?.classList.add('hidden');
      setTimeout(() => errorEl?.classList.add('hidden'), 5000);
    } finally {
      submitBtn.disabled = false;
      emailInput.disabled = false;
    }
  });
</script>

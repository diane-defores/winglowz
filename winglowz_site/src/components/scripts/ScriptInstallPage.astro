---
import MainLayout from '@/layouts/MainLayout.astro'
import { getLocalizedSiteUrl } from '@/constants'
import type { Language } from '@/types'
import type { ScriptInstallPageContent } from '@/data/scriptInstallPages'

interface Props {
	lang: Language
	page: ScriptInstallPageContent
}

const { lang, page } = Astro.props
const canonicalPath = `/${page.slug}`
const accentClasses = {
	cyan: {
		text: 'text-cyan-500 dark:text-cyan-300',
		border: 'border-cyan-300/70 dark:border-cyan-500/40',
		bg: 'bg-cyan-500',
		soft: 'bg-cyan-50 text-cyan-900 dark:bg-cyan-950/40 dark:text-cyan-100',
	},
	magenta: {
		text: 'text-fuchsia-500 dark:text-fuchsia-300',
		border: 'border-fuchsia-300/70 dark:border-fuchsia-500/40',
		bg: 'bg-fuchsia-500',
		soft: 'bg-fuchsia-50 text-fuchsia-900 dark:bg-fuchsia-950/40 dark:text-fuchsia-100',
	},
	green: {
		text: 'text-emerald-600 dark:text-emerald-300',
		border: 'border-emerald-300/70 dark:border-emerald-500/40',
		bg: 'bg-emerald-500',
		soft: 'bg-emerald-50 text-emerald-900 dark:bg-emerald-950/40 dark:text-emerald-100',
	},
}[page.accent]

const surfaceCardClasses =
	'rounded-3xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-900'
---

<MainLayout
	title={`${page.name} | WinGlows`}
	meta={{
		title: `${page.name} | WinGlows`,
		description: page.description,
		canonicalURL: getLocalizedSiteUrl(lang, canonicalPath),
		image: '/images/WinGlowz.png',
	}}
	lang={lang}
	structuredData={{
		'@context': 'https://schema.org',
		'@type': 'SoftwareApplication',
		name: page.name,
		description: page.description,
		applicationCategory: 'DeveloperApplication',
		operatingSystem: page.slug === 'termux' ? 'Android' : 'Linux',
		url: getLocalizedSiteUrl(lang, canonicalPath),
		codeRepository: page.githubUrl,
	}}
>
	<section class="script-hero relative isolate overflow-hidden rounded-3xl border border-neutral-200 bg-neutral-950 px-5 py-10 text-white shadow-2xl dark:border-neutral-800 sm:px-8 lg:px-12">
		<img
			src="/images/WinGlowz.png"
			alt=""
			aria-hidden="true"
			class="absolute right-0 top-0 -z-10 h-full w-full object-cover opacity-18 mix-blend-screen"
			loading="eager"
		/>
		<div class="absolute inset-0 -z-10 bg-gradient-to-br from-magenta/25 via-neutral-950 to-cyan/20"></div>

		<div class="grid gap-8 lg:grid-cols-2 lg:items-center">
			<div class="max-w-3xl">
				<p class={`mb-4 inline-flex rounded-full border ${accentClasses.border} bg-white/10 px-3 py-1 text-sm font-semibold uppercase tracking-widest ${accentClasses.text}`}>
					{page.kicker}
				</p>
				<h1 class="max-w-4xl text-4xl font-bold leading-none tracking-normal text-white sm:text-5xl lg:text-6xl">
					{page.title}
				</h1>
				<p class="mt-5 max-w-2xl text-base leading-7 text-neutral-200 sm:text-lg">
					{page.description}
				</p>
				<div class="mt-7 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
					<button
						type="button"
						class="copy-command inline-flex min-h-12 items-center justify-center rounded-lg bg-white px-5 text-sm font-semibold text-neutral-950 transition hover:bg-neutral-200"
						data-copy-command={page.command}
						data-copy-label={page.copyLabel}
						data-copied-label={page.copiedLabel}
					>
						{page.copyLabel}
					</button>
					<a
						href={page.rawScriptUrl}
						class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/20 px-5 text-sm font-semibold text-white transition hover:bg-white/10"
					>
						{page.rawScriptLabel}
					</a>
					<a
						href={page.githubUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/20 px-5 text-sm font-semibold text-white transition hover:bg-white/10"
					>
						{page.githubLabel}
					</a>
				</div>
			</div>

			<div class="terminal-visual rounded-3xl border border-white/20 bg-black/80 shadow-2xl">
				<div class="flex items-center justify-between border-b border-white/10 px-4 py-3">
					<div class="flex gap-2" aria-hidden="true">
						<span class="h-3 w-3 rounded-full bg-red-400"></span>
						<span class="h-3 w-3 rounded-full bg-yellow-300"></span>
						<span class="h-3 w-3 rounded-full bg-emerald-400"></span>
					</div>
					<span class="text-xs font-semibold uppercase tracking-widest text-neutral-400">{page.visualLabel}</span>
				</div>
				<div class="space-y-4 p-4 font-mono text-sm">
					<pre class="overflow-x-auto whitespace-pre-wrap break-words rounded-lg bg-white/5 p-4 text-cyan-100"><code>{page.command}</code></pre>
					<div class="space-y-2 text-neutral-300">
						{page.terminalLines.map((line) => <p class="m-0 text-sm leading-6 text-neutral-300">$ {line}</p>)}
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="grid gap-5 py-8 lg:grid-cols-3">
		<article class={surfaceCardClasses}>
			<h2 class="text-2xl font-bold tracking-normal text-neutral-900 dark:text-white">{page.fitTitle}</h2>
			<ul class="mt-5 space-y-3">
				{page.fit.map((item) => (
					<li class="flex gap-3 text-base leading-6 text-neutral-700 dark:text-neutral-300">
						<span class={`mt-2 h-2 w-2 shrink-0 rounded-full ${accentClasses.bg}`}></span>
						<span>{item}</span>
					</li>
				))}
			</ul>
		</article>

		<article class={surfaceCardClasses}>
			<h2 class="text-2xl font-bold tracking-normal text-neutral-900 dark:text-white">{page.installedTitle}</h2>
			<ul class="mt-5 space-y-3">
				{page.installed.map((item) => (
					<li class="flex gap-3 text-base leading-6 text-neutral-700 dark:text-neutral-300">
						<span class="mt-0.5 text-emerald-500">✓</span>
						<span>{item}</span>
					</li>
				))}
			</ul>
		</article>

		<article class={surfaceCardClasses}>
			<h2 class="text-2xl font-bold tracking-normal text-neutral-900 dark:text-white">{page.excludedTitle}</h2>
			<ul class="mt-5 space-y-3">
				{page.excluded.map((item) => (
					<li class="flex gap-3 text-base leading-6 text-neutral-700 dark:text-neutral-300">
						<span class="mt-0.5 text-red-500">×</span>
						<span>{item}</span>
					</li>
				))}
			</ul>
		</article>
	</section>

	<section class={`mb-10 rounded-3xl border ${accentClasses.border} ${accentClasses.soft} p-6`}>
		<div class="grid gap-6 lg:grid-cols-2 lg:items-center">
			<div>
				<h2 class="text-2xl font-bold tracking-normal">{page.linksTitle}</h2>
				<p class="mt-3 text-base leading-7 text-neutral-700 dark:text-neutral-200">{page.installNote}</p>
			</div>
			<div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
				{page.links.map((link) => (
					<a
						href={link.href}
						class="inline-flex min-h-11 items-center justify-center rounded-lg bg-neutral-950 px-4 text-sm font-semibold text-white transition hover:bg-neutral-800 dark:bg-white dark:text-neutral-950 dark:hover:bg-neutral-200"
					>
						{link.label}
					</a>
				))}
			</div>
		</div>
	</section>

	<script>
		document.querySelectorAll<HTMLButtonElement>('.copy-command').forEach((button) => {
			button.addEventListener('click', async () => {
				const command = button.dataset.copyCommand
				if (!command) return

				try {
					await navigator.clipboard.writeText(command)
					button.textContent = button.dataset.copiedLabel || 'Copied'
					window.setTimeout(() => {
						button.textContent = button.dataset.copyLabel || 'Copy command'
					}, 1800)
				} catch {
					button.textContent = command
				}
			})
		})
	</script>
</MainLayout>

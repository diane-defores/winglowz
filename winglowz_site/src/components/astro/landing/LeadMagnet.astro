---
/* Lead Magnet — free resource in exchange for email capture */
import { getLangFromUrl } from '@/utils/i18n'

const lang = getLangFromUrl(Astro.url)

const content = lang === 'fr'
  ? {
      badge: "Ressource Gratuite",
      title: "Top 10 des astuces de productivité Windows",
      sub: "Un guide PDF avec 10 idées Windows utiles pour réduire la friction dès la première semaine. Envoi immédiat par email.",
      placeholder: "Votre email",
      cta: "Recevoir le guide",
      privacy: "Pas de spam. Désabonnement en un clic.",
      success: "Merci ! Vérifiez votre boîte mail.",
      error: "Erreur. Veuillez réessayer.",
    }
  : {
      badge: "Free Resource",
      title: "Top 10 Windows Productivity Hacks",
      sub: "A free PDF with 10 practical Windows ideas to reduce friction. Delivered instantly to your inbox.",
      placeholder: "Your email",
      cta: "Get the Free Guide",
      privacy: "No spam. Unsubscribe in one click.",
      success: "Thanks! Check your inbox.",
      error: "Something went wrong. Please try again.",
    }
---

<section class="bg-neutral-50 dark:bg-black py-16 px-4">
  <div class="reveal max-w-3xl mx-auto">
    <div class="landing-surface relative overflow-hidden rounded-2xl border p-8 sm:p-12">
      <!-- Background glow -->
      <div class="absolute -top-24 -right-24 h-64 w-64 pointer-events-none rounded-full blur-3xl" style="background: radial-gradient(circle, rgb(var(--landing-glow) / 0.15), transparent 70%);"></div>

      <div class="relative z-10 text-center">
        <!-- Badge -->
        <span class="landing-soft-badge mb-6 inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs">
          <svg class="h-3 w-3 text-green" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19.5 21a3 3 0 0 0 3-3v-4.5a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3V18a3 3 0 0 0 3 3h15zM1.5 10.146V6a3 3 0 0 1 3-3h5.379a2.25 2.25 0 0 1 1.59.659l2.122 2.121c.14.141.331.22.53.22H19.5a3 3 0 0 1 3 3v1.146A4.483 4.483 0 0 0 19.5 9h-15a4.483 4.483 0 0 0-3 1.146z"/></svg>
          {content.badge}
        </span>

        <h2 class="mb-4 font-display text-3xl font-bold text-neutral-950 dark:text-white sm:text-4xl">
          {content.title}
        </h2>

        <p class="mx-auto mb-8 max-w-xl text-neutral-600 dark:text-zinc-400">
          {content.sub}
        </p>

        <!-- Email form -->
        <form id="lead-magnet-form" data-lang={lang} class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input
            type="email"
            name="email"
            required
            placeholder={content.placeholder}
            class="flex-1 rounded-full border border-neutral-300 bg-white px-5 py-3 text-sm text-neutral-950 placeholder:text-neutral-400 focus:border-neutral-500 focus:outline-none dark:border-zinc-700 dark:bg-zinc-800 dark:text-white dark:placeholder:text-zinc-500 dark:focus:border-zinc-500"
          />
          <button
            type="submit"
            class="shimmer-btn inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-full bg-neutral-950 px-6 py-3 text-sm font-medium text-white shadow-lg shadow-neutral-950/10 hover:bg-neutral-800 dark:bg-white dark:text-zinc-950 dark:shadow-white/10 dark:hover:bg-zinc-200"
            data-track="lead-magnet-cta"
          >
            {content.cta}
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>
        </form>

        <p id="lead-magnet-success" class="hidden mt-4 text-sm text-green">{content.success}</p>
        <p id="lead-magnet-error" class="hidden mt-4 text-sm text-red">{content.error}</p>

        <p class="mt-4 text-xs text-neutral-500 dark:text-zinc-600">{content.privacy}</p>
      </div>
    </div>
  </div>
</section>

<script>
  const leadForm = document.getElementById('lead-magnet-form') as HTMLFormElement | null;
  leadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const emailInput = leadForm.querySelector('input[type="email"]') as HTMLInputElement;
    const email = emailInput?.value;
    const successEl = document.getElementById('lead-magnet-success');
    const errorEl = document.getElementById('lead-magnet-error');
    const submitBtn = leadForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    const currentLang = leadForm.dataset.lang === 'fr' ? 'fr' : 'en';

    if (!email) return;

    submitBtn.disabled = true;
    emailInput.disabled = true;

    try {
      const res = await fetch('/api/newsletter/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: 'lead-magnet', lang: currentLang }),
      });

      if (res.ok) {
        successEl?.classList.remove('hidden');
        errorEl?.classList.add('hidden');
        emailInput.value = '';
        setTimeout(() => successEl?.classList.add('hidden'), 5000);
      } else {
        errorEl?.classList.remove('hidden');
        successEl?.classList.add('hidden');
        setTimeout(() => errorEl?.classList.add('hidden'), 5000);
      }
    } catch {
      errorEl?.classList.remove('hidden');
      successEl?.classList.add('hidden');
      setTimeout(() => errorEl?.classList.add('hidden'), 5000);
    } finally {
      submitBtn.disabled = false;
      emailInput.disabled = false;
    }
  });
</script>

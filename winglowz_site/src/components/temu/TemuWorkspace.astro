---
interface Props {
  lang: 'fr' | 'en'
}

const { lang } = Astro.props

const copyLabel = lang === 'fr' ? 'Copier la description' : 'Copy description'
const copyAiTitleLabel =
  lang === 'fr' ? "Copier le titre d'annonce" : 'Copy listing title'
const copyAiDescriptionLabel =
  lang === 'fr' ? "Copier l'annonce réécrite" : 'Copy rewritten listing'
const rewriteLabel =
  lang === 'fr' ? "Générer l'annonce de revente" : 'Generate resale listing'
const translateImagesLabel =
  lang === 'fr' ? 'Générer les images traduites' : 'Generate translated images'
const downloadLabel =
  lang === 'fr' ? 'Télécharger toutes les photos' : 'Download all photos'
const intro =
  lang === 'fr'
    ? "Colle une URL produit, récupère la description, télécharge les photos, puis génère une annonce de revente en indiquant que l'article est neuf et que la vente vient d'une erreur de modèle."
    : 'Paste a product URL, recover the description, download all photos, then generate a resale listing saying the item is new and being sold because the wrong model was ordered.'
const title = lang === 'fr' ? 'Assistant Temu' : 'Temu Assistant'
const submitLabel = lang === 'fr' ? 'Extraire' : 'Extract'
const inputLabel = lang === 'fr' ? 'URL produit' : 'Product URL'
const placeholder = 'https://www.temu.com/...'
---

<section class="mx-auto flex w-full max-w-6xl flex-col gap-8 pb-16 pt-4">
  <div class="overflow-hidden rounded-temu border border-neutral-200 bg-white shadow-sm dark:border-zinc-800 dark:bg-zinc-950">
    <div class="relative border-b border-neutral-200 px-6 py-8 dark:border-zinc-800 sm:px-8">
      <div class="absolute inset-0 temu-radial-bg"></div>
      <div class="relative flex flex-col gap-4">
        <span class="w-fit rounded-full border border-neutral-300 bg-neutral-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.28em] text-neutral-700 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-300">
          Temu -> Vinted
        </span>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div class="max-w-3xl">
            <h1 class="font-[var(--font-display)] text-4xl font-bold tracking-tight text-neutral-950 dark:text-white sm:text-5xl">
              {title}
            </h1>

          </div>
          <div class="grid gap-2 text-sm text-neutral-600 dark:text-zinc-400">
            <span>{lang === 'fr' ? 'Description copiable' : 'Copy-ready description'}</span>
            <span>{lang === 'fr' ? 'Photos téléchargeables' : 'Downloadable photos'}</span>
            <span>{lang === 'fr' ? 'Annonce revente + OCR traduits' : 'Resale copy + translated OCR'}</span>
          </div>
        </div>
      </div>
    </div>

    <div class="grid gap-8 px-6 py-8 sm:px-8 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)]">
      <div class="flex flex-col gap-6">
        <form id="temu-form" class="flex flex-col gap-4 rounded-temu-lg border border-neutral-200 bg-neutral-50 p-5 dark:border-zinc-800 dark:bg-zinc-900/70">
          <label for="temu-url" class="text-sm font-semibold text-neutral-800 dark:text-zinc-200">
            {inputLabel}
          </label>
          <div class="flex flex-col gap-3 sm:flex-row">
            <input
              id="temu-url"
              name="url"
              type="url"
              required
              placeholder={placeholder}
              class="min-w-0 flex-1 rounded-2xl border border-neutral-300 bg-white px-4 py-3 text-sm text-neutral-900 outline-none transition focus:border-neutral-900 focus:ring-2 focus:ring-neutral-900/10 dark:border-zinc-700 dark:bg-zinc-950 dark:text-white dark:focus:border-white dark:focus:ring-white/10"
            />
            <button
              type="submit"
              class="rounded-2xl bg-neutral-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-neutral-800 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200"
            >
              {submitLabel}
            </button>
          </div>
          <div class="flex flex-wrap gap-3">
            <button
              id="rewrite-listing"
              type="button"
              disabled
              class="rounded-2xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-700 transition disabled:cursor-not-allowed disabled:opacity-50 hover:border-neutral-900 hover:text-neutral-950 dark:border-zinc-700 dark:text-zinc-200 dark:hover:border-white dark:hover:text-white"
            >
              {rewriteLabel}
            </button>
            <button
              id="translate-images"
              type="button"
              disabled
              class="rounded-2xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-700 transition disabled:cursor-not-allowed disabled:opacity-50 hover:border-neutral-900 hover:text-neutral-950 dark:border-zinc-700 dark:text-zinc-200 dark:hover:border-white dark:hover:text-white"
            >
              {translateImagesLabel}
            </button>
          </div>
          <div id="temu-status-bar" class="flex flex-col gap-2 min-h-14">
            <div class="flex items-center gap-3 text-xs font-semibold">
              <span class="temu-step" data-step="extract">
                <span class="step-indicator"></span>
                {lang === 'fr' ? 'Extraction' : 'Extract'}
              </span>
              <span class="step-connector"></span>
              <span class="temu-step" data-step="rewrite">
                <span class="step-indicator"></span>
                {lang === 'fr' ? 'Réécriture' : 'Rewrite'}
              </span>
              <span class="step-connector"></span>
              <span class="temu-step" data-step="translate">
                <span class="step-indicator"></span>
                {lang === 'fr' ? 'Traduction' : 'Translate'}
              </span>
            </div>
            <p id="temu-status" class="min-h-5 text-sm text-neutral-600 dark:text-zinc-400"></p>
          </div>
        </form>

        <div class="rounded-temu-lg border border-neutral-200 bg-white p-5 dark:border-zinc-800 dark:bg-zinc-950/80">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-neutral-500 dark:text-zinc-500">
                {lang === 'fr' ? 'Description source' : 'Source description'}
              </p>
              <h2 class="mt-2 text-xl font-semibold text-neutral-950 dark:text-white">
                {lang === 'fr' ? 'Texte récupéré' : 'Extracted text'}
              </h2>
            </div>
            <button
              id="copy-description"
              type="button"
              disabled
              class="rounded-2xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-700 transition disabled:cursor-not-allowed disabled:opacity-50 hover:border-neutral-900 hover:text-neutral-950 dark:border-zinc-700 dark:text-zinc-200 dark:hover:border-white dark:hover:text-white"
            >
              {copyLabel}
            </button>
          </div>
          <textarea
            id="temu-description"
            rows="12"
            readonly
            class="mt-4 w-full rounded-temu-md border border-neutral-200 bg-neutral-50 px-4 py-4 text-sm leading-7 text-neutral-800 outline-none dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-100"
          ></textarea>
        </div>

        <div class="rounded-temu-lg border border-neutral-200 bg-white p-5 dark:border-zinc-800 dark:bg-zinc-950/80">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-neutral-500 dark:text-zinc-500">
                {lang === 'fr' ? 'Annonce de revente' : 'Resale listing'}
              </p>
              <h2 class="mt-2 text-xl font-semibold text-neutral-950 dark:text-white">
                {lang === 'fr' ? 'Version prête à publier' : 'Ready-to-publish version'}
              </h2>
            </div>
            <div class="flex flex-wrap gap-2">
              <button
                id="copy-ai-title"
                type="button"
                disabled
                class="rounded-2xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-700 transition disabled:cursor-not-allowed disabled:opacity-50 hover:border-neutral-900 hover:text-neutral-950 dark:border-zinc-700 dark:text-zinc-200 dark:hover:border-white dark:hover:text-white"
              >
                {copyAiTitleLabel}
              </button>
              <button
                id="copy-ai-description"
                type="button"
                disabled
                class="rounded-2xl bg-neutral-950 px-4 py-2 text-sm font-semibold text-white transition disabled:cursor-not-allowed disabled:opacity-50 hover:bg-neutral-800 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200"
              >
                {copyAiDescriptionLabel}
              </button>
            </div>
          </div>
          <div class="mt-4 grid gap-4">
            <div class="rounded-temu-md border border-neutral-200 bg-neutral-50 p-4 dark:border-zinc-800 dark:bg-zinc-900">
              <p class="text-xs uppercase tracking-[0.18em] text-neutral-500 dark:text-zinc-500">
                {lang === 'fr' ? "Titre d'annonce" : 'Listing title'}
              </p>
              <p id="ai-listing-title" class="mt-2 text-base font-semibold text-neutral-900 dark:text-white"></p>
            </div>
            <textarea
              id="ai-listing-description"
              rows="10"
              readonly
              class="w-full rounded-temu-md border border-neutral-200 bg-neutral-50 px-4 py-4 text-sm leading-7 text-neutral-800 outline-none dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-100"
            ></textarea>
            <div class="rounded-temu-md border border-neutral-200 bg-neutral-50 p-4 dark:border-zinc-800 dark:bg-zinc-900">
              <p class="text-xs uppercase tracking-[0.18em] text-neutral-500 dark:text-zinc-500">
                {lang === 'fr' ? 'Points forts' : 'Selling points'}
              </p>
              <ul id="ai-selling-points" class="mt-3 list-disc space-y-2 pl-5 text-sm text-neutral-800 dark:text-zinc-100"></ul>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-6">
        <div class="rounded-temu-lg border border-neutral-200 bg-white p-5 dark:border-zinc-800 dark:bg-zinc-950/80">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-neutral-500 dark:text-zinc-500">
                {lang === 'fr' ? 'Photos' : 'Photos'}
              </p>
              <h2 class="mt-2 text-xl font-semibold text-neutral-950 dark:text-white">
                {lang === 'fr' ? 'Pack visuel détecté' : 'Detected visual pack'}
              </h2>
            </div>
            <button
              id="download-all"
              type="button"
              disabled
              class="rounded-2xl bg-neutral-950 px-4 py-2 text-sm font-semibold text-white transition disabled:cursor-not-allowed disabled:opacity-50 hover:bg-neutral-800 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200"
            >
              {downloadLabel}
            </button>
          </div>
          <div class="mt-4 grid gap-4">
            <dl class="grid grid-cols-1 gap-3 rounded-temu-md border border-neutral-200 bg-neutral-50 p-4 text-sm dark:border-zinc-800 dark:bg-zinc-900 sm:grid-cols-2">
              <div>
                <dt class="text-xs uppercase tracking-[0.18em] text-neutral-500 dark:text-zinc-500">{lang === 'fr' ? 'Titre' : 'Title'}</dt>
                <dd id="temu-title" class="mt-1 font-medium text-neutral-900 dark:text-white"></dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-[0.18em] text-neutral-500 dark:text-zinc-500">{lang === 'fr' ? 'Nombre d’images' : 'Image count'}</dt>
                <dd id="temu-count" class="mt-1 font-medium text-neutral-900 dark:text-white">0</dd>
              </div>
              <div class="sm:col-span-2">
                <dt class="text-xs uppercase tracking-[0.18em] text-neutral-500 dark:text-zinc-500">{lang === 'fr' ? 'URL source' : 'Source URL'}</dt>
                <dd class="mt-1 break-all">
                  <a id="temu-source" href="#" target="_blank" rel="noreferrer" class="font-medium text-neutral-900 underline decoration-neutral-300 underline-offset-4 dark:text-white dark:decoration-zinc-700"></a>
                </dd>
              </div>
            </dl>
            <div id="temu-images" class="grid grid-cols-2 gap-3 sm:grid-cols-3"></div>
          </div>
        </div>

        <div class="rounded-temu-lg border border-neutral-200 bg-white p-5 dark:border-zinc-800 dark:bg-zinc-950/80">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-neutral-500 dark:text-zinc-500">
                {lang === 'fr' ? 'Images traduites' : 'Translated images'}
              </p>
              <h2 class="mt-2 text-xl font-semibold text-neutral-950 dark:text-white">
                {lang === 'fr' ? 'Fichiers prêts à télécharger' : 'Files ready to download'}
              </h2>
            </div>
            <button
              id="download-translated-all"
              type="button"
              disabled
              class="rounded-2xl bg-neutral-950 px-4 py-2 text-sm font-semibold text-white transition disabled:cursor-not-allowed disabled:opacity-50 hover:bg-neutral-800 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200"
            >
              {lang === 'fr' ? 'Télécharger toutes les images traduites' : 'Download all translated images'}
            </button>
          </div>
          <div id="translated-images" class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .temu-radial-bg {
    background: radial-gradient(circle at top left, color-mix(in srgb, var(--brand-red) 10%, transparent), transparent 35%),
                radial-gradient(circle at bottom right, color-mix(in srgb, var(--brand-cyan) 12%, transparent), transparent 30%);
  }
  .temu-step {
    display: inline-flex;
    align-items: center;
    gap: var(--temu-step-gap);
    color: var(--temu-step-idle);
    transition: color var(--temu-step-transition) ease;
  }
  .temu-step.active {
    color: var(--temu-step-active);
  }
  .dark .temu-step.active {
    color: var(--temu-step-active-light);
  }
  .temu-step.done {
    color: var(--temu-step-done);
  }

  .step-indicator {
    display: inline-block;
    width: var(--temu-step-dot-size);
    height: var(--temu-step-dot-size);
    border-radius: var(--step-dot-circle);
    background: var(--temu-step-indicator-rest);
    transition: background var(--temu-step-transition) ease, transform var(--temu-step-transition) ease, box-shadow var(--temu-step-transition) ease;
    flex-shrink: 0;
  }
  .temu-step.active .step-indicator {
    background: var(--temu-step-active);
    animation: step-pulse var(--temu-step-pulse-duration) ease-in-out infinite;
  }
  .dark .temu-step.active .step-indicator {
    background: var(--temu-step-active-light);
  }
  .temu-step.done .step-indicator {
    background: var(--temu-step-done);
    animation: none;
  }
  .temu-step.done .step-indicator::after {
    content: '✓';
    display: block;
    font-size: var(--temu-step-dot-font-size);
    line-height: var(--temu-step-dot-line-height);
    text-align: center;
    color: var(--btn-primary-text);
  }

  @keyframes step-pulse {
    0%, 100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--temu-step-active) 30%, transparent); transform: scale(1); }
    50% { box-shadow: 0 0 0 var(--temu-step-pulse-max-spread) transparent; transform: scale(1.25); }
  }

  .step-connector {
    display: inline-block;
    width: var(--temu-step-connector-width);
    height: var(--temu-step-connector-height);
    border-radius: var(--temu-step-connector-radius);
    background: var(--temu-step-indicator-rest);
    transition: background var(--temu-step-transition) ease;
    flex-shrink: 0;
  }
  .step-connector.done {
    background: var(--temu-step-done);
  }

  .status-dots::after {
    content: '';
    animation: status-ellipsis var(--temu-status-ellipsis-duration) steps(4, end) infinite;
  }

  @keyframes status-ellipsis {
    0% { content: ''; }
    25% { content: '.'; }
    50% { content: '..'; }
    75% { content: '...'; }
    100% { content: ''; }
  }

  .status-fade-in {
    animation: status-fade var(--temu-status-fade-duration) ease-out;
  }

  @keyframes status-fade {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script is:inline define:vars={{ lang }}>
  const messages = {
    extracting: lang === 'fr' ? 'Extraction en cours...' : 'Extracting...',
    rewriting:
      lang === 'fr'
        ? "Génération de l'annonce et traduction des photos..."
        : 'Generating listing and translating photo text...',
    translatingImages:
      lang === 'fr'
        ? 'Génération des images traduites...'
        : 'Generating translated images...',
    copyingDone: lang === 'fr' ? 'Texte copié.' : 'Text copied.',
    downloadStarted:
      lang === 'fr'
        ? 'Téléchargement des photos en cours...'
        : 'Downloading photos...',
    downloadDone:
      lang === 'fr'
        ? 'Téléchargement terminé.'
        : 'Downloads completed.',
    invalidUrl:
      lang === 'fr'
        ? 'Entre une URL valide.'
        : 'Enter a valid URL.',
    emptyResult:
      lang === 'fr'
        ? "Aucune donnée utile n'a été trouvée sur cette page."
        : 'No useful data was found on this page.',
    extractFailed:
      lang === 'fr'
        ? "Extraction impossible pour cette URL pour l'instant."
        : 'Extraction failed for this URL right now.',
    rewriteFailed:
      lang === 'fr'
        ? "La génération de l'annonce a échoué."
        : 'Listing generation failed.',
    translateImagesFailed:
      lang === 'fr'
        ? 'La génération des images traduites a échoué.'
        : 'Translated image generation failed.',
    geminiMissing:
      lang === 'fr'
        ? "Gemini n'est pas configuré côté serveur. Ajoute GEMINI_API_KEY pour activer la réécriture et l'OCR."
        : 'Gemini is not configured on the server. Add GEMINI_API_KEY to enable rewriting and OCR.',
    downloadFailed:
      lang === 'fr'
        ? 'Certaines images ont échoué au téléchargement.'
        : 'Some images failed to download.',
  }

  const form = document.getElementById('temu-form')
  const input = document.getElementById('temu-url')
  const statusEl = document.getElementById('temu-status')
  const descriptionEl = document.getElementById('temu-description')
  const titleEl = document.getElementById('temu-title')
  const countEl = document.getElementById('temu-count')
  const sourceEl = document.getElementById('temu-source')
  const imagesEl = document.getElementById('temu-images')
  const copyButton = document.getElementById('copy-description')
  const downloadAllButton = document.getElementById('download-all')
  const rewriteButton = document.getElementById('rewrite-listing')
  const translateImagesButton = document.getElementById('translate-images')
  const aiTitleEl = document.getElementById('ai-listing-title')
  const aiDescriptionEl = document.getElementById('ai-listing-description')
  const aiSellingPointsEl = document.getElementById('ai-selling-points')
  const copyAiTitleButton = document.getElementById('copy-ai-title')
  const copyAiDescriptionButton = document.getElementById('copy-ai-description')
  const translatedImagesEl = document.getElementById('translated-images')
  const downloadTranslatedAllButton = document.getElementById('download-translated-all')

  let currentResult = null
  let currentTranslatedImages = []

  function updateSteps(activeStep) {
    const steps = ['extract', 'rewrite', 'translate']
    const idx = steps.indexOf(activeStep)
    document.querySelectorAll('.temu-step').forEach((el) => {
      const step = el.dataset.step
      const stepIdx = steps.indexOf(step)
      el.classList.toggle('active', step === activeStep)
      el.classList.toggle('done', stepIdx !== -1 && stepIdx < idx)
    })
    document.querySelectorAll('.step-connector').forEach((el, i) => {
      el.classList.toggle('done', i < idx)
    })
  }

  function completeStep(step) {
    const el = document.querySelector(`.temu-step[data-step="${step}"]`)
    if (el) {
      el.classList.remove('active')
      el.classList.add('done')
    }
  }

  function resetSteps() {
    document.querySelectorAll('.temu-step').forEach((el) => {
      el.classList.remove('active', 'done')
    })
    document.querySelectorAll('.step-connector').forEach((el) => {
      el.classList.remove('done')
    })
  }

  function setStatus(message, isError = false) {
    statusEl.textContent = message
    statusEl.className = 'min-h-5 text-sm status-fade-in'
      + (isError
        ? ' text-red-600 dark:text-red-400'
        : ' text-neutral-600 dark:text-zinc-400')
    void statusEl.offsetWidth
  }

  function setLoadingStatus(message) {
    statusEl.textContent = message
    statusEl.className = 'min-h-5 text-sm status-fade-in text-neutral-600 dark:text-zinc-400 status-dots'
    void statusEl.offsetWidth
  }

  function escapeHtml(value) {
    return value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;')
  }

  function resetRewrite() {
    aiTitleEl.textContent = ''
    aiDescriptionEl.value = ''
    aiSellingPointsEl.innerHTML = ''
    copyAiTitleButton.disabled = true
    copyAiDescriptionButton.disabled = true
  }

  function resetTranslatedImages() {
    currentTranslatedImages = []
    translatedImagesEl.innerHTML = ''
    downloadTranslatedAllButton.disabled = true
  }

  function resetResult() {
    currentResult = null
    descriptionEl.value = ''
    titleEl.textContent = ''
    countEl.textContent = '0'
    sourceEl.textContent = ''
    sourceEl.href = '#'
    imagesEl.innerHTML = ''
    copyButton.disabled = true
    downloadAllButton.disabled = true
    rewriteButton.disabled = true
    translateImagesButton.disabled = true
    resetRewrite()
    resetTranslatedImages()
    resetSteps()
  }

  function renderImages(images) {
    imagesEl.innerHTML = images
      .map(
        (image, index) => `
          <article class="overflow-hidden rounded-temu-md border border-neutral-200 bg-neutral-50 dark:border-zinc-800 dark:bg-zinc-900">
            <img src="${escapeHtml(image)}" alt="Temu image ${index + 1}" loading="lazy" class="aspect-square w-full object-cover" />
            <div class="p-3">
              <button
                type="button"
                class="temu-download-one w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm font-semibold text-neutral-700 transition hover:border-neutral-900 hover:text-neutral-950 dark:border-zinc-700 dark:text-zinc-200 dark:hover:border-white dark:hover:text-white"
                data-image="${escapeHtml(image)}"
                data-index="${index}"
              >
                ${lang === 'fr' ? 'Télécharger' : 'Download'}
              </button>
            </div>
          </article>
        `
      )
      .join('')
  }

  function renderRewrite(data) {
    aiTitleEl.textContent = data.listingTitle || ''
    aiDescriptionEl.value = data.listingDescription || ''
    aiSellingPointsEl.innerHTML = (data.sellingPoints || [])
      .map((item) => `<li>${escapeHtml(item)}</li>`)
      .join('')
    copyAiTitleButton.disabled = !data.listingTitle
    copyAiDescriptionButton.disabled = !data.listingDescription
  }

  function renderTranslatedImages(images) {
    translatedImagesEl.innerHTML = images
      .map(
        (item, index) => `
          <article class="overflow-hidden rounded-temu-md border border-neutral-200 bg-neutral-50 dark:border-zinc-800 dark:bg-zinc-900">
            <img src="${item.dataUrl}" alt="Translated image ${index + 1}" loading="lazy" class="aspect-square w-full object-cover" />
            <div class="p-3">
              <button
                type="button"
                class="download-translated-one w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm font-semibold text-neutral-700 transition hover:border-neutral-900 hover:text-neutral-950 dark:border-zinc-700 dark:text-zinc-200 dark:hover:border-white dark:hover:text-white"
                data-index="${index}"
              >
                ${lang === 'fr' ? 'Télécharger cette image' : 'Download this image'}
              </button>
            </div>
          </article>
        `
      )
      .join('')
    downloadTranslatedAllButton.disabled = !images.length
  }

  async function copyText(value) {
    if (!value) return
    await navigator.clipboard.writeText(value)
    setStatus(messages.copyingDone)
  }

  function downloadTranslatedImage(item, index) {
    const anchor = document.createElement('a')
    anchor.href = item.dataUrl
    const ext = item.mimeType?.includes('png')
      ? 'png'
      : item.mimeType?.includes('webp')
        ? 'webp'
        : 'jpg'
    anchor.download = `temu-translated-${String(index + 1).padStart(2, '0')}.${ext}`
    document.body.append(anchor)
    anchor.click()
    anchor.remove()
  }

  async function downloadImage(imageUrl, index) {
    const response = await fetch(
      `/api/temu/image?src=${encodeURIComponent(imageUrl)}&index=${index}`
    )
    if (!response.ok) {
      throw new Error('download_failed')
    }

    const blob = await response.blob()
    const contentDisposition = response.headers.get('content-disposition') || ''
    const filenameMatch = contentDisposition.match(/filename="([^"]+)"/i)
    const filename = filenameMatch ? filenameMatch[1] : `temu-image-${index + 1}.jpg`
    const objectUrl = URL.createObjectURL(blob)
    const anchor = document.createElement('a')
    anchor.href = objectUrl
    anchor.download = filename
    document.body.append(anchor)
    anchor.click()
    anchor.remove()
    URL.revokeObjectURL(objectUrl)
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault()
    resetResult()

    const url = input.value.trim()
    if (!url) {
      setStatus(messages.invalidUrl, true)
      return
    }

    updateSteps('extract')
    setLoadingStatus(
      lang === 'fr'
        ? 'Connexion à Temu...'
        : 'Connecting to Temu...'
    )

    try {
      const response = await fetch('/api/temu/extract', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url }),
      })
      const payload = await response.json()

      if (!response.ok || !payload?.data) {
        completeStep('extract')
        setStatus(messages.extractFailed, true)
        return
      }

      currentResult = payload.data
      descriptionEl.value = payload.data.description || ''
      titleEl.textContent = payload.data.title || ''
      countEl.textContent = String(payload.data.images?.length || 0)
      sourceEl.textContent = payload.data.resolvedUrl || payload.data.sourceUrl || url
      sourceEl.href = payload.data.resolvedUrl || payload.data.sourceUrl || url
      renderImages(payload.data.images || [])

      copyButton.disabled = !payload.data.description
      downloadAllButton.disabled = !(payload.data.images && payload.data.images.length)
      rewriteButton.disabled = false
      translateImagesButton.disabled = !(payload.data.images && payload.data.images.length)

      if (!payload.data.description && !(payload.data.images && payload.data.images.length)) {
        completeStep('extract')
        setStatus(messages.emptyResult, true)
        return
      }

      completeStep('extract')
      setStatus(
        lang === 'fr'
          ? `Extraction prête: ${payload.data.images.length} photo(s) détectée(s).`
          : `Extraction ready: ${payload.data.images.length} image(s) detected.`
      )
    } catch (error) {
      console.error(error)
      completeStep('extract')
      setStatus(messages.extractFailed, true)
    }
  })

  rewriteButton?.addEventListener('click', async () => {
    if (!currentResult) return
    resetRewrite()
    updateSteps('rewrite')
    setLoadingStatus(
      lang === 'fr'
        ? 'Envoi à Gemini...'
        : 'Sending to Gemini...'
    )

    try {
      const response = await fetch('/api/temu/rewrite', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          sourceUrl: currentResult.resolvedUrl || currentResult.sourceUrl,
          title: currentResult.title,
          description: currentResult.description,
          images: currentResult.images,
          sellerLanguage: lang,
        }),
      })

      const payload = await response.json()

      if (payload?.error === 'gemini_not_configured') {
        completeStep('rewrite')
        setStatus(messages.geminiMissing, true)
        return
      }

      if (!response.ok || !payload?.data) {
        completeStep('rewrite')
        setStatus(messages.rewriteFailed, true)
        return
      }

      renderRewrite(payload.data)
      completeStep('rewrite')
      setStatus(
        lang === 'fr'
          ? 'Annonce de revente générée.'
          : 'Resale listing generated.'
      )
    } catch (error) {
      console.error(error)
      completeStep('rewrite')
      setStatus(messages.rewriteFailed, true)
    }
  })

  translateImagesButton?.addEventListener('click', async () => {
    if (!currentResult?.images?.length) return
    resetTranslatedImages()
    updateSteps('translate')
    const total = currentResult.images.length
    setLoadingStatus(
      lang === 'fr'
        ? `Traduction des images (0/${total})...`
        : `Translating images (0/${total})...`
    )

    try {
      const response = await fetch('/api/temu/translate-images', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          images: currentResult.images,
        }),
      })

      const payload = await response.json()
      if (payload?.error === 'gemini_not_configured') {
        completeStep('translate')
        setStatus(messages.geminiMissing, true)
        return
      }

      if (!response.ok || !payload?.data?.images) {
        completeStep('translate')
        setStatus(messages.translateImagesFailed, true)
        return
      }

      currentTranslatedImages = payload.data.images
      renderTranslatedImages(currentTranslatedImages)
      completeStep('translate')
      setStatus(
        lang === 'fr'
          ? `Images traduites générées (${currentTranslatedImages.length}/${total}).`
          : `Translated images generated (${currentTranslatedImages.length}/${total}).`
      )
    } catch (error) {
      console.error(error)
      completeStep('translate')
      setStatus(messages.translateImagesFailed, true)
    }
  })

  copyButton?.addEventListener('click', async () => {
    await copyText(descriptionEl.value)
  })

  copyAiTitleButton?.addEventListener('click', async () => {
    await copyText(aiTitleEl.textContent || '')
  })

  copyAiDescriptionButton?.addEventListener('click', async () => {
    await copyText(aiDescriptionEl.value)
  })

  downloadAllButton?.addEventListener('click', async () => {
    if (!currentResult?.images?.length) return
    setStatus(messages.downloadStarted)

    let failed = false
    for (const [index, imageUrl] of currentResult.images.entries()) {
      try {
        await downloadImage(imageUrl, index)
      } catch (error) {
        console.error(error)
        failed = true
      }
    }

    setStatus(failed ? messages.downloadFailed : messages.downloadDone, failed)
  })

  imagesEl?.addEventListener('click', async (event) => {
    const target = event.target.closest('.temu-download-one')
    if (!target) return

    const imageUrl = target.getAttribute('data-image')
    const index = Number.parseInt(target.getAttribute('data-index') || '0', 10)
    if (!imageUrl) return

    try {
      await downloadImage(imageUrl, Number.isNaN(index) ? 0 : index)
    } catch (error) {
      console.error(error)
      setStatus(messages.downloadFailed, true)
    }
  })

  translatedImagesEl?.addEventListener('click', (event) => {
    const target = event.target.closest('.download-translated-one')
    if (!target) return

    const index = Number.parseInt(target.getAttribute('data-index') || '0', 10)
    const item = currentTranslatedImages[index]
    if (!item) return
    downloadTranslatedImage(item, index)
  })

  downloadTranslatedAllButton?.addEventListener('click', () => {
    if (!currentTranslatedImages.length) return
    currentTranslatedImages.forEach((item, index) => downloadTranslatedImage(item, index))
  })
</script>

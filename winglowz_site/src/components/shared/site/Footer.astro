---
import { getLangFromUrl, useTranslations } from '@/utils/i18n'
import { SITE } from '@/constants'
import TextLogo from '@components/ui/TextLogo.astro'

interface FooterLink {
  name: string
  url: string
}

interface FooterSection {
  section: string
  links: FooterLink[]
}

interface Props {
  forceDark?: boolean
}

const { forceDark = false } = Astro.props
const lang = getLangFromUrl(Astro.url)
const t = await useTranslations(lang, 'navigation')
const homeUrl = lang === 'fr' ? '/fr' : '/'

const footerSections: Array<{
  title: string
  links: Array<{ label: string; href: string }>
}> =
  t.footerLinks?.map((section: FooterSection) => ({
    title: section.section,
    links: section.links.map((link: FooterLink) => ({
      label: link.name,
      href: link.url,
    })),
  })) || []

const newsletterTitle =
  t.newsletterSection?.title || 'This Week In Windows Productivity'
const newsletterDesc =
  t.newsletterSection?.description ||
  'Weekly newsletter about Windows tooling and the productivity ecosystem.'
const craftedBy = t.footer?.crafted || 'Crafted by'
const githubUrl =
  t.socialLinks?.github || 'https://github.com/diane-defores/winglowz'
const currentYear = new Date().getFullYear()
const backToTopLabel = lang === 'fr' ? '↑ Retour en haut' : '↑ Back to top'

const footerClass = forceDark
  ? 'border-t border-zinc-800 bg-black'
  : 'border-t border-neutral-200 bg-neutral-50 dark:border-zinc-800 dark:bg-black'

const footerTextClass = forceDark
  ? 'text-sm text-zinc-500'
  : 'text-sm text-neutral-500 dark:text-zinc-500'

const footerMutedClass = forceDark
  ? 'text-xs text-zinc-500'
  : 'text-xs text-neutral-500 dark:text-zinc-500'

const footerLabelClass = forceDark
  ? 'mb-2 text-xs text-zinc-400'
  : 'mb-2 text-xs text-neutral-600 dark:text-zinc-400'

const footerHeadingClass = forceDark
  ? 'mb-4 text-sm font-semibold text-white'
  : 'mb-4 text-sm font-semibold text-neutral-900 dark:text-white'

const footerLinkClass = forceDark
  ? 'text-sm text-zinc-500 transition-colors hover:text-white'
  : 'text-sm text-neutral-500 transition-colors hover:text-neutral-900 dark:text-zinc-500 dark:hover:text-white'

const statusShellClass = forceDark
  ? 'inline-flex items-center gap-2 rounded-full border border-zinc-800 bg-zinc-900 px-3 py-1.5'
  : 'inline-flex items-center gap-2 rounded-full border border-neutral-200 bg-neutral-100 px-3 py-1.5 dark:border-zinc-800 dark:bg-zinc-900'

const dividerClass = forceDark
  ? 'reveal delay-3 mt-16 flex flex-col items-center justify-between gap-4 border-t border-zinc-800 pt-8 sm:flex-row'
  : 'reveal delay-3 mt-16 flex flex-col items-center justify-between gap-4 border-t border-neutral-200 pt-8 dark:border-zinc-800 sm:flex-row'
---

<footer class={footerClass}>
  <div class="mx-auto max-w-6xl px-4 py-16">
    <div class="reveal grid grid-cols-2 gap-8 md:grid-cols-5">
      <div class="col-span-2 md:col-span-1">
        <!-- The landing layout has no ClientRouter; keep this layered logo out of a cross-layout transition. -->
        <a
          href={homeUrl}
          data-astro-reload
          class="no-hover-animation mb-4 flex items-center gap-2"
        >
          <TextLogo class="w-28" />
        </a>
        <p class={footerTextClass}>
          Productivity plugins & Windows training by {SITE.authorName}.
        </p>
        <div class="mb-4">
          <p class={footerLabelClass}>
            {newsletterTitle}
          </p>
          <p class={footerMutedClass}>
            {newsletterDesc}
          </p>
        </div>
        <div class={statusShellClass}>
          <span
            class="pulse-glow h-2 w-2 rounded-full"
            style="background-color: var(--brand-green);"></span>
          <span
            class={forceDark
              ? 'text-xs text-zinc-400'
              : 'text-xs text-neutral-500 dark:text-zinc-400'}
          >
            Site and catalog are maintained continuously
          </span>
        </div>
      </div>

      {
        footerSections.map((section) => (
          <div>
            <h4 class={footerHeadingClass}>{section.title}</h4>
            <ul class="space-y-3">
              {section.links.map((link) => (
                <li>
                  <a href={link.href} class={footerLinkClass}>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class={dividerClass}>
      <p class={footerTextClass}>
        &copy; {currentYear}
        {SITE.name}. {craftedBy}
        {SITE.authorName}.
      </p>
      <div class="flex items-center gap-6">
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class={footerLinkClass}
        >
          GitHub
        </a>
        <a href={`mailto:${SITE.emails.contact}`} class={footerLinkClass}>
          Contact
        </a>
        <a href="#top" class={footerLinkClass}>
          {backToTopLabel}
        </a>
      </div>
    </div>
  </div>
</footer>

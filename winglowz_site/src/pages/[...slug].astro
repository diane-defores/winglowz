---
import { getCollection, render } from 'astro:content';
import DocsLayout from '@/layouts/DocsLayout.astro';
import CoursePreviewGate from '@/components/overrides/CoursePreviewGate.astro';
import { buildDocTree, getDocLang, getDocPager, getEntrySlug } from '@/utils/docs';
import { isPremiumFormationSlug } from '@/utils/courseGating';

export const prerender = true;

export async function getStaticPaths() {
  const docs = await getCollection('docs', ({ data }) => !data.draft);
  return docs.map((entry) => ({
    params: {
      slug: getEntrySlug(entry),
    },
  }));
}

const requestedSlug = Astro.params.slug?.replace(/\/$/, '');
const docs = await getCollection('docs');
const entry = docs.find((doc) => getEntrySlug(doc).replace(/\/$/, '') === requestedSlug);

if (!entry || entry.data.draft) {
  return Astro.redirect('/404');
}

const entrySlug = getEntrySlug(entry);
const { Content, headings } = await render(entry);
const lang = getDocLang(entrySlug);
const sidebar = buildDocTree(docs, lang);
const pager = getDocPager(docs, lang, entrySlug);
const isPremiumFormationPage = isPremiumFormationSlug(entrySlug);
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  lang={lang}
  sidebar={sidebar}
  headings={headings}
  currentPath={Astro.url.pathname}
  pager={pager}
>
  {
    isPremiumFormationPage ? (
      <CoursePreviewGate
        entry={{
          slug: entrySlug,
          body: entry.body ?? '',
          title: entry.data.title,
          description: entry.data.description,
        }}
        headings={headings}
        isAuthenticated={false}
        hasAccess={false}
      />
    ) : (
      <Content />
    )
  }
</DocsLayout>

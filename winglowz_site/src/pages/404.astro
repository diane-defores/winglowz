---
export const prerender = true
import MainLayout from '@/layouts/MainLayout.astro'
import { useTranslations } from '@/utils/i18n'
import type { Language } from '@/types/i18n'

// Detect language from URL - if path starts with /fr, use French, otherwise English
const url = Astro.url
const lang: Language = url.pathname.startsWith('/fr') ? 'fr' : 'en'
const t = await useTranslations(lang, '404')
---

<MainLayout
	title={t.title || '404'}
	meta={{
		description: t.description || '404 - Page not found',
	}}
	lang={lang}
>
	<section class="mx-auto max-w-screen-2xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
		<div class="text-center">
			<h1
				class="block text-7xl font-bold text-neutral-800 dark:text-neutral-200 sm:text-9xl"
			>
				404
			</h1>
			<h2
				class="mt-3 text-xl font-bold text-neutral-800 dark:text-neutral-200 sm:text-2xl"
			>
				{t.heading || 'Page not found'}
			</h2>
			<p class="mt-4 text-neutral-600 dark:text-neutral-400">
				{t.message || 'The page you are looking for does not exist.'}
			</p>
			<div
				class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
			>
				<a
					class="text-magenta dark:bg-neutral-800 dark:hover:bg-neutral-700 inline-flex w-full items-center justify-center gap-x-2 rounded-lg border border-transparent bg-neutral-100 px-4 py-3 text-sm font-semibold hover:bg-neutral-200 disabled:pointer-events-none disabled:opacity-50 dark:text-magenta dark:focus:outline-none dark:focus:ring-1 dark:focus:ring-neutral-600 sm:w-auto"
					href={lang === 'fr' ? '/fr' : '/'}
				>
					<svg
						class="size-4 flex-shrink-0"
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="m15 18-6-6 6-6"></path>
					</svg>
					{t.backHome || 'Back to home'}
				</a>
			</div>
		</div>
	</section>
</MainLayout>

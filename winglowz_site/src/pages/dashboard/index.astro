---
import MainLayout from '@/layouts/MainLayout.astro'

const auth = Astro.locals.auth()
if (!auth.userId) {
	return Astro.redirect('/signin')
}
---

<MainLayout title="Dashboard">
	<div class="min-h-screen py-12">
		<div class="mx-auto max-w-4xl">
			<h1 class="text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-8">
				Dashboard
			</h1>

			<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				<!-- Subscription Status -->
				<div class="rounded-xl border border-neutral-200 bg-white p-6 dark:border-neutral-800 dark:bg-neutral-800">
					<h2 class="text-sm font-medium text-neutral-500 dark:text-neutral-400 mb-2">Plan</h2>
					<p class="text-2xl font-bold text-neutral-900 dark:text-white">Free</p>
					<a href="/landing#pricing" class="mt-3 inline-block text-sm text-magenta hover:underline">
						Upgrade to Pro
					</a>
				</div>

				<!-- Quick Links -->
				<div class="rounded-xl border border-neutral-200 bg-white p-6 dark:border-neutral-800 dark:bg-neutral-800">
					<h2 class="text-sm font-medium text-neutral-500 dark:text-neutral-400 mb-2">Quick Links</h2>
					<ul class="space-y-2 text-sm">
						<li><a href="/dashboard/taches" class="text-magenta hover:underline">Tasks</a></li>
						<li><a href="/dashboard/parametres" class="text-magenta hover:underline">Settings</a></li>
						<li><a href="/products" class="text-magenta hover:underline">Products</a></li>
					</ul>
				</div>

				<!-- Resources -->
				<div class="rounded-xl border border-neutral-200 bg-white p-6 dark:border-neutral-800 dark:bg-neutral-800">
					<h2 class="text-sm font-medium text-neutral-500 dark:text-neutral-400 mb-2">Resources</h2>
					<ul class="space-y-2 text-sm">
						<li><a href="/en/formations/" class="text-magenta hover:underline">Courses</a></li>
						<li><a href="/blog" class="text-magenta hover:underline">Blog</a></li>
						<li><a href="/roadmap" class="text-magenta hover:underline">Roadmap</a></li>
					</ul>
				</div>
			</div>
		</div>
	</div>
</MainLayout>

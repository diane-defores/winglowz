---
import MainLayout from '@/layouts/MainLayout.astro'
import { isSafePrivateCoursePath } from '@/utils/courseGating'

const auth = Astro.locals.auth()
const nextUrl = Astro.url.searchParams.get('next')
const offerId = Astro.url.searchParams.get('offerId')
const safeNextUrl = isSafePrivateCoursePath(nextUrl) ? nextUrl : null
const lang = safeNextUrl?.includes('/dashboard/docs/fr/') ? 'fr' : 'en'
const isWinGlowzAppOffer = offerId?.startsWith('winglowz_app/') ?? false
const isSocialGlowzOffer = offerId === 'socialglowz/lifetime_deal'
const labels =
	lang === 'fr'
		? {
				title: 'Achat confirme',
				body:
					isWinGlowzAppOffer || isSocialGlowzOffer
						? isWinGlowzAppOffer
							? "Paiement reçu. L'accès WinGlowz est confirmé par webhook signé et peut nécessiter une vérification de compte avant activation dans l'app."
							: "Paiement reçu. L'accès SocialGlowz est confirmé par webhook signé et peut nécessiter une vérification de compte avant activation."
						: 'Votre acces a la formation a ete debloque. Vous pouvez ouvrir la lecon privee maintenant.',
				openLesson: 'Ouvrir la lecon',
				goToDashboard: 'Aller au dashboard',
				signIn: 'Se connecter pour acceder',
				viewProducts: 'Voir les produits',
				contact: 'Contacter le support',
			}
		: {
				title: 'Purchase Confirmed',
				body:
					isWinGlowzAppOffer || isSocialGlowzOffer
						? isWinGlowzAppOffer
							? 'Payment received. WinGlowz access is confirmed by signed webhook and may require account verification before activation in the app.'
							: 'Payment received. SocialGlowz access is confirmed by signed webhook and may require account verification before activation.'
						: 'Your training access has been unlocked. You can open the private lesson now.',
				openLesson: 'Open Lesson',
				goToDashboard: 'Go to Dashboard',
				signIn: 'Sign In to Access',
				viewProducts: 'View Products',
				contact: 'Contact Support',
			}
const productsUrl = lang === 'fr' ? '/fr/produits' : '/products'
const contactUrl = lang === 'fr' ? '/fr/contact' : '/contact'
---

<MainLayout title={labels.title}>
	<div class="flex min-h-screen items-center justify-center py-12">
		<div class="mx-auto max-w-lg text-center">
			<div class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-full bg-green/10">
				<svg class="h-8 w-8 text-green" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M20 6 9 17l-5-5"/>
				</svg>
			</div>

			<h1 class="mb-4 text-3xl font-bold text-neutral-900 dark:text-neutral-100">{labels.title}</h1>
			<p class="mb-8 text-lg text-neutral-500 dark:text-neutral-400">
				{labels.body}
			</p>

			<div class="flex flex-col gap-3 sm:flex-row sm:justify-center">
				{isWinGlowzAppOffer || isSocialGlowzOffer ? (
					<a href={contactUrl} class="inline-flex items-center justify-center rounded-lg bg-magenta px-6 py-3 font-medium text-white hover:opacity-90 transition-opacity">
						{labels.contact}
					</a>
				) : auth.userId ? (
					<a href={safeNextUrl || '/dashboard'} class="inline-flex items-center justify-center rounded-lg bg-magenta px-6 py-3 font-medium text-white hover:opacity-90 transition-opacity">
						{safeNextUrl ? labels.openLesson : labels.goToDashboard}
					</a>
				) : (
					<a href={safeNextUrl ? `/signin?next=${encodeURIComponent(safeNextUrl)}` : '/signin'} class="inline-flex items-center justify-center rounded-lg bg-magenta px-6 py-3 font-medium text-white hover:opacity-90 transition-opacity">
						{labels.signIn}
					</a>
				)}
				<a href={productsUrl} class="inline-flex items-center justify-center rounded-lg border border-neutral-300 px-6 py-3 font-medium text-neutral-700 hover:bg-neutral-50 dark:border-neutral-700 dark:text-neutral-300 dark:hover:bg-neutral-800 transition-colors">
					{labels.viewProducts}
				</a>
			</div>
		</div>
	</div>
</MainLayout>

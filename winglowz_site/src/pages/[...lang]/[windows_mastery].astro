---
export const prerender = true

import MainLayout from '@/layouts/MainLayout.astro'
import { getLangFromUrl } from '@/utils/i18n'
import { SITE, getLocalizedSiteUrl } from '@/constants'
import { getCourseCheckoutPath } from '@/utils/courseGating'

export function getStaticPaths() {
	return [
		{ params: { lang: undefined, windows_mastery: 'windows-mastery' } },
		{ params: { lang: 'fr', windows_mastery: 'maitrise-windows' } },
	]
}

const lang = getLangFromUrl(Astro.url)

const salesPath = lang === 'fr' ? '/maitrise-windows' : '/windows-mastery'
const courseHubUrl = lang === 'fr' ? '/fr/formations/' : '/en/formations/'
const premiumEntryLesson =
	lang === 'fr'
		? 'fr/formations/module-2-windows/'
		: 'en/formations/module-2-windows/'
const checkoutUrl = getCourseCheckoutPath(premiumEntryLesson, lang)
const bundleUrl =
	lang === 'fr' ? '/fr/produits/winglowz' : '/products/winglowz'

const page =
	lang === 'fr'
			? {
				title: 'Maîtrise Windows | WinGlowz',
				description:
					'Une page de vente dédiée à la formation Windows WinGlowz : réduire la friction, protéger le focus et reprendre le contrôle de votre environnement de travail.',
				badge: 'Formation Windows · 8 modules · parcours de formation',
				heroTitle: 'Reprenez le contrôle de votre environnement Windows',
				heroSubtitle:
					'Une formation concrète pour réduire les frictions, protéger votre focus et transformer votre ordinateur en système de travail réel.',
				heroBody: [
					"Si vous perdez trop d'énergie dans les onglets, les interruptions, les recherches inutiles, les outils mal choisis et les changements de contexte, le problème n'est probablement pas vous.",
					"Le vrai point de friction, c'est l'environnement numérique dans lequel vous travaillez chaque jour.",
				],
				primaryCta: 'Accéder à la formation',
				secondaryCta: 'Voir le programme',
				proof: ['8 modules structurés', 'contenu FR + EN', 'accès via le parcours premium'],
				problemTitle: 'Le vrai problème',
				problemIntro:
					"Vous n'avez pas forcément besoin de plus de motivation. Vous avez peut-être surtout besoin de moins de friction.",
				problemBullets: [
					"trop d'onglets et trop d'allers-retours",
					"trop de bruit et d'interruptions",
						"trop d'outils mal choisis ou mal reliés",
						"trop d'énergie gaspillée à chercher, retrouver, réorganiser",
				],
			mechanismTitle: 'Pourquoi les méthodes classiques ne suffisent pas',
				mechanismBody: [
						"Quand le travail devient pénible, on essaie souvent de se corriger soi-même : plus de motivation, une nouvelle app, une meilleure to-do, un nouveau système.",
						"Mais on essaie alors de réparer un problème structurel avec de la volonté. Si l'environnement reste trop bruyant, trop fragmenté et trop mal configuré, tout cela s'effondre rapidement.",
				],
				paradigmTitle: 'Le nouveau paradigme',
				paradigmIntro:
						"La productivité n'est pas d'abord une question de motivation. C'est une question d'architecture.",
				paradigmBullets: [
					'le focus se protège',
						"l'information est retrouvable",
						'les outils se choisissent avec logique',
						"l'environnement enlève du bruit avant d'exiger plus d'effort",
				],
				solutionTitle: 'Ce que fait WinGlowz',
				solutionBody: [
						"WinGlowz n'est pas une encyclopédie d'outils ni une collection de hacks. La formation vous apprend à construire un environnement Windows plus clair, plus rapide, plus cohérent et plus soutenant.",
						"Vous n'achetez pas seulement une liste de logiciels. Vous achetez une logique de configuration, de choix et d'usage pour récupérer de la bande passante mentale.",
				],
				audienceTitle: "Pour qui c'est",
				audienceIntro:
						"La douleur ne prend pas la même forme pour tout le monde. Mais le mécanisme reste le même : trop de friction, pas assez de système.",
				audiences: [
					{
						title: 'Travailleur du savoir sur Windows',
						body:
								'Vous jonglez entre navigateur, fichiers, messagerie, notes, recherches et documents. WinGlowz vous aide à retrouver plus de clarté, de continuité et de contrôle.',
						cta: 'Je veux un environnement plus net',
					},
					{
						title: 'Créateur / solopreneur',
						body:
								"Vous avez besoin de vraies plages de création, mais l'administration, les messages, les outils et le chaos numérique mangent votre énergie. WinGlowz vous aide à protéger votre flow.",
							cta: 'Je veux protéger mon flow',
					},
					{
						title: 'Développeur / power user',
						body:
								'Vous sentez déjà que Windows peut aller plus loin. WinGlowz vous aide à construire un poste plus net, plus rapide et plus exigeant sans transformer le tout en gadget.',
						cta: 'Je veux un setup plus exigeant',
					},
				],
				modulesTitle: 'Ce que la formation contient',
				modulesIntro:
						"La formation est organisée en 8 modules qui couvrent les dimensions principales d'un système de travail numérique solide.",
				modules: [
					['Focus et environnement', 'retirer le bruit numérique et protéger de vraies sessions utiles'],
					['Temps et énergie', 'dessiner une semaine plus tenable et mieux répartir les charges'],
						['Actions et exécution', "rendre l'action plus simple, plus claire et moins mentale"],
					['Setup Windows', 'configurer le poste pour soutenir les usages réels'],
					['Information et consommation', 'mieux filtrer, mieux lire, mieux capter'],
						['Connaissance et rétention', "retrouver l'information et réutiliser ce qui compte"],
					['Communication', 'réduire la fragmentation entre email, chat et réunions'],
					['Raccourcis et vitesse', "installer les automatismes qui réduisent le coût d'exécution"],
				],
				transformationTitle: 'Ce qui change concretement',
				beforeTitle: 'Avant',
				beforeBullets: [
					'vous subissez votre ordinateur',
					'vous cherchez trop',
						'vous décidez trop',
					'vous supportez trop de bruit',
					'vous travaillez dans un flux trop cassé',
				],
				afterTitle: 'Après',
				afterBullets: [
					'vous savez quoi simplifier',
					'vous savez quels outils garder ou ignorer',
					"vous retrouvez l'information plus vite",
					'vous protégez mieux vos sessions de travail',
					'vous travaillez dans un environnement plus net et plus soutenant',
				],
				proofTitle: 'Preuves',
				testimonial:
					"Félicitations, Diane ! Je viens de passer 20 minutes dessus et je me demande déjà ce que j'ai fait de ma vie jusqu'à maintenant :)) Plein de bonnes choses pour améliorer mon travail. J'adore !",
				testimonialAuthor: 'Florin Muresan',
				testimonialRole: 'PDG et cofondateur | Squirrly',
				offerTitle: "L'offre",
				offerName: 'Formation Windows Mastery',
				offerPrice: '49€',
				offerPeriod: 'paiement unique',
					offerBullets: ['8 modules', 'FR + EN', 'accès au parcours premium', 'mise en place continue'],
					offerBody:
						"Cette offre est faite pour vous si vous voulez une amélioration concrète de votre environnement de travail Windows sans devoir tout redécouvrir seul.",
				checkoutNote:
					'Connexion si nécessaire, puis validation du paiement et accès au parcours premium.',
				bundleTitle: 'Et si vous voulez aller plus loin',
					bundleBody:
						"Le Pack WinGlowz existe pour les profils qui veulent aussi les outils complémentaires. Il apparaît ici comme un complément, pas comme message principal.",
				bundleCta: 'Voir le pack WinGlowz',
				faqTitle: 'Questions fréquentes',
				faq: [
						[
							'Je manque déjà de temps',
							'Justement. Quand chaque tâche coûte trop cher à cause du setup actuel, il faut d’abord retirer les frictions qui siphonnent votre énergie.',
					],
					[
							"J'ai déjà essayé plein d'outils",
							"WinGlowz ne vend pas une nouvelle pile d'outils au hasard. La formation donne une logique de tri, de choix et de réduction.",
					],
					[
							'Je ne suis pas technique',
							"Le cœur de l'offre n'est pas la sophistication. C'est la clarté et la réduction du bruit.",
					],
					[
							"Je peux trouver ces infos gratuitement",
							"L'information existe déjà, mais elle est dispersée, contradictoire et rarement organisée en système cohérent.",
					],
					[
							"Je ne veux pas refaire tout mon setup",
							"Le but n'est pas de tout casser. Le but est d'enlever ce qui vous freine vraiment.",
					],
					[
							"Je suis sur Windows par contrainte",
							"C'est justement pour cela que la formation part du réel, pas d'un setup fantasme.",
					],
				],
				finalTitle: "Vous n'avez pas besoin de devenir une autre personne pour mieux travailler.",
				finalBody:
					"Vous avez besoin d'un environnement qui arrête enfin de vous freiner.",
			}
		: {
				title: 'Windows Mastery | WinGlowz',
				description:
					'A dedicated sales page for the WinGlowz Windows course: reduce friction, protect focus, and regain control over your work environment.',
				badge: 'Windows course • 8 modules • premium training path',
				heroTitle: 'Take back control of your Windows work environment',
				heroSubtitle:
					'A practical course to reduce friction, protect your focus, and turn your computer into a real work system.',
				heroBody: [
					'If you feel like you spend too much energy on tabs, interruptions, repeated searches, poorly chosen tools, and endless context switching, the problem is probably not you.',
					"The problem is the digital environment you're forced to work inside every day.",
				],
				primaryCta: 'Access the course',
				secondaryCta: 'See the curriculum',
				proof: ['8 structured modules', 'FR + EN', 'premium access after checkout'],
				problemTitle: 'The real problem',
				problemIntro: 'You probably do not need more motivation. You may mostly need less friction.',
				problemBullets: [
					'too many tabs and too many back-and-forths',
					'too much noise and too many interruptions',
					'too many poorly chosen or disconnected tools',
					'too much energy wasted searching, retrieving, and reorganizing',
				],
				mechanismTitle: 'Why the usual methods do not hold',
				mechanismBody: [
					'When work feels harder than it should, most people try to fix themselves: more motivation, a new app, a better to-do system, a fresh set of habits.',
					'But that means trying to solve a structural problem with willpower. If the environment stays noisy, fragmented, and badly configured, all of that collapses quickly.',
				],
				paradigmTitle: 'The new paradigm',
				paradigmIntro:
					'Productivity is not primarily a motivation problem. It is an architecture problem.',
				paradigmBullets: [
					'focus must be protected',
					'information must be retrievable',
					'tools must be chosen with logic',
					'the environment should remove noise before it asks for more effort',
				],
				solutionTitle: 'What WinGlowz does',
				solutionBody: [
					'WinGlowz is not a giant tool encyclopedia or a pile of hacks. The course teaches you how to build a Windows environment that is clearer, faster, more coherent, and more supportive.',
					'You are not just buying a list of software. You are buying a logic for configuration, tool choice, and use so you can recover mental bandwidth.',
				],
				audienceTitle: 'Who this is for',
				audienceIntro:
					'The pain does not look the same for everyone. But the mechanism stays the same: too much friction, not enough system.',
				audiences: [
					{
						title: 'Knowledge workers on Windows',
						body:
							'You juggle browsers, files, messages, notes, research, and documents. WinGlowz helps you recover clarity, continuity, and control.',
						cta: 'I want a cleaner environment',
					},
					{
						title: 'Creators / solopreneurs',
						body:
							'You need real blocks of time to create, but admin, messages, tools, and digital chaos keep eating your momentum. WinGlowz helps you protect your flow.',
						cta: 'I want to protect my flow',
					},
					{
						title: 'Developers / power users',
						body:
							'You already know Windows could go further. WinGlowz helps you build a cleaner, faster, more demanding setup without turning everything into gadgetry.',
						cta: 'I want a more demanding setup',
					},
				],
				modulesTitle: 'What the course contains',
				modulesIntro:
					'The course is organized into 8 modules that cover the main dimensions of a strong digital work system.',
				modules: [
					['Focus and environment', 'remove digital noise and protect real work sessions'],
					['Time and energy', 'design a more sustainable week and allocate effort better'],
					['Actions and execution', 'make action simpler, clearer, and less mentally expensive'],
					['Windows setup', 'configure the workstation around real use cases'],
					['Information and consumption', 'filter better, read better, capture better'],
					['Knowledge and retrieval', 'retrieve information and reuse what matters'],
					['Communication', 'reduce fragmentation across email, chat, and meetings'],
					['Shortcuts and speed', 'install the habits that lower execution cost'],
				],
				transformationTitle: 'What changes in practice',
				beforeTitle: 'Before',
				beforeBullets: [
					'you work against your computer',
					'you search too much',
					'you re-decide too much',
					'you tolerate too much noise',
					'you work in a broken, chopped-up flow',
				],
				afterTitle: 'After',
				afterBullets: [
					'you know what to simplify',
					'you know which tools to keep or ignore',
					'you retrieve information faster',
					'you protect work sessions better',
					'you work in a cleaner and more supportive environment',
				],
				proofTitle: 'Proof',
				testimonial:
					"Congratulations, Diane! I just spent 20 minutes in it and I'm already wondering what I've been doing with my life until now :)) Lots of goodies to improve my work. I love it!",
				testimonialAuthor: 'Florin Muresan',
				testimonialRole: 'CEO and Co-Founder | Squirrly',
				offerTitle: 'The offer',
				offerName: 'Complete Windows course',
				offerPrice: '$49',
				offerPeriod: 'one-time payment',
				offerBullets: ['8 modules', 'FR + EN', 'access through course enrollment', 'focused implementation updates'],
				offerBody:
					'This offer is for you if you want a concrete improvement to your Windows work environment without having to rediscover everything alone.',
				checkoutNote:
					'Sign in if needed, then go through secure checkout and unlock the premium path directly.',
				bundleTitle: 'If you want to go further',
				bundleBody:
					'The WinGlowz bundle exists for people who also want the complementary tools. It appears here as an upsell, not as the primary message.',
				bundleCta: 'See the WinGlowz bundle',
				faqTitle: 'Frequently asked questions',
				faq: [
					[
						'I already lack time',
						'Exactly. When each task costs too much because of your current setup, the first move is to remove the frictions draining your energy.',
					],
					[
						"I've already tried lots of tools",
						'WinGlowz is not another random tool stack. The course gives you a logic for filtering, choosing, and reducing.',
					],
					[
						"I'm not technical",
						'The core of the offer is not sophistication. It is clarity and noise reduction.',
					],
					[
						'I can find this information for free',
						'The information exists, but it is scattered, contradictory, and rarely organized into a coherent system.',
					],
					[
						"I don't want to rebuild my whole setup",
						'The goal is not to tear everything down. The goal is to remove what keeps slowing you down.',
					],
					[
						"I'm on Windows by constraint",
						'That is exactly why the course starts from reality instead of an idealized setup fantasy.',
					],
				],
				finalTitle: 'You do not need to become a different person to work better.',
				finalBody: 'You need an environment that finally stops slowing you down.',
			}
---

<MainLayout
	title={page.title}
	lang={lang}
	meta={{ description: page.description }}
	structuredData={{
		'@context': 'https://schema.org',
		'@type': 'Course',
		'@id': getLocalizedSiteUrl(lang, salesPath),
		url: getLocalizedSiteUrl(lang, salesPath),
		name: page.title,
		description: page.description,
		inLanguage: lang,
		provider: {
			'@type': 'Organization',
			name: SITE.name,
			url: SITE.url,
		},
	}}
>
	<section class="relative overflow-hidden border-b border-neutral-200 bg-gradient-to-b from-neutral-50 via-white to-neutral-100 dark:border-neutral-800 dark:from-black dark:via-black dark:to-zinc-950">
		<div class="mx-auto max-w-6xl px-4 pb-16 pt-14 sm:px-6 sm:pt-16 lg:px-8 lg:pb-24 lg:pt-20">
			<div class="max-w-4xl">
				<p class="mb-5 inline-flex rounded-full border border-neutral-300 px-4 py-2 text-sm font-semibold uppercase tracking-[0.16em] text-neutral-600 dark:border-neutral-700 dark:text-neutral-300">
					{page.badge}
				</p>
				<h1 class="max-w-4xl text-balance text-4xl font-bold tracking-tight text-neutral-950 dark:text-white sm:text-5xl lg:text-6xl">
					{page.heroTitle}
				</h1>
				<p class="mt-5 max-w-3xl text-lg leading-relaxed text-neutral-700 dark:text-neutral-300 sm:text-xl">
					{page.heroSubtitle}
				</p>
				<div class="mt-6 max-w-3xl space-y-4 text-base leading-relaxed text-neutral-600 dark:text-neutral-400 sm:text-lg">
					{page.heroBody.map((paragraph) => <p>{paragraph}</p>)}
				</div>
				<div class="mt-8 flex flex-col gap-4 sm:flex-row">
					<a href={checkoutUrl} class="inline-flex items-center justify-center rounded-xl bg-neutral-950 px-6 py-3 font-semibold text-white transition hover:bg-neutral-800 dark:bg-white dark:text-neutral-950 dark:hover:bg-neutral-200">
						{page.primaryCta}
					</a>
					<a href="#modules" class="inline-flex items-center justify-center rounded-xl border border-neutral-300 px-6 py-3 font-semibold text-neutral-800 transition hover:bg-neutral-100 dark:border-neutral-700 dark:text-neutral-100 dark:hover:bg-neutral-900">
						{page.secondaryCta}
					</a>
				</div>
				<div class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
					{page.proof.map((item) => (
						<div class="rounded-2xl border border-neutral-200 bg-white/80 px-4 py-4 text-sm font-medium text-neutral-700 shadow-sm backdrop-blur dark:border-neutral-800 dark:bg-neutral-900/70 dark:text-neutral-200">
							{item}
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
		<div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr]">
			<div>
				<h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white">{page.problemTitle}</h2>
				<p class="mt-5 text-lg leading-relaxed text-neutral-700 dark:text-neutral-300">{page.problemIntro}</p>
				<ul class="mt-6 space-y-3 text-neutral-600 dark:text-neutral-400">
					{page.problemBullets.map((bullet) => (
						<li class="flex gap-3">
							<span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-magenta"></span>
							<span>{bullet}</span>
						</li>
					))}
				</ul>
			</div>
			<div class="rounded-3xl border border-neutral-200 bg-neutral-50 p-8 dark:border-neutral-800 dark:bg-neutral-900">
				<h3 class="text-xl font-bold text-neutral-900 dark:text-white">{page.mechanismTitle}</h3>
				<div class="mt-5 space-y-4 text-neutral-600 dark:text-neutral-400">
					{page.mechanismBody.map((paragraph) => <p>{paragraph}</p>)}
				</div>
			</div>
		</div>
	</section>

	<section class="border-y border-neutral-200 bg-neutral-50/70 py-16 dark:border-neutral-800 dark:bg-neutral-900/40">
		<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
			<div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr]">
				<div>
					<h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white">{page.paradigmTitle}</h2>
					<p class="mt-5 text-lg leading-relaxed text-neutral-700 dark:text-neutral-300">{page.paradigmIntro}</p>
				</div>
				<div class="grid gap-4 sm:grid-cols-2">
					{page.paradigmBullets.map((item) => (
						<div class="rounded-2xl border border-neutral-200 bg-white p-5 text-neutral-700 shadow-sm dark:border-neutral-800 dark:bg-black dark:text-neutral-200">
							{item}
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
		<div class="grid gap-10 lg:grid-cols-[1fr_1fr]">
			<div>
				<h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white">{page.solutionTitle}</h2>
			</div>
			<div class="space-y-5 text-neutral-600 dark:text-neutral-400">
				{page.solutionBody.map((paragraph) => <p class="leading-relaxed">{paragraph}</p>)}
			</div>
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
		<div class="mb-10 max-w-3xl">
			<h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white">{page.audienceTitle}</h2>
			<p class="mt-4 text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">{page.audienceIntro}</p>
		</div>
		<div class="grid gap-6 lg:grid-cols-3">
			{page.audiences.map((audience) => (
				<div class="rounded-3xl border border-neutral-200 bg-white p-7 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
					<h3 class="text-xl font-bold text-neutral-900 dark:text-white">{audience.title}</h3>
					<p class="mt-4 text-neutral-600 dark:text-neutral-400">{audience.body}</p>
					<p class="mt-5 text-sm font-semibold uppercase tracking-[0.14em] text-magenta">{audience.cta}</p>
				</div>
			))}
		</div>
	</section>

	<section id="modules" class="border-y border-neutral-200 bg-neutral-50/70 py-16 dark:border-neutral-800 dark:bg-neutral-900/40">
		<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
			<div class="mb-10 max-w-3xl">
				<h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white">{page.modulesTitle}</h2>
				<p class="mt-4 text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">{page.modulesIntro}</p>
			</div>
			<div class="grid gap-5 md:grid-cols-2">
				{page.modules.map(([title, desc]) => (
					<div class="rounded-3xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-black">
						<h3 class="text-lg font-bold text-neutral-900 dark:text-white">{title}</h3>
						<p class="mt-3 text-neutral-600 dark:text-neutral-400">{desc}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
		<h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white">{page.transformationTitle}</h2>
		<div class="mt-8 grid gap-6 md:grid-cols-2">
			<div class="rounded-3xl border border-neutral-200 bg-white p-7 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
				<h3 class="text-xl font-bold text-neutral-900 dark:text-white">{page.beforeTitle}</h3>
				<ul class="mt-5 space-y-3 text-neutral-600 dark:text-neutral-400">
					{page.beforeBullets.map((bullet) => (
						<li class="flex gap-3">
							<span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-neutral-400"></span>
							<span>{bullet}</span>
						</li>
					))}
				</ul>
			</div>
			<div class="rounded-3xl border border-green/30 bg-green/5 p-7 shadow-sm dark:border-green/20 dark:bg-green/10">
				<h3 class="text-xl font-bold text-neutral-900 dark:text-white">{page.afterTitle}</h3>
				<ul class="mt-5 space-y-3 text-neutral-700 dark:text-neutral-200">
					{page.afterBullets.map((bullet) => (
						<li class="flex gap-3">
							<span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-green"></span>
							<span>{bullet}</span>
						</li>
					))}
				</ul>
			</div>
		</div>
	</section>

	<section class="border-y border-neutral-200 bg-neutral-950 py-16 text-white dark:border-neutral-800">
		<div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
			<h2 class="text-3xl font-bold tracking-tight">{page.proofTitle}</h2>
			<blockquote class="mt-8 rounded-3xl border border-white/10 bg-white/5 p-8 text-xl leading-relaxed text-neutral-100">
				“{page.testimonial}”
			</blockquote>
			<p class="mt-5 text-sm uppercase tracking-[0.16em] text-neutral-400">{page.testimonialAuthor}</p>
			<p class="text-neutral-500">{page.testimonialRole}</p>
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
		<div class="grid gap-8 lg:grid-cols-[1fr_0.8fr]">
			<div class="rounded-3xl border border-neutral-200 bg-white p-8 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
				<h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white">{page.offerTitle}</h2>
				<div class="mt-6 flex items-baseline gap-4">
					<p class="text-4xl font-bold text-neutral-900 dark:text-white">{page.offerPrice}</p>
					<p class="text-neutral-500 dark:text-neutral-400">{page.offerPeriod}</p>
				</div>
				<p class="mt-2 text-xl font-semibold text-neutral-800 dark:text-neutral-200">{page.offerName}</p>
				<p class="mt-5 max-w-2xl text-neutral-600 dark:text-neutral-400">{page.offerBody}</p>
				<ul class="mt-6 grid gap-3 sm:grid-cols-2">
					{page.offerBullets.map((item) => (
						<li class="flex items-center gap-3 rounded-2xl bg-neutral-50 px-4 py-3 text-neutral-700 dark:bg-black dark:text-neutral-200">
							<span class="h-2.5 w-2.5 rounded-full bg-green"></span>
							<span>{item}</span>
						</li>
					))}
				</ul>
				<a href={checkoutUrl} class="mt-8 inline-flex items-center justify-center rounded-xl bg-gradient-rainbow px-6 py-3 font-bold text-white transition hover:opacity-90">
					{page.primaryCta}
				</a>
				<p class="mt-4 text-sm text-neutral-500 dark:text-neutral-400">{page.checkoutNote}</p>
			</div>
			<div class="rounded-3xl border border-neutral-200 bg-neutral-50 p-8 dark:border-neutral-800 dark:bg-neutral-900/60">
				<h3 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-white">{page.bundleTitle}</h3>
				<p class="mt-4 text-neutral-600 dark:text-neutral-400">{page.bundleBody}</p>
				<a href={bundleUrl} class="mt-8 inline-flex items-center justify-center rounded-xl border border-neutral-300 px-6 py-3 font-semibold text-neutral-800 transition hover:bg-neutral-100 dark:border-neutral-700 dark:text-neutral-100 dark:hover:bg-neutral-800">
					{page.bundleCta}
				</a>
			</div>
		</div>
	</section>

	<section class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
		<h2 class="text-center text-3xl font-bold tracking-tight text-neutral-900 dark:text-white">{page.faqTitle}</h2>
		<div class="mt-10 space-y-4">
			{page.faq.map(([question, answer]) => (
				<div class="rounded-3xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
					<h3 class="text-lg font-bold text-neutral-900 dark:text-white">{question}</h3>
					<p class="mt-3 text-neutral-600 dark:text-neutral-400">{answer}</p>
				</div>
			))}
		</div>
	</section>

	<section class="mx-auto max-w-5xl px-4 py-16 text-center sm:px-6 lg:px-8 lg:py-24">
		<h2 class="text-balance text-4xl font-bold tracking-tight text-neutral-950 dark:text-white sm:text-5xl">
			{page.finalTitle}
		</h2>
		<p class="mx-auto mt-5 max-w-3xl text-lg text-neutral-600 dark:text-neutral-400 sm:text-xl">
			{page.finalBody}
		</p>
		<div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
			<a href={courseHubUrl} class="inline-flex items-center justify-center rounded-xl bg-neutral-950 px-6 py-3 font-semibold text-white transition hover:bg-neutral-800 dark:bg-white dark:text-neutral-950 dark:hover:bg-neutral-200">
				{page.primaryCta}
			</a>
			<a href="#modules" class="inline-flex items-center justify-center rounded-xl border border-neutral-300 px-6 py-3 font-semibold text-neutral-800 transition hover:bg-neutral-100 dark:border-neutral-700 dark:text-neutral-100 dark:hover:bg-neutral-900">
				{page.secondaryCta}
			</a>
		</div>
	</section>
</MainLayout>

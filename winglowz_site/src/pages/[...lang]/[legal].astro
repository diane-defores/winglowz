---
export const prerender = true
import MainLayout from '@/layouts/MainLayout.astro'
import { getLangFromUrl, useTranslations } from '@/utils/i18n'
import { SITE, getLocalizedSiteUrl } from '@/constants'

export function getStaticPaths() {
	return [
		{ params: { lang: undefined, legal: 'legal' } },
		{ params: { lang: 'fr', legal: 'mentions-legales' } },
	]
}

const lang = getLangFromUrl(Astro.url)
const t = await useTranslations(lang, 'legal')
const sections = (t.sections ?? {}) as Record<
	string,
	{ title?: string; intro?: string; items?: string[] }
>
const legalDescription = sections.legalInfo?.intro ?? ''
---

<MainLayout
	title={t.title}
	lang={lang}
	structuredData={{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		'@id': getLocalizedSiteUrl(lang, lang === 'fr' ? '/mentions-legales' : '/legal'),
		url: getLocalizedSiteUrl(lang, lang === 'fr' ? '/mentions-legales' : '/legal'),
		name: `${t.title} | ${SITE.name}`,
		description: legalDescription,
		inLanguage: lang,
	}}
>
	<div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
		<h1 class="mb-8 text-3xl font-bold text-neutral-900 dark:text-white">
			{t.title}
		</h1>

		<p class="mb-4 text-sm text-neutral-500 dark:text-neutral-400">
			{t.lastUpdated}
		</p>

		<div class="space-y-6 text-neutral-600 dark:text-neutral-400">
			{/* Section Informations Légales */}
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.legalInfo?.title}
			</h2>
			<p>{sections.legalInfo?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.legalInfo?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			{/* Section Activité Professionnelle */}
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.activity?.title}
			</h2>
			<p>{sections.activity?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.activity?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			{/* Section Hébergement */}
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.hosting?.title}
			</h2>
			<p>{sections.hosting?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.hosting?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			{/* Section Services d'Authentification */}
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.auth?.title}
			</h2>
			<p>{sections.auth?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.auth?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			{/* Section Propriété Intellectuelle */}
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.ip?.title}
			</h2>
			<p>{sections.ip?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.ip?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			{/* Section Protection des Données */}
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.dataProtection?.title}
			</h2>
			<p>{sections.dataProtection?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{
					(sections.dataProtection?.items ?? []).map((item: string) => (
						<li>{item}</li>
					))
				}
			</ul>

			{/* Section Assurance */}
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.insurance?.title}
			</h2>
			<p>{sections.insurance?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.insurance?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			{/* Section Litiges */}
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.disputes?.title}
			</h2>
			<p>{sections.disputes?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{(sections.disputes?.items ?? []).map((item: string) => <li>{item}</li>)}
			</ul>

			{/* Section Immatriculation */}
			<h2
				class="mb-4 mt-8 text-xl font-semibold text-neutral-800 dark:text-neutral-200"
			>
				{sections.registration?.title}
			</h2>
			<p>{sections.registration?.intro}</p>
			<ul class="list-disc space-y-2 pl-6">
				{
					(sections.registration?.items ?? []).map((item: string) => (
						<li>{item}</li>
					))
				}
			</ul>

			<p class="mt-8">
				{t.footer.updates}
			</p>
		</div>

		<p class="mt-8 text-sm text-neutral-500 dark:text-neutral-400">
			{t.footer.contact}
		</p>
	</div>
</MainLayout>

---
import MainLayout from '@/layouts/MainLayout.astro'
import KanbanBoard from '../../components/roadmap/KanbanBoard.astro'
import ProjectNav from '../../components/roadmap/ProjectNav.astro'
import AddFeatureModal from '../../components/roadmap/AddFeatureModal.astro'
import { projects } from '../../types/roadmap'
import type { Feature } from '../../types/roadmap'
import { ROADMAP_DEFAULT_FEATURES } from '@/lib/roadmapDefaults'
import { getLangFromUrl, useTranslations } from '@/utils/i18n'
import { ConvexHttpClient } from 'convex/browser'
import { getServerEnv } from '@/lib/serverEnv'

export const prerender = false

const lang = getLangFromUrl(Astro.url)
const t = await useTranslations(lang, 'roadmap')

const segments = Astro.url.pathname.split('/')
const projectId =
	segments[segments.length - 1] === 'roadmap'
		? null
		: segments[segments.length - 1]
const project = projectId ? projects.find((p) => p.id === projectId) : null

const defaultTranslations = {
	planned: 'Planned',
	inProgress: 'In Development',
	completed: 'Completed',
	considering: 'Ideas',
	rejected: 'Rejected',
	vote: 'Vote',
	votes: 'votes',
	loginToVote: 'Sign in to vote',
	accountNotReady: 'Your account is still syncing. Retry in a moment.',
	alreadyVoted: 'You already voted for this feature',
	voteFailed: 'Vote failed. Please retry.',
}

const translations = {
	planned: t?.status?.planned ?? defaultTranslations.planned,
	inProgress: t?.status?.inProgress ?? defaultTranslations.inProgress,
	completed: t?.status?.completed ?? defaultTranslations.completed,
	considering: t?.status?.considering ?? defaultTranslations.considering,
	rejected: t?.status?.rejected ?? defaultTranslations.rejected,
	vote: t?.feature?.vote ?? defaultTranslations.vote,
	votes: t?.feature?.votes ?? defaultTranslations.votes,
	loginToVote: t?.feature?.loginToVote ?? defaultTranslations.loginToVote,
	accountNotReady: t?.feature?.accountNotReady ?? defaultTranslations.accountNotReady,
	alreadyVoted: t?.feature?.alreadyVoted ?? defaultTranslations.alreadyVoted,
	voteFailed: t?.feature?.voteFailed ?? defaultTranslations.voteFailed,
}

const env = getServerEnv()
const convexUrl = env.PUBLIC_CONVEX_URL

async function loadRoadmapFeatures(): Promise<Feature[]> {
	if (!convexUrl || convexUrl === 'https://PLACEHOLDER.convex.cloud') {
		return projectId
			? ROADMAP_DEFAULT_FEATURES.filter((feature) => feature.projectId === projectId)
			: ROADMAP_DEFAULT_FEATURES
	}

	try {
		const convex = new ConvexHttpClient(convexUrl)
		const data = (await convex.query('features:list' as never, {
			projectId,
		} as never)) as Feature[]

		if (data.length > 0) {
			return data
		}
	} catch {
		// Fallback to the legacy catalog when Convex is unavailable.
	}

	return projectId
		? ROADMAP_DEFAULT_FEATURES.filter((feature) => feature.projectId === projectId)
		: ROADMAP_DEFAULT_FEATURES
}

const features = await loadRoadmapFeatures()
const featuresWithProjectNames =
	features.map((feature) => ({
		...feature,
		projectName:
			projects.find((p) => p.id === feature.projectId)?.name ??
			feature.projectId,
	})) ?? []

const pageTitle: string = project
	? `${project.name} - ${t?.title || 'Roadmap'}`
	: t?.title || 'Roadmap'
---

<MainLayout title={pageTitle} lang={lang}>
	<div class="min-h-screen bg-white dark:bg-neutral-900">
		<ProjectNav currentProjectId={projectId} />
		<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
			<KanbanBoard
				features={featuresWithProjectNames}
				showProjectName={!project}
				translations={translations}
			/>
		</div>
	</div>

	<AddFeatureModal />
</MainLayout>

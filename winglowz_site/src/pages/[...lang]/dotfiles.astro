---
import ScriptInstallPage from '@/components/scripts/ScriptInstallPage.astro'
import { getScriptInstallPage } from '@/data/scriptInstallPages'
import type { Language } from '@/types'

export const prerender = true

export async function getStaticPaths() {
	return [
		{ params: { lang: undefined }, props: { lang: 'en' as Language } },
		{ params: { lang: 'fr' }, props: { lang: 'fr' as Language } },
	]
}

const { lang } = Astro.props
---

<ScriptInstallPage lang={lang} page={getScriptInstallPage('dotfiles', lang)} />

---
export const prerender = true
import type { Language } from '@/types'
import { generateStaticPaths, getLocalizedPath } from '@/utils/routing'

export const getStaticPaths = () => generateStaticPaths('testimonials')

interface Props {
  lang: Language
}

const { lang } = Astro.props
const target = getLocalizedPath(lang, 'recommendations')
const canonical = new URL(target, Astro.site).toString()
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={canonical} />
    <script is:inline>
      {`window.location.replace(${JSON.stringify(target)});`}
    </script>
  </head>
  <body>
    <a href={target}>Continue to recommendations</a>
  </body>
</html>

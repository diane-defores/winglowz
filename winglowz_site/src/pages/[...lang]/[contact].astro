---
export const prerender = true
import MainLayout from '@/layouts/MainLayout.astro'
import ContactSection from '@/components/sections/ContactSection.astro'
import { useTranslations } from '@/utils/i18n'
import type { Language } from '@/types'
import { generateStaticPaths } from '@/utils/routing'
import { getLocalizedSiteUrl } from '@/constants'

export const getStaticPaths = () => generateStaticPaths('contact')

interface Props {
	lang: Language
}

const { lang } = Astro.props
const t = await useTranslations(lang, 'contact')

// S'assurer que t.title est une chaîne de caractères
const title: string = typeof t.title === 'string' ? t.title : 'Contact'
const description: string =
	typeof t.meta?.description === 'string' ? t.meta.description : ''
---

<MainLayout
	title={title}
	meta={{
		description: description,
	}}
	lang={lang}
	structuredData={{
		'@context': 'https://schema.org',
		'@type': 'ContactPage',
		'@id': getLocalizedSiteUrl(lang, '/contact'),
		url: getLocalizedSiteUrl(lang, '/contact'),
		name: title,
		description: description,
		inLanguage: lang,
	}}
>
	<ContactSection t={t} />
</MainLayout>
